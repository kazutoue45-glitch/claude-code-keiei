<style>
  /* =========================================
     §1 Hero（上下分割：紫帯／画像／白テキストエリア）
     ========================================= */
  .hero {
    position: relative;
    background: var(--paper);
    overflow: hidden;
  }

  .hero__topband {
    background: var(--purple);
    color: var(--paper);
    padding: 8px 0;
  }

  .hero__topband-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .hero__topband-logo {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0.06em;
    color: var(--paper);
  }

  .hero__topband-logo ruby rt {
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 1px;
    font-family: var(--font-sans);
  }

  .hero__topband-sub {
    font-size: 11px;
    line-height: 1.45;
    text-align: right;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.02em;
  }

  .hero__topband-sub small {
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.04em;
  }

  .hero__photo {
    position: relative;
    aspect-ratio: 16 / 13;
    max-height: 78vh;
    overflow: visible;
    background: var(--purple-deep);
  }

  .hero__photo > img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 60%;
  }

  /* 写真の下端に白フェード（白パネルへの繋ぎを自然に） */
  .hero__photo-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 55%, rgba(255, 255, 255, 0.92) 100%);
    pointer-events: none;
  }

  /* キャッチコピーを写真下端寄りに配置（バッジと高さを揃える） */
  .hero__catch {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0 28px 14px;
    z-index: 3;
  }

  /* §1 円形メダル型ゴールドバッジ（catch の下端ラインと揃える） */
  .hero__medal {
    position: absolute;
    bottom: 22px;
    right: 20px;
    width: 130px;
    height: 130px;
    z-index: 4;
    filter: drop-shadow(0 12px 22px rgba(26, 15, 46, 0.4));
    animation: medal-in 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero__medal img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  @keyframes medal-in {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero__panel {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 32px;
    position: relative;
    z-index: 2;
  }

  .hero__logo {
    display: block;
    width: clamp(180px, 52vw, 360px);
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(255, 255, 255, 0.6));
  }

  .hero__sub {
    font-size: 15px;
    line-height: 2;
    color: var(--charcoal-soft);
    letter-spacing: 0.02em;
    margin-bottom: 0;
  }

  /* FV内3サービスナビ：横幅いっぱい・斜め区切り位置をカード①③の内側に寄せる */
  .hero__nav {
    display: flex;
    width: 100%;
    scroll-margin-top: 80px;
    --slant: 28px;
  }

  .hero__nav :global(.svc-card) {
    flex: 1 1 0;
    min-width: 0;
  }

  /* カード①：右端の斜めを内側に slant 丸ごとシフト（カード①の上幅をカード②の上幅と揃える） */
  .hero__nav :global(.svc-card:nth-child(1)) {
    clip-path: polygon(0 0, calc(100% - var(--slant)) 0, calc(100% - 2 * var(--slant)) 100%, 0 100%);
    margin-right: calc(-2 * var(--slant));
  }

  /* カード②：両端を斜めに切る（変更なし） */
  .hero__nav :global(.svc-card:nth-child(2)) {
    clip-path: polygon(var(--slant) 0, 100% 0, calc(100% - var(--slant)) 100%, 0 100%);
    margin-right: calc(-3 * var(--slant) / 2);
  }

  /* カード③：左端の斜めを内側に slant/2 シフト（=可視幅を縮める） */
  .hero__nav :global(.svc-card:nth-child(3)) {
    clip-path: polygon(calc(3 * var(--slant) / 2) 0, 100% 0, 100% 100%, calc(var(--slant) / 2) 100%);
  }

  /* 斜めカット領域にnum/contentが食い込まないようパディング調整 */
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__num),
  .hero__nav :global(.svc-card:nth-child(3) .svc-card__num) {
    left: calc(18px + var(--slant) * 1.2);
  }
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__content),
  .hero__nav :global(.svc-card:nth-child(3) .svc-card__content) {
    padding-left: calc(18px + var(--slant));
  }
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__content) {
    padding-right: calc(18px + var(--slant));
  }
  /* カード①は右斜めを2倍シフトしているので、本文も矢印もその分内側に */
  .hero__nav :global(.svc-card:nth-child(1) .svc-card__content) {
    padding-right: calc(18px + 2 * var(--slant));
  }

  @media (max-width: 768px) {
    .hero__nav { --slant: 18px; }
    .hero__nav :global(.svc-card:nth-child(2) .svc-card__num),
    .hero__nav :global(.svc-card:nth-child(3) .svc-card__num) {
      left: calc(12px + var(--slant) * 1.1);
    }
  }

  @media (max-width: 380px) {
    .hero__topband-inner { padding: 0 18px; }
    .hero__topband-logo { font-size: 20px; }
    .hero__topband-sub { font-size: 10.5px; }
    .hero__panel { padding: 32px 20px 28px; }
    .hero__catch { padding: 0 20px 8px; }
    .hero__medal { width: 100px; height: 100px; bottom: 16px; right: 14px; }
  }

  @media (min-width: 769px) {
    .hero__topband { padding: 10px 0; }
    .hero__topband-logo { font-size: 26px; }
    .hero__topband-sub { font-size: 12px; }
    .hero__topband-sub small { font-size: 10px; }
    .hero__photo { aspect-ratio: 16 / 8; max-height: none; }
    .hero__panel { padding: 48px 32px 40px; }
    .hero__catch { padding: 0 56px 30px; }
    .hero__logo { width: clamp(280px, 38vw, 440px); }
    .hero__sub { font-size: 17px; }
    .hero__medal { width: 180px; height: 180px; bottom: 38px; right: 40px; }
  }

  /* =========================================
     §2 共感末尾の ZERO型 ▼ 視線誘導ブロック＋合格実績（証拠）
     ========================================= */
  .empathy__transition {
    position: relative;
    margin-top: 48px;
    background: var(--purple-deep);
    color: var(--paper);
    padding: 28px 24px 56px;
    /* 下端を ▼ に切り欠く（ZERO型） */
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 32px), 50% 100%, 0 calc(100% - 32px));
  }

  .empathy__transition-text {
    text-align: center;
    margin: 0;
  }

  .empathy__transition-text span {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: clamp(24px, 5.6vw, 34px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.5;
    letter-spacing: 0.08em;
  }

  /* 合格実績カードレール：▼ブロックから少し離して配置 */
  .trust__rail--inempathy {
    margin-top: 40px;
    margin-bottom: -32px;
  }

  @media (max-width: 768px) {
    .empathy__transition {
      margin-top: 32px;
      padding: 20px 20px 42px;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 22px), 50% 100%, 0 calc(100% - 22px));
    }
    .trust__rail--inempathy {
      margin-top: 28px;
      margin-bottom: -20px;
    }
  }

  .trust__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--purple);
    margin-bottom: 12px;
  }

  .trust__title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 4vw, 36px);
    color: var(--purple-deep);
    line-height: 1.5;
    margin-bottom: 32px;
  }

  /* レール：containerを超えて画面幅まで広げる */
  .trust__rail {
    margin: 0 calc(50% - 50vw);
    padding: 0 max(24px, calc((100vw - var(--container)) / 2));
  }

  .trust__cards {
    display: flex;
    flex-wrap: nowrap;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 0 18px;
    scrollbar-width: thin;
    scrollbar-color: var(--purple-line) transparent;
    -webkit-overflow-scrolling: touch;
  }
  .trust__cards::-webkit-scrollbar { height: 6px; }
  .trust__cards::-webkit-scrollbar-thumb {
    background: var(--purple-line);
    border-radius: 3px;
  }
  .trust__cards::-webkit-scrollbar-track { background: transparent; }

  /* 各カード：背景写真 or プレースホルダ */
  .trust__card {
    flex: 0 0 auto;
    width: 220px;
    aspect-ratio: 4 / 3;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background-color: var(--purple);
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow-sm);
  }

  /* 写真なし：パープル系の塗りつぶしカード */
  .trust__card--placeholder {
    background: linear-gradient(135deg, var(--purple) 0%, var(--purple-deep) 100%);
  }

  /* 写真あり：暗幕オーバーレイ（下半分グラデ） */
  .trust__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.0) 30%, rgba(0, 0, 0, 0.65) 100%);
  }
  .trust__card--placeholder .trust__card-overlay {
    background: none;
  }

  .trust__card-content {
    position: absolute;
    inset: 0;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 1;
  }

  .trust__card-group {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.92);
