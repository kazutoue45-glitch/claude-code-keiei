---
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ReasonCard from "../components/ReasonCard.astro";
import ServiceCompareTable from "../components/ServiceCompareTable.astro";
import VoiceCard from "../components/VoiceCard.astro";
import AchievementBadge from "../components/AchievementBadge.astro";
import TeacherCard from "../components/TeacherCard.astro";
import PriceTable from "../components/PriceTable.astro";
import PricePlan from "../components/PricePlan.astro";
import QaItem from "../components/QaItem.astro";
import CtaButton from "../components/CtaButton.astro";

const base = import.meta.env.BASE_URL;

// §2 信頼帯：合格校（写真があるものはWikipediaから、無いものは色面プレースホルダ）
const passSchools = [
  { name: "大阪国際", group: "中学受験", img: "osaka-kokusai.jpg" },
  { name: "常翔啓光学園", group: "中学受験", img: "keiko.jpg" },
  { name: "寝屋川", group: "高校受験", img: "neyagawa.jpg" },
  { name: "牧野", group: "高校受験", img: "makino.jpg" },
  { name: "四條畷", group: "高校受験", img: "shijonawate.jpg" },
  { name: "東", group: "高校受験", img: "higashi.jpg" },
  { name: "枚方", group: "高校受験", img: "hirakata.jpg" },
  { name: "香里丘", group: "高校受験", img: "korigaoka.jpg" },
  { name: "北かわち皐が丘", group: "高校受験", img: "kitakawachi.jpg" },
  { name: "いちりつ", group: "高校受験", img: "ichiritsu.jpg" },
  { name: "大阪国際", group: "高校受験", img: "osaka-kokusai.jpg" },
  { name: "東海大付大阪仰星", group: "高校受験", img: "gyosei.jpg" },
  { name: "香里ヌヴェール学院", group: "高校受験", img: "kori-nuvelle.jpg" },
  { name: "四條畷学園", group: "高校受験", img: "shijonawate-gakuen.jpg" },
  { name: "常翔啓光学園", group: "高校受験", img: "keiko.jpg" },
];

// 3サービス（クイックナビ用・縦長カラムカード）
const services = [
  {
    index: "01",
    title: "義塾（リアル校舎）",
    shortLabel: "成田町の校舎で学ぶ",
    anchorId: "service-real",
    accentColor: "#4C1D95",
    bgImage: `${base}images/room-class.jpg`,
  },
  {
    index: "02",
    title: "義塾オンライン",
    shortLabel: "ご自宅から1対1",
    anchorId: "service-online",
    accentColor: "#2E8B57",
    bgImage: `${base}images/building-exterior.jpg`,
  },
  {
    index: "03",
    title: "義塾の家庭教師",
    shortLabel: "講師がご自宅へ訪問",
    anchorId: "service-tutor",
    accentColor: "#2563B8",
    bgImage: `${base}images/building-sign.jpg`,
  },
];

// 3サービス比較表用（§5.6 スキャナブル）
const servicesCompare = [
  {
    name: "リアル校舎",
    target: "小3〜高3",
    form: "個別／クラス",
    price: "14,300〜44,000円",
    forWhom: "通塾可能・集団で切磋琢磨",
    accent: "#4C1D95",
  },
  {
    name: "オンライン",
    target: "小4〜社会人",
    form: "1対1（4講座）",
    price: "22,000円〜",
    forWhom: "専門領域を深掘り",
    accent: "#2E8B57",
  },
  {
    name: "家庭教師",
    target: "中1〜高2",
    form: "訪問1対1",
    price: "26,400円〜",
    forWhom: "進路相談込みのマンツー",
    accent: "#2563B8",
  },
];

// 共感ブロック Before：6項目チェックリスト（悩み）
const empathyItems = [
  "お子様のテストの点数が伸び悩んでいる",
  "受験までに間に合うか不安",
  "子どもに合う指導形態（個別／クラス／オンライン／家庭教師）が分からない",
  "通塾の送迎が大変",
  "自宅学習だと集中できない",
  "進路や勉強法を相談できる相手が欲しい",
];

// 共感ブロック After：6項目の解決約束（Beforeと同じ並び順）
const solveItems = [
  "学び方から見直し、点数の伸びる指導を設計します",
  "入塾面談で、受験までのカリキュラムを一緒に設計します",
  "リアル校舎／オンライン／家庭教師の3つから最適な形をご提案します",
  "ご自宅で受けられるオンライン・家庭教師も選べます",
  "集中できる校舎環境と週次の伴走で学習を習慣化します",
  "塾長と公式LINEで直接ご相談いただけます",
];

// §4 選ばれる3つの理由
const reasons = [
  {
    number: "01",
    title: "「塾長の私が、最後まで責任を持ってお返事します。」",
    bullets: [
      "大手チェーン塾では難しい、塾長と保護者の直接コミュニケーション",
      "進路相談・成績不振の相談・通塾相談まで、公式LINEから直接連絡可能",
      "担当が変わっても、塾長は変わらず伴走する",
    ],
    iconSrc: `${base}images/reason-icon-line.png`,
    iconAlt: "公式LINEで塾長と直接つながる",
  },
  {
    number: "02",
    title: "「お子様の状況に、塾を合わせる。」",
    bullets: [
      "リアル校舎・オンライン1対1・家庭教師訪問の3サービスを併走",
      "部活・習い事・送迎事情・性格・志望校に合わせて最適な学び方を提案",
      "入塾後も状況変化に応じて指導形態を柔軟に変更可能",
    ],
    iconSrc: `${base}images/reason-icon-fork.png`,
    iconAlt: "3つの学び方から選べる柔軟性",
  },
  {
    number: "03",
    title: "「ベテランから若手まで、得意領域を持つ9人体制。」",
    bullets: [
      "中学受験・高校受験・大学受験すべてに対応できる講師布陣",
      "TOEIC990点23回連続満点・英検1級保持のスペシャリストも在籍",
      "1人の講師に依存しないチーム指導で、苦手単元を講師同士でカバー",
    ],
    iconSrc: `${base}images/reason-icon-team.png`,
    iconAlt: "9名の講師チーム",
  },
];

// §6 保護者の声（仮値・要差し替え／avatarSrc は claude-design Anti-slop "no fake faces" のため null）
const parentVoices = [
  {
    name: "Aさんのお母様",
    role: "中3／高校受験",
    quote: "数学が苦手で、夏休み前まで本当に間に合うのか不安でした。塾長が公式LINEで何度も状況を共有してくださり、家でどう声をかければいいかまで一緒に考えてくれて。本人も「先生が見てくれてる」と安心して机に向かえるようになりました。",
  },
  {
    name: "Bさんのお父様",
    role: "高2／大学受験",
    quote: "部活との両立が心配でしたが、時間割を柔軟に組んでもらえたので最後まで続けられました。先生方それぞれの得意分野で見てくださるので、苦手科目も逃げずに向き合えたと思います。",
  },
  {
    name: "Cさんのお母様",
    role: "小6／中学受験",
    quote: "大手塾も体験しましたが、最終的に義塾を選びました。一人ひとりの様子を見て指導の進め方を変えてくれる柔軟さが決め手です。志望校に合格できて、親子で本当に感謝しています。",
  },
];

// §6 生徒の声（仮値・要差し替え）
const studentVoices = [
  {
    name: "Dくん",
    role: "中3／高校受験合格",
    quote: "質問しやすい雰囲気で、分からないところを放置せずに済みました。授業外でも先生がLINEで答えてくれて助かりました。",
  },
  {
    name: "Eさん",
    role: "高3／大学受験合格",
    quote: "自分の志望校に詳しい先生が指導してくれたので、効率よく対策できました。",
  },
];

// FAQ（§9）
const faqs = [
  {
    q: "初月授業料1ヶ月無料の対象や条件を教えてください。",
    a: '新規入塾生限定のキャンペーンです。対象期間・対象サービス・対象学年・適用条件の詳細は、公式LINEからお問い合わせください。<!-- 要確認: キャンペーン詳細条件 -->',
  },
  {
    q: "公式LINEに登録したら、しつこく勧誘されませんか？",
    a: "ご安心ください。義塾の公式LINEは、塾長との相談窓口としてご利用いただくものです。ご家庭の状況をうかがった上でご案内するため、無理な勧誘や強引な営業は一切いたしません。ご相談だけで終わっていただいて構いません。<!-- 要確認: 勧誘ポリシーの最終文言 -->",
  },
  {
    q: "無料体験はできますか？",
    a: "はい、公式LINE登録後、塾長との個別相談を経て無料体験授業をご案内します（リアル校舎・オンライン・家庭教師いずれも対応）。",
  },
  {
    q: "途中で退塾する場合の手続きは？",
    a: "月末締めでのご退塾手続きが基本です。違約金等は発生しません。<!-- 要確認: 退塾手続きの正確なルール -->",
  },
  {
    q: "部活や習い事と両立できますか？",
    a: "はい、リアル校舎は17:00〜21:40の中から時間帯を選択でき、家庭教師は曜日・時間をご家庭の都合に合わせて調整します。オンラインなら移動時間ゼロで両立しやすくなります。",
  },
  {
    q: "途中で指導形態（リアル↔オンライン↔家庭教師）を変更できますか？",
    a: "状況に応じて柔軟にご相談いただけます。塾長との個別面談で最適な形をご提案します。<!-- 要確認: 形態変更時の事務手続き -->",
  },
  {
    q: "受験対策はどの学年から始めればよいですか？",
    a: "中学受験は小3〜小5、高校受験は中1〜中2、大学受験は高1からのスタートが理想です。学年や状況に応じて、塾長が最適なプランをご提案します。",
  },
];
---

<Base>
  {/* ============ §1 ファーストビュー ============ */}
  <section class="hero">
    {/* 上部全幅の紫帯：ロゴ＋住所サブ */}
    <div class="hero__topband">
      <div class="hero__topband-inner">
        <span class="hero__topband-logo">
          <ruby>義塾<rt>よしじゅく</rt></ruby>
        </span>
        <span class="hero__topband-sub">
          寝屋川市成田町の学習塾<br />
          <small>小学生・中学生・高校生 対応</small>
        </span>
      </div>
    </div>

    {/* FV画像エリア（実写：義塾校舎外観＋キャッチコピーオーバーレイ） */}
    <div class="hero__photo">
      <img src={`${base}images/building-exterior.jpg`} alt="義塾の校舎外観（寝屋川市成田町）" loading="eager" />
      <span class="hero__photo-tint" aria-hidden="true"></span>

      {/* タイトル：義塾ロゴ（毛筆書道・透過PNG） */}
      <h1 class="hero__catch">
        <img src={`${base}images/logo-yoshijuku.png`} alt="義塾（よしじゅく）" class="hero__logo" loading="eager" />
      </h1>

      {/* §1 円形メダル型ゴールドバッジ（写真下端寄り・白パネルにまたぐ） */}
      <div class="hero__medal" aria-label="新規入塾生限定 初月授業料1ヶ月無料">
        <img src={`${base}images/badge-medal.png`} alt="新規入塾生限定 初月授業料1ヶ月無料" loading="eager" />
      </div>
    </div>

    {/* 下段：白背景のテキストエリア（サブコピー） */}
    <div class="hero__panel">
      <p class="hero__sub">
        <span class="mark">寝屋川・成田町で高校受験に向き合うご家庭へ。</span><br />
        お子様を合格させたい想いに、<span class="num">9</span>人の講師陣が本気で応えます。
      </p>
    </div>

    {/* 3サービスナビ：横幅いっぱい・gap無し */}
    <div class="hero__nav" id="services">
      {services.map((s) => <ServiceCard {...s} />)}
    </div>

  </section>

  {/* CTA ① FV直下（FV紫専用） */}
  <CtaButton text="今だけ初月無料で申し込む" href="#" id="cta-1" variant="fv" />

  {/* ============ §2 共感＋解決＋合格実績 ============ */}
  <section class="section section--purple-pale empathy">
    <div class="container">
      <SectionHeader
        title="成績・進路で、こんなお悩みありませんか？"
        lead="一つでも当てはまるなら、<span class='mark'>一人で抱え込まずに義塾にご相談ください。</span>"
      />

      {/* ① Before：悩みリスト＋左にシルエット（リストに追従） */}
      <div class="empathy__pair empathy__pair--problems">
        <img class="empathy__silhouette empathy__silhouette--problems" src={`${base}images/empathy-silhouette-question.png`} alt="" aria-hidden="true" />
        <ul class="empathy__list empathy__list--problems">
          {empathyItems.map((item) => (
            <li>
              <span class="empathy__mark empathy__mark--q" aria-hidden="true">?</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      {/* ② 橋渡しコピー */}
      <p class="empathy__bridge">
        上記に一つでも当てはまるなら、<br />
        <span>義塾はこれで解決します！</span>
      </p>

      {/* ③ After：解決リスト＋右にシルエット（具体的な解決約束 6項目） */}
      <div class="empathy__pair empathy__pair--solve">
        <ul class="empathy__list empathy__list--solve">
          {solveItems.map((item) => (
            <li>
              <span class="empathy__check" aria-hidden="true">
                <svg viewBox="0 0 28 28" fill="none" width="28" height="28">
                  <path d="M5 14l6 6 13-13" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <img class="empathy__silhouette empathy__silhouette--solve" src={`${base}images/empathy-silhouette-solved.png`} alt="" aria-hidden="true" />
      </div>
    </div>

    {/* ④ ZERO型 ▼ 視線誘導ブロック＋証拠への橋渡し */}
    <div class="empathy__transition">
      <p class="empathy__transition-text">
        <span>2026年合格実績</span>
      </p>
    </div>

    {/* ⑤ 合格実績カード（証拠） */}
    <div class="trust__rail trust__rail--inempathy">
      <ul class="trust__cards" aria-label="合格校一覧">
        {passSchools.map((s) => (
          <li
            class={`trust__card ${s.img ? "" : "trust__card--placeholder"}`}
            style={s.img ? `background-image: url(${base}images/schools/${s.img});` : ""}
          >
            <span class="trust__card-overlay" aria-hidden="true"></span>
            <div class="trust__card-content">
              <span class="trust__card-group">{s.group}</span>
              <span class="trust__card-name">{s.name}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* CTA ② 共感末尾 */}
  <CtaButton text="塾長に無料相談する" href="#" id="cta-2" />

  {/* ============ §3 3つの学び方（脱カード・レイヤー構成） ============ */}
  <section class="section section--white learn section-anchor" id="services">
    <div class="container">
      <SectionHeader
        title="お子様に合う学び方が、必ずあります。"
        lead="成績が伸びないのは、お子様の能力ではなく、<span class='mark'>学び方が合っていないだけ</span>かもしれません。義塾は、リアル校舎・オンライン・家庭教師の<span class='num'>3</span>サービスを併走しています。"
      />

    </div>

    <article class="service service--real section-anchor" id="service-real" style="--accent:#4C1D95;--accent-deep:#2D1167;">
      <div class="service__hero">
        <img class="service__hero-photo" src={`${base}images/hero-real.jpg`} alt="義塾の校舎・個別指導教室" loading="lazy" />
        <div class="service__hero-tint" aria-hidden="true"></div>
        <div class="service__hero-content">
          <div class="container">
            <span class="service__num" aria-hidden="true">01</span>
            <p class="service__eyebrow">通塾型｜個別＋クラス</p>
            <p class="service__name">義塾のリアル校舎</p>
            <h3 class="service__catch">質問できる距離で、<br />考える力を育てる。</h3>
          </div>
        </div>
      </div>

      <div class="service__body">
        <div class="container">
          <div class="service__story">
            <p>「家ではどうしてもやる気が出ない」「親の前では、ついサボってしまう」——保護者の方からよく聞くお声です。</p>
            <p>義塾の校舎は、そんなお子様にとっての <span class="mark">「集中できる場所」</span> になります。9人の講師陣と顔を合わせ、わからないことをその場で質問できる。同じ机に向かう仲間がいる。教室の空気が、お子様の背中をそっと押し続けます。</p>
            <p>個別指導とクラス授業を、その時々の状況に合わせて<span class="mark">使い分けられる</span>のも義塾だけの強み。基礎固めから受験対策まで、お子様のペースで「考える力」を育てます。</p>
          </div>

          <ul class="service__meta">
            <li><span>対象</span><b>小3〜高3</b></li>
            <li><span>指導形態</span><b>個別／クラス</b></li>
            <li><span>月額目安</span><b>14,300〜44,000円</b></li>
          </ul>

          <div class="service__forwhom">
            <p class="service__forwhom-title">こんな方におすすめ</p>
            <ul>
              <li>通塾できる</li>
              <li>講師と顔を合わせて学びたい</li>
              <li>クラスで切磋琢磨したい</li>
            </ul>
          </div>

          <details class="service__details">
            <summary>時間割・担当講師・校舎の詳細を見る</summary>

            <div class="service__details-section">
              <h4>時間割</h4>
              <ul>
                <li>月・水・木・金 17:00〜21:40</li>
                <li>1コマ45分の選択制（個別指導）</li>
                <li>クラス授業は学年別に固定時間（中1：水19:05〜20:45／中3：木金19:05〜21:40／高1：月19:05〜21:40／高3：月水木19:05〜21:40）</li>
              </ul>
            </div>

            <div class="service__details-section">
              <h4>担当講師（9名体制）</h4>
              <ul>
                <li>塾長：小川 大輔（指導歴12年・複数校舎の立ち上げ経験）</li>
                <li>國府 泰：大手予備校20年超の英語ベテラン（TOEIC990点23回連続・英検1級）</li>
                <li>大学受験専任講師</li>
                <li>学校の教員免許を持つ講師</li>
                <li>元気あふれる若手講師 ほか</li>
              </ul>
            </div>

            <div class="service__details-section">
              <h4>校舎（新築一戸建てを改装した3教室）</h4>
              <ul>
                <li>第一教室：クラス授業用の大きめの教室</li>
                <li>第二教室：1枚板の机がある個別指導教室</li>
                <li>第三教室：多目的に使用</li>
              </ul>
            </div>

            <a class="service__cta service__cta--in-details" href="#" data-service="real">公式LINEで無料相談する<span aria-hidden="true">›</span></a>
          </details>
        </div>
      </div>
    </article>

    <article class="service service--online section-anchor" id="service-online" style="--accent:#2E8B57;--accent-deep:#1F6240;">
      <div class="service__hero">
        <img class="service__hero-photo" src={`${base}images/hero-online.jpg`} alt="自宅でオンライン1対1授業を受ける生徒" loading="lazy" />
