---
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ReasonCard from "../components/ReasonCard.astro";
import ServiceCompareTable from "../components/ServiceCompareTable.astro";
import VoiceCard from "../components/VoiceCard.astro";
import AchievementBadge from "../components/AchievementBadge.astro";
import TeacherCard from "../components/TeacherCard.astro";
import PriceTable from "../components/PriceTable.astro";
import PricePlan from "../components/PricePlan.astro";
import QaItem from "../components/QaItem.astro";
import CtaButton from "../components/CtaButton.astro";

const base = import.meta.env.BASE_URL;

// 3サービス（クイックナビ用・縦長カラムカード）
const services = [
  {
    index: "01",
    title: "義塾（リアル校舎）",
    shortLabel: "成田町の校舎で学ぶ",
    anchorId: "service-real",
    accentColor: "#4C1D95",
    bgImage: `${base}images/room-class.jpg`,
  },
  {
    index: "02",
    title: "義塾オンライン",
    shortLabel: "ご自宅から1対1",
    anchorId: "service-online",
    accentColor: "#2E8B57",
    bgImage: `${base}images/building-exterior.jpg`,
  },
  {
    index: "03",
    title: "義塾の家庭教師",
    shortLabel: "講師がご自宅へ訪問",
    anchorId: "service-tutor",
    accentColor: "#2563B8",
    bgImage: `${base}images/building-sign.jpg`,
  },
];

// 3サービス比較表用（§5.6 スキャナブル）
const servicesCompare = [
  {
    name: "リアル校舎",
    target: "小3〜高3",
    form: "個別／クラス",
    price: "14,300〜44,000円",
    forWhom: "通塾可能・集団で切磋琢磨",
    accent: "#4C1D95",
  },
  {
    name: "オンライン",
    target: "小4〜社会人",
    form: "1対1（4講座）",
    price: "22,000円〜",
    forWhom: "専門領域を深掘り",
    accent: "#2E8B57",
  },
  {
    name: "家庭教師",
    target: "中1〜高2",
    form: "訪問1対1",
    price: "26,400円〜",
    forWhom: "進路相談込みのマンツー",
    accent: "#2563B8",
  },
];

// 共感ブロック チェックリスト
const empathyItems = [
  "お子様のテストの点数が伸び悩んでいる",
  "受験までに間に合うか不安",
  "子どもに合う指導形態（個別／クラス／オンライン／家庭教師）が分からない",
  "通塾の送迎が大変",
  "自宅学習だと集中できない",
  "進路や勉強法を相談できる相手が欲しい",
];

// §4 選ばれる3つの理由
const reasons = [
  {
    number: "01",
    title: "「塾長の私が、最後まで責任を持ってお返事します。」",
    bullets: [
      "大手チェーン塾では難しい、塾長と保護者の直接コミュニケーション",
      "進路相談・成績不振の相談・通塾相談まで、公式LINEから直接連絡可能",
      "担当が変わっても、塾長は変わらず伴走する",
    ],
    iconSrc: `${base}images/reason-icon-line.svg`,
    iconAlt: "公式LINEで塾長と直接つながる",
  },
  {
    number: "02",
    title: "「お子様の状況に、塾を合わせる。」",
    bullets: [
      "リアル校舎・オンライン1対1・家庭教師訪問の3サービスを併走",
      "部活・習い事・送迎事情・性格・志望校に合わせて最適な学び方を提案",
      "入塾後も状況変化に応じて指導形態を柔軟に変更可能",
    ],
    iconSrc: `${base}images/reason-icon-fork.svg`,
    iconAlt: "3つの学び方から選べる柔軟性",
  },
  {
    number: "03",
    title: "「ベテランから若手まで、得意領域を持つ8人体制。」",
    bullets: [
      "中学受験・高校受験・大学受験すべてに対応できる講師布陣",
      "TOEIC990点23回連続満点・英検1級保持のスペシャリストも在籍",
      "1人の講師に依存しないチーム指導で、苦手単元を講師同士でカバー",
    ],
    iconSrc: `${base}images/reason-icon-team.svg`,
    iconAlt: "8名の講師チーム",
  },
];

// §6 保護者の声（仮値・要差し替え）
const parentVoices = [
  {
    avatarSrc: `${base}images/voice-avatar-1.svg`,
    name: "Aさんのお母様",
    role: "中3／高校受験",
    quote: "数学が苦手で、夏休み前まで本当に間に合うのか不安でした。塾長が公式LINEで何度も状況を共有してくださり、家でどう声をかければいいかまで一緒に考えてくれて。本人も「先生が見てくれてる」と安心して机に向かえるようになりました。",
  },
  {
    avatarSrc: `${base}images/voice-avatar-2.svg`,
    name: "Bさんのお父様",
    role: "高2／大学受験",
    quote: "部活との両立が心配でしたが、時間割を柔軟に組んでもらえたので最後まで続けられました。先生方それぞれの得意分野で見てくださるので、苦手科目も逃げずに向き合えたと思います。",
  },
  {
    avatarSrc: `${base}images/voice-avatar-3.svg`,
    name: "Cさんのお母様",
    role: "小6／中学受験",
    quote: "大手塾も体験しましたが、最終的に義塾を選びました。一人ひとりの様子を見て指導の進め方を変えてくれる柔軟さが決め手です。志望校に合格できて、親子で本当に感謝しています。",
  },
];

// §6 生徒の声（仮値・要差し替え）
const studentVoices = [
  {
    avatarSrc: `${base}images/voice-avatar-4.svg`,
    name: "Dくん",
    role: "中3／高校受験合格",
    quote: "質問しやすい雰囲気で、分からないところを放置せずに済みました。授業外でも先生がLINEで答えてくれて助かりました。",
  },
  {
    avatarSrc: `${base}images/voice-avatar-5.svg`,
    name: "Eさん",
    role: "高3／大学受験合格",
    quote: "自分の志望校に詳しい先生が指導してくれたので、効率よく対策できました。",
  },
];

// FAQ（§9）
const faqs = [
  {
    q: "初月授業料1ヶ月無料の対象や条件を教えてください。",
    a: '新規入塾生限定のキャンペーンです。対象期間・対象サービス・対象学年・適用条件の詳細は、公式LINEからお問い合わせください。<!-- 要確認: キャンペーン詳細条件 -->',
  },
  {
    q: "公式LINEに登録したら、しつこく勧誘されませんか？",
    a: "ご安心ください。義塾の公式LINEは、塾長との相談窓口としてご利用いただくものです。ご家庭の状況をうかがった上でご案内するため、無理な勧誘や強引な営業は一切いたしません。ご相談だけで終わっていただいて構いません。<!-- 要確認: 勧誘ポリシーの最終文言 -->",
  },
  {
    q: "無料体験はできますか？",
    a: "はい、公式LINE登録後、塾長との個別相談を経て無料体験授業をご案内します（リアル校舎・オンライン・家庭教師いずれも対応）。",
  },
  {
    q: "途中で退塾する場合の手続きは？",
    a: "月末締めでのご退塾手続きが基本です。違約金等は発生しません。<!-- 要確認: 退塾手続きの正確なルール -->",
  },
  {
    q: "部活や習い事と両立できますか？",
    a: "はい、リアル校舎は17:00〜21:40の中から時間帯を選択でき、家庭教師は曜日・時間をご家庭の都合に合わせて調整します。オンラインなら移動時間ゼロで両立しやすくなります。",
  },
  {
    q: "途中で指導形態（リアル↔オンライン↔家庭教師）を変更できますか？",
    a: "状況に応じて柔軟にご相談いただけます。塾長との個別面談で最適な形をご提案します。<!-- 要確認: 形態変更時の事務手続き -->",
  },
  {
    q: "受験対策はどの学年から始めればよいですか？",
    a: "中学受験は小3〜小5、高校受験は中1〜中2、大学受験は高1からのスタートが理想です。学年や状況に応じて、塾長が最適なプランをご提案します。",
  },
];
---

<Base>
  {/* ============ §1 ファーストビュー ============ */}
  <section class="hero">
    {/* 上部全幅の紫帯：ロゴ＋住所サブ */}
    <div class="hero__topband">
      <div class="hero__topband-inner">
        <span class="hero__topband-logo">
          <ruby>義塾<rt>よしじゅく</rt></ruby>
        </span>
        <span class="hero__topband-sub">
          寝屋川市成田町の学習塾<br />
          <small>小学生・中学生・高校生 対応</small>
        </span>
      </div>
    </div>

    {/* FV画像エリア（実写：義塾校舎外観＋キャッチコピーオーバーレイ） */}
    <div class="hero__photo">
      <img src={`${base}images/building-exterior.jpg`} alt="義塾の校舎外観（寝屋川市成田町）" loading="eager" />
      <span class="hero__photo-tint" aria-hidden="true"></span>

      {/* タイトル：義塾ロゴ（毛筆書道・透過PNG） */}
      <h1 class="hero__catch">
        <img src={`${base}images/logo-yoshijuku.png`} alt="義塾（よしじゅく）" class="hero__logo" loading="eager" />
      </h1>

      {/* §1 円形メダル型ゴールドバッジ（写真下端寄り・白パネルにまたぐ） */}
      <div class="hero__medal" aria-label="新規入塾生限定 初月授業料1ヶ月無料">
        <img src={`${base}images/badge-medal.png`} alt="新規入塾生限定 初月授業料1ヶ月無料" loading="eager" />
      </div>
    </div>

    {/* 下段：白背景のテキストエリア（サブコピー＋チップ） */}
    <div class="hero__panel">
      <p class="hero__sub">
        『行きたい高校・大学に合格させたい』<br />
        その想いに、8人の講師陣が本気で応えます。
      </p>

      {/* 3つの実績ポイントチップ */}
      <ul class="hero__chips" role="list">
        <li>
          <span class="hero__chip-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M3 9l9-5 9 5-9 5-9-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M7 11v5c0 1 2.5 2 5 2s5-1 5-2v-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M21 9v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="hero__chip-text">中学・高校・大学<br />受験すべて対応</span>
        </li>
        <li>
          <span class="hero__chip-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M21 12c0 4.4-4 8-9 8-1.5 0-3-.3-4.3-.9L3 20l1.4-3.6C3.5 15.2 3 13.6 3 12c0-4.4 4-8 9-8s9 3.6 9 8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="hero__chip-text">公式LINEで<br />塾長と直接相談できる</span>
        </li>
        <li>
          <span class="hero__chip-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <circle cx="12" cy="9" r="2.6" stroke="currentColor" stroke-width="1.6"/>
            </svg>
          </span>
          <span class="hero__chip-text">寝屋川市成田町・<br />成田山不動尊近く</span>
        </li>
      </ul>
    </div>

  </section>

  {/* CTA ① FV直下（FV紫専用） */}
  <CtaButton text="今だけ初月無料で申し込む" href="#" id="cta-1" variant="fv" />

  {/* ============ §2 サービスクイックナビ（帯型カード3段・背景画像付き） ============ */}
  <section class="section quicknav">
    <span class="quicknav__bg" aria-hidden="true"></span>
    <div class="container">
      <header class="quicknav__head">
        <span class="quicknav__eyebrow">学び方を選ぶ</span>
        <h2 class="quicknav__title">あなたに合う、3つの学び方。</h2>
        <p class="quicknav__lead">
          通塾・オンライン・家庭教師から、お子様の状況に合わせて選べます。
        </p>
      </header>
      <div class="quicknav__list" id="services">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  {/* ============ §3 共感ブロック ============ */}
  <section class="section section--bg section--bg-empathy empathy">
    <div class="container">
      <SectionHeader
        title="「うちの子、本当に大丈夫かな。」"
        lead="夜にふと、そう思ったことはありませんか。<br />ひとつでも当てはまるなら、義塾にまとめてご相談ください。"
      />
      <ul class="empathy__list">
        {empathyItems.map((item) => (
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="empathy__solve">
        <strong>義塾なら、すべてまとめて解決できます。</strong>
      </p>
    </div>
  </section>

  {/* CTA ② 共感末尾 */}
  <CtaButton text="塾長に無料相談する" href="#" id="cta-2" />

  {/* ============ §4 義塾が選ばれる3つの理由（NEW） ============ */}
  <section class="section section--bg section--bg-reasons reasons">
    <div class="container">
      <SectionHeader
        title="寝屋川・成田町のご家庭から、<br />義塾が選ばれている理由。"
        lead="塾の数は地域に星の数ほどあります。その中で、なぜ義塾が選ばれ続けてきたのか。塾長の小川と8名の講師陣が、長年大事にしてきた3つの軸でお伝えします。"
      />
      <div class="reasons__grid">
        {reasons.map((r) => <ReasonCard {...r} />)}
      </div>
    </div>
  </section>

  {/* ============ §5 3サービス比較 ============ */}
  <section class="section section--pale-gray services-detail">
    <div class="container">
      <SectionHeader
        title="お子様に合う学び方が、必ずあります。"
        lead="成績が伸びないのは、お子様の能力ではなく、<strong>学び方が合っていないだけ</strong>かもしれません。義塾は、リアル校舎・オンライン・家庭教師の3サービスを併走しています。"
      />

      {/* ① リアル校舎 */}
      <article class="svc-detail section-anchor" id="service-real" style="--accent:#4C1D95;">
        <header class="svc-detail__head">
          <span class="svc-detail__num">01</span>
          <div>
            <h3>義塾（リアル校舎）</h3>
            <p class="svc-detail__lead">指導経験が豊富で安心できる8人の講師陣と、集中できる環境</p>
          </div>
        </header>
        <div class="svc-detail__body">
          <div class="svc-detail__photo">
            <img src={`${base}images/service-real.svg`} alt="リアル校舎の授業風景" loading="lazy" />
          </div>
          <dl class="svc-detail__data">
            <div><dt>対象</dt><dd>小3〜高3</dd></div>
            <div><dt>指導形態</dt><dd>個別指導（月水木金 17:00〜21:40・45分選択制）／クラス授業（中1・中3・高1・高3）</dd></div>
            <div><dt>強み</dt><dd>指導経験が豊富で安心できる講師陣／個別とクラスを必要に応じて使い分けられる選択肢の幅</dd></div>
            <div><dt>おすすめ</dt><dd>新学期はクラス授業の受講が始めやすい時期です</dd></div>
          </dl>
        </div>
      </article>

      {/* ② オンライン */}
      <article class="svc-detail section-anchor" id="service-online" style="--accent:#2E8B57;">
        <header class="svc-detail__head">
          <span class="svc-detail__num">02</span>
          <div>
            <h3>義塾オンライン（オンラインプライベートレッスン）</h3>
            <p class="svc-detail__lead">完全個別指導1対1、選べる4つの専門講座をご自宅から</p>
          </div>
        </header>
        <div class="svc-detail__body">
          <div class="svc-detail__photo">
            <img src={`${base}images/service-online.svg`} alt="オンライン受講イメージ" loading="lazy" />
          </div>
          <dl class="svc-detail__data">
            <div><dt>対象</dt><dd>小4〜社会人（講座により異なる）</dd></div>
            <div><dt>指導形態</dt><dd>完全個別指導 1対1／オンラインプライベートレッスン</dd></div>
            <div>
              <dt>4つの講座</dt>
              <dd>
                <ul class="svc-detail__sublist">
                  <li>探究プレゼン講座（小4〜高3）</li>
                  <li>実践プレゼン講座（大学生・社会人・指導者）</li>
                  <li>AI音楽制作講座（中1〜社会人）</li>
                  <li>英検・TOEIC対策講座（中1〜社会人）</li>
                </ul>
              </dd>
            </div>
            <div><dt>強み</dt><dd>完全マンツーマンで密に伴走／TOEIC990点23回連続満点・英検1級保持のスペシャリスト講師が担当（英検・TOEIC講座）／受験以外の専門領域もカバー</dd></div>
          </dl>
        </div>
      </article>

      {/* ③ 家庭教師 */}
      <article class="svc-detail section-anchor" id="service-tutor" style="--accent:#2563B8;">
        <header class="svc-detail__head">
          <span class="svc-detail__num">03</span>
          <div>
            <h3>義塾の家庭教師</h3>
            <p class="svc-detail__lead">講師がご自宅へ。授業も進路相談も、塾長と直接つながる安心を。</p>
          </div>
        </header>
        <div class="svc-detail__body">
          <div class="svc-detail__photo">
            <img src={`${base}images/service-tutor.svg`} alt="家庭教師訪問イメージ" loading="lazy" />
          </div>
          <dl class="svc-detail__data">
            <div><dt>対象</dt><dd>中1〜高2（中学受験生・高3は個別相談）</dd></div>
            <div><dt>指導形態</dt><dd>完全マンツーマン／週1日2時間（月4回・計8時間）</dd></div>
            <div><dt>強み</dt><dd>第1期生特別価格（2026年入塾生限定）／講師がご自宅まで訪問／公式LINEでいつでも塾長と連絡可能（授業だけでなく進路相談も安心）／兄弟姉妹・お友達とのペア受講でさらにお得</dd></div>
          </dl>
        </div>
      </article>

      {/* §5.6 3サービス比較表（NEW・スキャナブル） */}
      <ServiceCompareTable services={servicesCompare} />
    </div>
  </section>

  {/* CTA ③ 3サービス比較末尾 */}
  <CtaButton text="塾長に無料相談する" href="#" id="cta-3" />

  {/* ============ §6 校舎紹介＋「思い出の場所に」（NEW） ============ */}
  <section class="section section--white campus">
    <div class="container">
      <SectionHeader
        title="義塾を、<br />学生時代の思い出の場所に。"
        lead="勉強の点数を上げるだけが、塾の役割ではないと考えています。<br />お子様が大人になったとき、「あの教室で、先生や仲間と一緒に頑張った」と<strong class='text-orange'>ふと思い出せる場所</strong>であってほしい——塾長の小川と8人の講師陣が、そんな想いで毎日この校舎の灯りをともしています。"
      />

      <div class="campus__gallery">
        <figure class="campus__photo">
