<style>
  /* =========================================
     §1 Hero（上下分割：紫帯／画像／白テキストエリア）
     ========================================= */
  .hero {
    position: relative;
    background: var(--paper);
    overflow: hidden;
  }

  .hero__topband {
    background: var(--purple);
    color: var(--paper);
    padding: 8px 0;
  }

  .hero__topband-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .hero__topband-logo {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0.06em;
    color: var(--paper);
  }

  .hero__topband-logo ruby rt {
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 1px;
    font-family: var(--font-sans);
  }

  .hero__topband-sub {
    font-size: 11px;
    line-height: 1.45;
    text-align: right;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.02em;
  }

  .hero__topband-sub small {
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.04em;
  }

  .hero__photo {
    position: relative;
    aspect-ratio: 16 / 13;
    max-height: 78vh;
    overflow: visible;
    background: var(--purple-deep);
  }

  .hero__photo > img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 60%;
  }

  /* 写真の下端に白フェード（白パネルへの繋ぎを自然に） */
  .hero__photo-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 55%, rgba(255, 255, 255, 0.92) 100%);
    pointer-events: none;
  }

  /* キャッチコピーを写真下端寄りに配置（バッジと高さを揃える） */
  .hero__catch {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0 28px 14px;
    z-index: 3;
  }

  /* §1 円形メダル型ゴールドバッジ（FVだけバッジ・他のキャンペーン訴求はobiで統一） */
  .hero__medal {
    position: absolute;
    bottom: 22px;
    right: 20px;
    width: 130px;
    height: 130px;
    z-index: 4;
    filter: drop-shadow(0 12px 22px rgba(26, 15, 46, 0.4));
    animation: medal-in 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .hero__medal img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }
  @keyframes medal-in {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero__panel {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 32px;
    position: relative;
    z-index: 2;
  }

  .hero__logo {
    display: block;
    width: clamp(180px, 52vw, 360px);
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(255, 255, 255, 0.6));
  }

  /* §1 FV 9人講師シルエット：素材を活かすためリード文の下にフル表示（重ねない） */
  .hero__teachers {
    margin-top: 28px;
  }
  .hero__teachers img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero__sub {
    font-size: 15px;
    line-height: 2;
    color: var(--charcoal-soft);
    letter-spacing: 0.02em;
    margin-bottom: 0;
  }

  /* FV内3サービスナビ：横幅いっぱい・斜め区切り位置をカード①③の内側に寄せる */
  .hero__nav {
    display: flex;
    width: 100%;
    scroll-margin-top: 80px;
    --slant: 28px;
  }

  .hero__nav :global(.svc-card) {
    flex: 1 1 0;
    min-width: 0;
  }

  /* カード①：右端の斜めを内側に slant 丸ごとシフト（カード①の上幅をカード②の上幅と揃える） */
  .hero__nav :global(.svc-card:nth-child(1)) {
    clip-path: polygon(0 0, calc(100% - var(--slant)) 0, calc(100% - 2 * var(--slant)) 100%, 0 100%);
    margin-right: calc(-2 * var(--slant));
  }

  /* カード②：両端を斜めに切る（変更なし） */
  .hero__nav :global(.svc-card:nth-child(2)) {
    clip-path: polygon(var(--slant) 0, 100% 0, calc(100% - var(--slant)) 100%, 0 100%);
    margin-right: calc(-3 * var(--slant) / 2);
  }

  /* カード③：左端の斜めを内側に slant/2 シフト（=可視幅を縮める） */
  .hero__nav :global(.svc-card:nth-child(3)) {
    clip-path: polygon(calc(3 * var(--slant) / 2) 0, 100% 0, 100% 100%, calc(var(--slant) / 2) 100%);
  }

  /* 斜めカット領域にnum/contentが食い込まないようパディング調整 */
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__num),
  .hero__nav :global(.svc-card:nth-child(3) .svc-card__num) {
    left: calc(18px + var(--slant) * 1.2);
  }
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__content),
  .hero__nav :global(.svc-card:nth-child(3) .svc-card__content) {
    padding-left: calc(18px + var(--slant));
  }
  .hero__nav :global(.svc-card:nth-child(2) .svc-card__content) {
    padding-right: calc(18px + var(--slant));
  }
  /* カード①は右斜めを2倍シフトしているので、本文も矢印もその分内側に */
  .hero__nav :global(.svc-card:nth-child(1) .svc-card__content) {
    padding-right: calc(18px + 2 * var(--slant));
  }

  @media (max-width: 768px) {
    .hero__nav { --slant: 18px; }
    .hero__nav :global(.svc-card:nth-child(2) .svc-card__num),
    .hero__nav :global(.svc-card:nth-child(3) .svc-card__num) {
      left: calc(12px + var(--slant) * 1.1);
    }
  }

  @media (max-width: 380px) {
    .hero__topband-inner { padding: 0 18px; }
    .hero__topband-logo { font-size: 20px; }
    .hero__topband-sub { font-size: 10.5px; }
    .hero__panel { padding: 32px 20px 28px; }
    .hero__catch { padding: 0 20px 8px; }
    .hero__medal { width: 100px; height: 100px; bottom: 16px; right: 14px; }
  }

  @media (min-width: 769px) {
    .hero__topband { padding: 10px 0; }
    .hero__topband-logo { font-size: 26px; }
    .hero__topband-sub { font-size: 12px; }
    .hero__topband-sub small { font-size: 10px; }
    .hero__photo { aspect-ratio: 16 / 8; max-height: none; }
    .hero__panel { padding: 48px 32px 40px; }
    .hero__catch { padding: 0 56px 30px; }
    .hero__logo { width: clamp(280px, 38vw, 440px); }
    .hero__sub { font-size: 17px; }
    .hero__medal { width: 180px; height: 180px; bottom: 38px; right: 40px; }
  }

  /* =========================================
     §2 共感末尾の ZERO型 ▼ 視線誘導ブロック＋合格実績（証拠）
     ========================================= */
  .empathy__transition {
    position: relative;
    margin-top: 48px;
    background: var(--purple-deep);
    color: var(--paper);
    padding: 28px 24px 56px;
    /* 下端を ▼ に切り欠く（ZERO型） */
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 32px), 50% 100%, 0 calc(100% - 32px));
  }

  .empathy__transition-text {
    text-align: center;
    margin: 0;
  }

  .empathy__transition-text span {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: clamp(24px, 5.6vw, 34px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.5;
    letter-spacing: 0.08em;
  }

  /* 合格実績カードレール：▼ブロックから少し離して配置 */
  .trust__rail--inempathy {
    margin-top: 40px;
    margin-bottom: -32px;
  }

  @media (max-width: 768px) {
    .empathy__transition {
      margin-top: 32px;
      padding: 20px 20px 42px;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 22px), 50% 100%, 0 calc(100% - 22px));
    }
    .trust__rail--inempathy {
      margin-top: 28px;
      margin-bottom: -20px;
    }
  }

  .trust__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--purple);
    margin-bottom: 12px;
  }

  .trust__title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 4vw, 36px);
    color: var(--purple-deep);
    line-height: 1.5;
    margin-bottom: 32px;
  }

  /* レール：containerを超えて画面幅まで広げる */
  .trust__rail {
    margin: 0 calc(50% - 50vw);
    padding: 0 max(24px, calc((100vw - var(--container)) / 2));
  }

  .trust__cards {
    display: flex;
    flex-wrap: nowrap;
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 0 18px;
    scrollbar-width: thin;
    scrollbar-color: var(--purple-line) transparent;
    -webkit-overflow-scrolling: touch;
  }
  .trust__cards::-webkit-scrollbar { height: 6px; }
  .trust__cards::-webkit-scrollbar-thumb {
    background: var(--purple-line);
    border-radius: 3px;
  }
  .trust__cards::-webkit-scrollbar-track { background: transparent; }

  /* 各カード：背景写真 or プレースホルダ */
  .trust__card {
    flex: 0 0 auto;
    width: 220px;
    aspect-ratio: 4 / 3;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background-color: var(--purple);
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow-sm);
  }

  /* 写真なし：パープル系の塗りつぶしカード */
  .trust__card--placeholder {
    background: linear-gradient(135deg, var(--purple) 0%, var(--purple-deep) 100%);
  }

  /* 写真あり：暗幕オーバーレイ（下半分グラデ） */
  .trust__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.0) 30%, rgba(0, 0, 0, 0.65) 100%);
  }
  .trust__card--placeholder .trust__card-overlay {
    background: none;
  }

  .trust__card-content {
    position: absolute;
    inset: 0;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    z-index: 1;
  }

  .trust__card-group {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.92);
    color: var(--purple-deep);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .trust__card-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--paper);
    line-height: 1.3;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }
  .trust__card--placeholder .trust__card-name {
    text-shadow: none;
  }

  @media (max-width: 768px) {
    .trust { padding: 48px 0 56px; }
    .trust__title { margin-bottom: 20px; }
    .trust__card { width: 170px; }
    .trust__card-name { font-size: 18px; }
    .trust__card-group { font-size: 10px; padding: 3px 8px; }
  }

  /* =========================================
     §3 共感
     ========================================= */
  /* §3 共感セクション（シルエット配置の基準） */
  .empathy {
    position: relative;
    padding: 96px 0;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .empathy { padding: 56px 0; }
  }

  /* SectionHeader下マージンは標準維持 */
  .empathy :global(.sh) { margin-bottom: 36px; }
  @media (max-width: 768px) {
    .empathy :global(.sh) { margin-bottom: 28px; }
  }

  /* pair：リスト＋シルエットをまとめる箱（シルエットがリストに追従） */
  .empathy__pair {
    position: relative;
    margin: 0 auto;
    max-width: 720px;
  }

  /* リスト本体を前面に */
  .empathy__pair > .empathy__list {
    position: relative;
    z-index: 1;
  }

  /* シルエット：pair の縦中央に絶対配置 → リストの真横に並ぶ */
  .empathy__silhouette {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    opacity: 0.18;
    top: 50%;
    transform: translateY(-50%);
    width: 360px;
    height: auto;
  }

  /* PC: リストの左/右側にしっかり大きく見える */
  .empathy__silhouette--problems { left: -120px; }
  .empathy__silhouette--solve { right: -120px; }

  /* スマホ: リスト本体と重なるサイズで配置 */
  @media (max-width: 768px) {
    .empathy__silhouette {
      opacity: 0.14;
      width: 220px;
    }
    .empathy__silhouette--problems { left: -50px; }
    .empathy__silhouette--solve { right: -50px; }
  }

  /* §3 共感リスト：1行1項目・余白最小・密度高 */
  .empathy__list {
    display: flex;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .empathy__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 3px 0;
    font-size: 14.5px;
    line-height: 1.45;
    color: var(--charcoal);
  }

  @media (max-width: 768px) {
    .empathy__list li {
      padding: 2px 0;
      gap: 10px;
      font-size: 13.5px;
      line-height: 1.4;
    }
  }

  /* お悩み：オレンジ円に白の「?」（コンパクト） */
  .empathy__mark--q {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: 13px;
    line-height: 1;
  }

  /* 解決：丸ナシ・太いオレンジ単独チェック */
  .empathy__check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--orange);
  }
  .empathy__check svg { width: 20px; height: 20px; }

  /* Before/After 切り替えの橋渡し・締めコピー（リスト周辺は適度な余白） */
  .empathy__bridge,
  .empathy__close {
    margin: 40px auto 28px;
    text-align: center;
    color: var(--charcoal-soft);
    font-size: 13.5px;
    line-height: 1.7;
  }

  .empathy__bridge span,
  .empathy__close span {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: clamp(20px, 5.5vw, 30px);
    font-weight: 900;
    color: var(--purple-deep);
    letter-spacing: 0.04em;
    padding: 4px 12px;
    background: linear-gradient(transparent 60%, rgba(255, 105, 0, 0.32) 60%);
    line-height: 1.5;
    margin-top: 8px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .empathy__bridge {
      margin: 32px auto 20px;
      font-size: 13px;
    }
  }

  /* =========================================
     §3 3つの学び方（脱カード・レイヤー構成）
     ========================================= */
  .learn .container { position: relative; }

  .learn__service {
    position: relative;
    display: grid;
    align-items: center;
    margin-top: 96px;
    padding-top: 56px;
    border-top: 1px solid var(--line);
  }
  .learn__service:first-of-type {
    border-top: none;
    margin-top: 32px;
    padding-top: 24px;
  }

  /* 巨大番号＝背景レイヤー */
  .learn__num {
    position: absolute;
    font-family: var(--font-serif);
    font-weight: 900;
    color: var(--accent);
    opacity: 0.07;
    line-height: 0.82;
    letter-spacing: -0.02em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    font-size: clamp(180px, 28vw, 360px);
  }
  .learn__service--01 .learn__num { top: 20px; left: -8px; }
  .learn__service--02 .learn__num { top: 20px; right: -8px; }
  .learn__service--03 .learn__num { top: 20px; left: -8px; }

  .learn__photo {
    position: relative;
    z-index: 1;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--pale-gray);
  }
  .learn__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .learn__photo-tag {
    position: absolute;
    bottom: 0;
    left: 0;
    background: var(--accent);
    color: var(--paper);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 8px 16px;
  }

  .learn__text {
    position: relative;
    z-index: 2;
  }
  .learn__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 16px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--accent);
  }
  .learn__text h3 {
    font-family: var(--font-serif);
    font-size: clamp(22px, 3.4vw, 34px);
    color: var(--charcoal);
    line-height: 1.45;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }
  .learn__lead {
    font-size: 16px;
    color: var(--charcoal-soft);
    line-height: 1.95;
    margin-bottom: 28px;
  }
  /* リード文（ナラティブ） */
  .learn__lead {
    font-size: 16px;
    color: var(--charcoal-soft);
    line-height: 2;
    margin-bottom: 28px;
  }

  /* メタ情報1行：対象 / 指導形態 / 月額 */
  .learn__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 32px;
    padding: 18px 0;
    margin-bottom: 24px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .learn__meta li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .learn__meta span {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .learn__meta b {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 900;
    color: var(--charcoal);
    letter-spacing: 0.02em;
  }

  /* 「こんな方におすすめ」コールアウト */
  .learn__forwhom {
    background: rgba(76, 29, 149, 0.04);
    border-left: 3px solid var(--accent);
    padding: 18px 22px;
    margin-bottom: 28px;
  }
  .learn__forwhom-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }
  .learn__forwhom ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .learn__forwhom li {
    font-size: 14px;
    color: var(--charcoal);
    line-height: 1.7;
    padding-left: 22px;
    position: relative;
  }
  .learn__forwhom li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 900;
    font-size: 14px;
  }

  /* 詳細トグル */
  .learn__details {
    margin-top: 20px;
    border-top: 1px solid var(--line);
    padding-top: 4px;
  }
  .learn__details > summary {
    list-style: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.06em;
    padding: 14px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .learn__details > summary::-webkit-details-marker { display: none; }
  .learn__details > summary::before {
    content: "＋";
    font-size: 16px;
    line-height: 1;
    width: 1em;
    text-align: center;
    transition: transform 0.2s;
  }
  .learn__details[open] > summary::before {
    content: "−";
  }
  .learn__details > summary:hover {
    opacity: 0.75;
  }

  /* トグル内データ：基本情報と同じグリッド */
  .learn__details-data {
    display: flex;
    flex-direction: column;
    margin: 8px 0 24px;
  }
  .learn__details-data > div {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--line);
  }
  .learn__details-data > div:last-child { border-bottom: none; }
  .learn__details-data dt {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.06em;
    padding-top: 3px;
  }
  .learn__details-data dd {
    font-size: 13.5px;
    color: var(--charcoal-soft);
    line-height: 1.85;
  }

  /* トグル内のセクションブロック（時間割／講師／校舎 等） */
  .learn__details-section {
    margin: 8px 0 24px;
  }
  .learn__details-section + .learn__details-section {
    margin-top: 28px;
  }
  .learn__details-section h4 {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 900;
    color: var(--charcoal);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
    letter-spacing: 0.04em;
  }
  .learn__details-section ul,
  .learn__details-section ol {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 0;
  }
  .learn__details-section ul li {
    font-size: 13.5px;
    color: var(--charcoal-soft);
    line-height: 1.85;
    padding-left: 16px;
    position: relative;
  }
  .learn__details-section ul li::before {
    content: "・";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .learn__details-note {
    font-size: 11.5px;
    color: var(--muted);
    margin-top: 8px;
  }

  /* 受講までの流れ（番号付きステップ） */
  .learn__steps {
    counter-reset: learn-step;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 0;
  }
  .learn__steps li {
    counter-increment: learn-step;
    list-style: none;
    padding-left: 32px;
    position: relative;
    font-size: 14px;
    color: var(--charcoal);
    line-height: 1.7;
  }
  .learn__steps li::before {
    content: counter(learn-step);
    position: absolute;
    left: 0;
    top: 0;
    width: 22px;
    height: 22px;
    background: var(--accent);
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: 12px;
    font-weight: 900;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 4つの講座カード（オンライン詳細内） */
  .learn__course {
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }
  .learn__course:last-child { border-bottom: none; }
  .learn__course h5 {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 900;
    color: var(--accent);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }
  .learn__course h5 .num {
    color: var(--accent);
    font-size: 1.2em;
    margin: 0 0.05em;
  }
  .learn__course > p {
    font-size: 14px;
    color: var(--charcoal-soft);
    line-height: 1.95;
    margin-bottom: 14px;
  }
  .learn__course dl {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: rgba(76, 29, 149, 0.03);
    border-left: 2px solid var(--accent);
    padding: 14px 16px;
  }
  .learn__course dl > div {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 12px;
  }
  .learn__course dl dt {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .learn__course dl dd {
    font-size: 13px;
    color: var(--charcoal-soft);
    line-height: 1.75;
  }

  @media (max-width: 768px) {
    .learn__details-section h4 { font-size: 14px; }
    .learn__details-section ul li { font-size: 13px; }
    .learn__course h5 { font-size: 15px; }
    .learn__course > p { font-size: 13.5px; }
    .learn__course dl > div { grid-template-columns: 76px 1fr; gap: 10px; }
    .learn__course dl dt { font-size: 11px; }
    .learn__course dl dd { font-size: 12.5px; }
    .learn__steps li { font-size: 13px; }
  }

  /* サービス特化CTA（トグル内末尾） */
  .learn__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: var(--accent);
    color: var(--paper);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 16px 20px;
    border-radius: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .learn__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.18);
  }
  .learn__cta span {
    font-weight: 900;
  }

  /* PC: ジグザグ配置・写真は端まではみ出す */
  @media (min-width: 901px) {
    .learn__service {
      grid-template-columns: 1.05fr 1fr;
      column-gap: 64px;
    }
    .learn__service--02 {
      grid-template-columns: 1fr 1.05fr;
    }
    .learn__service--02 .learn__photo { order: 2; }
    .learn__service--02 .learn__text { order: 1; }
    /* 写真を画面端まで広げる（container を超える） */
    .learn__service--01 .learn__photo,
    .learn__service--03 .learn__photo {
      margin-left: calc((100vw - var(--container)) / -2 - 24px);
    }
    .learn__service--02 .learn__photo {
      margin-right: calc((100vw - var(--container)) / -2 - 24px);
    }
  }

  /* SP: 縦積み・写真→テキスト */
  @media (max-width: 900px) {
    .learn__service {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-top: 64px;
      padding-top: 40px;
    }
    .learn__service:first-of-type {
      margin-top: 24px;
      padding-top: 16px;
    }
    .learn__photo {
      aspect-ratio: 5 / 4;
      margin-left: calc(-1 * 18px);
      margin-right: calc(-1 * 18px);
      width: calc(100% + 36px);
    }
    .learn__num {
      font-size: 220px;
      opacity: 0.06;
      top: 12px;
    }
    .learn__service--01 .learn__num { left: -12px; }
    .learn__service--02 .learn__num { right: -12px; }
    .learn__service--03 .learn__num { left: -12px; }
    .learn__lead { font-size: 14.5px; line-height: 1.95; margin-bottom: 22px; }
    .learn__meta { gap: 16px 24px; padding: 14px 0; margin-bottom: 20px; }
    .learn__meta b { font-size: 15.5px; }
    .learn__forwhom { padding: 16px 18px; margin-bottom: 22px; }
    .learn__forwhom li { font-size: 13.5px; }
    .learn__details-data > div {
      grid-template-columns: 84px 1fr;
      gap: 12px;
    }
    .learn__details-data dt { font-size: 11px; }
    .learn__details-data dd { font-size: 13px; }
    .learn__cta { font-size: 14px; padding: 14px 18px; }
  }

  /* =========================================
     §3 サービス紹介（フルブリード・イメージカラー背景・写真にコピー重ね）
     ========================================= */
  .service {
    background: var(--accent);
    color: var(--paper);
    margin: 0;
  }
  .service:first-of-type { margin-top: 56px; }
  .service + .service { margin-top: 0; }

  /* ヒーロー：写真にコピーを重ねる */
  .service__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
  }
  /* §3 家庭教師 hero 用 NEW バッジ（quicknav svc-card__new と同じプレミアムゴールド世界観） */
  .service__new-badge {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 76px;
    height: 76px;
    padding: 0 8px;
    background:
      radial-gradient(ellipse at 50% 28%, rgba(255, 255, 255, 0.45) 0%, transparent 50%),
      linear-gradient(180deg, var(--gold-light) 0%, var(--gold-classic) 55%, var(--gold-shadow) 100%);
    color: var(--burgundy);
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 900;
    letter-spacing: 0.02em;
    border-radius: 50%;
    border: 2px double var(--gold-dark);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
    box-shadow:
      0 8px 18px rgba(139, 105, 20, 0.5),
      0 0 0 4px rgba(255, 255, 255, 0.85),
      inset 0 1px 2px rgba(255, 255, 255, 0.55);
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .service__new-badge {
      min-width: 56px;
      height: 56px;
      font-size: 18px;
      top: 14px;
      right: 14px;
      box-shadow:
        0 6px 14px rgba(139, 105, 20, 0.5),
        0 0 0 3px rgba(255, 255, 255, 0.85),
        inset 0 1px 2px rgba(255, 255, 255, 0.55);
    }
  }
  .service__hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* hero-real/online/tutor は被写体（机・椅子・生徒）が画像右側に集中しているため、右端を基準にして cover */
    object-position: right center;
  }
  .service__hero-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(95deg,
        color-mix(in srgb, var(--accent) 88%, transparent) 0%,
        color-mix(in srgb, var(--accent) 55%, transparent) 28%,
        transparent 52%),
      linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.18) 100%);
  }
  .service__hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 36px 0;
  }
  .service__hero-content > .container {
    position: relative;
    max-width: var(--container);
    margin: 0 auto;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .service__hero-top {
    position: relative;
  }
  .service__num {
    position: absolute;
    top: -28px;
    right: 0;
    font-family: var(--font-serif);
    font-size: clamp(120px, 16vw, 200px);
    font-weight: 900;
    line-height: 1;
    color: rgba(255, 255, 255, 0.16);
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
  }
  .service__name {
    position: relative;
    font-family: var(--font-serif);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.25;
    letter-spacing: 0.04em;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.45);
    margin: 0;
  }
  .service__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    background: rgba(255, 255, 255, 0.18);
    color: var(--paper);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 14px;
    backdrop-filter: blur(6px);
  }
  .service__catch {
    font-family: var(--font-serif);
    font-size: clamp(32px, 5.6vw, 58px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.45;
    letter-spacing: 0.02em;
    text-shadow: 0 3px 16px rgba(0, 0, 0, 0.5);
    max-width: 760px;
  }
  .service__catch .num {
    color: var(--paper);
    font-size: 1.05em;
    margin: 0 0.05em;
  }

  /* 本文：service color背景にホワイト */
  .service__body {
    padding: 56px 0 72px;
  }
  .service__body > .container {
    max-width: 760px;
    margin: 0 auto;
  }
  .service__story p {
    font-size: 16px;
    line-height: 2.1;
    color: rgba(255, 255, 255, 0.96);
    margin-bottom: 22px;
  }
  .service__story p:last-child { margin-bottom: 0; }
  .service__story .mark {
    background: linear-gradient(transparent 60%, rgba(255, 215, 100, 0.4) 60%);
    color: var(--paper);
    font-weight: 700;
    padding: 0 2px;
  }

  /* メタ情報1行 */
  .service__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 36px;
    padding: 22px 0;
    margin: 32px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }
  .service__meta li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .service__meta span {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .service__meta b {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 900;
    color: var(--paper);
    letter-spacing: 0.02em;
  }
  .service__meta b small {
    display: block;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 2px;
  }

  /* こんな方におすすめ コールアウト */
  .service__forwhom {
    background: rgba(0, 0, 0, 0.18);
    padding: 22px 26px;
    margin: 28px 0;
    border-radius: 8px;
  }
  .service__forwhom-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 14px;
  }
  .service__forwhom ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service__forwhom li {
    position: relative;
    padding-left: 24px;
    font-size: 15px;
    color: var(--paper);
    line-height: 1.7;
  }
  .service__forwhom li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    font-size: 14px;
    font-weight: 900;
    color: var(--paper);
  }

  /* 詳細トグル：シンプルな「続きを読む」テキストのみ（背景色フェードなし） */
  .service__details {
    position: relative;
    margin-top: 32px;
  }
  .service__details > summary {
    position: relative;
    z-index: 2;
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 auto;
    padding: 6px 2px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: opacity 0.2s, border-color 0.2s;
  }
  .service__details > summary::-webkit-details-marker { display: none; }
  .service__details > summary:hover {
    opacity: 0.85;
    border-bottom-color: rgba(255, 255, 255, 0.7);
  }
  .service__details > summary .more-arrow {
    display: inline-block;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.85);
    transition: transform 0.25s ease;
  }
  .service__details[open] > summary .more-arrow {
    transform: rotate(180deg);
  }
  /* summary を中央寄せするためのwrapper代わり（detailsはblock、summaryはinline-flex） */
  .service__details > summary {
    display: flex;
    width: max-content;
    max-width: 100%;
  }
  .service__details {
    text-align: center;
  }
  .service__details > *:not(summary) {
    text-align: left;
  }
  .service__story--continued {
    margin-top: 28px;
  }
  .service__story--continued p {
    margin-bottom: 0;
  }
  /* details 内に持ち上がった meta/forwhom の余白調整 */
  .service__details > .service__meta {
    margin-top: 28px;
  }
  .service__details > .service__forwhom {
    margin-top: 24px;
  }
  /* details 内 CtaButton wrap のmargin・色上書き */
  .service__details :global(.cta-wrap) {
    margin: 36px auto 0;
    max-width: 420px;
    padding: 0;
  }
  /* CTA下のサブテキスト：service color背景上で読めるよう白に */
  .service__details :global(.cta-wrap__sub) {
    color: rgba(255, 255, 255, 0.92);
  }

  .service__details-section { margin: 12px 0 28px; }
  .service__details-section h4 {
    font-family: var(--font-serif);
    font-size: 15.5px;
    font-weight: 900;
    color: var(--paper);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    letter-spacing: 0.04em;
  }
  .service__details-section ul,
  .service__details-section ol {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 0;
  }
  .service__details-section ul li {
    position: relative;
    padding-left: 16px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.85;
  }
  .service__details-section ul li::before {
    content: "・";
    position: absolute;
    left: 0;
    color: var(--paper);
    font-weight: 700;
  }

  /* 受講までの流れ（番号ステップ） */
  .service__steps {
    counter-reset: svc-step;
  }
  .service__steps li {
    counter-increment: svc-step;
    list-style: none;
    padding-left: 36px !important;
    position: relative;
    font-size: 14.5px;
    color: var(--paper) !important;
    line-height: 1.8;
  }
  .service__steps li::before {
    content: counter(svc-step) !important;
    position: absolute;
    left: 0;
    top: 1px;
    width: 24px;
    height: 24px;
    background: var(--paper) !important;
    color: var(--accent) !important;
    font-family: var(--font-serif) !important;
    font-weight: 900;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px !important;
  }

  /* 4つの講座カード（オンライン詳細内） */
  .service__course {
    padding: 22px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }
  .service__course:last-child { border-bottom: none; }
  .service__course h5 {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 900;
    color: var(--paper);
    margin-bottom: 12px;
    letter-spacing: 0.02em;
  }
  .service__course h5 .num {
    color: var(--paper);
    font-size: 1.2em;
    margin: 0 0.06em;
  }
  .service__course > p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.95;
    margin-bottom: 14px;
  }
  .service__course dl {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: rgba(0, 0, 0, 0.22);
    padding: 16px 18px;
    border-radius: 6px;
  }
  .service__course dl > div {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 14px;
  }
  .service__course dl dt {
    font-size: 11.5px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.72);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .service__course dl dd {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.8;
  }


  @media (max-width: 768px) {
    .service { margin: 0; }
    .service:first-of-type { margin-top: 32px; }
    .service + .service { margin-top: 0; }
    .service__hero { aspect-ratio: 4 / 4.4; }
    .service__hero-photo { object-position: right center; }
    .service__hero-tint {
      background: linear-gradient(180deg,
        color-mix(in srgb, var(--accent) 60%, transparent) 0%,
        transparent 28%,
        transparent 50%,
        color-mix(in srgb, var(--accent) 55%, transparent) 80%,
        var(--accent) 100%);
    }
    .service__hero-content { padding: 24px 0 18px; }
    .service__num { top: -16px; right: -8px; font-size: 140px; }
    .service__name { font-size: clamp(24px, 6.4vw, 32px); }
    .service__catch { font-size: clamp(26px, 7.4vw, 36px); line-height: 1.45; }
    .service__eyebrow { font-size: 11px; padding: 5px 12px; margin-bottom: 12px; }
    .service__body { padding: 36px 0 48px; }
    .service__story p { font-size: 14.5px; line-height: 1.95; margin-bottom: 18px; }
    .service__meta { gap: 16px 24px; padding: 16px 0; margin: 22px 0; }
    .service__meta b { font-size: 16px; }
    .service__forwhom { padding: 18px 20px; margin: 22px 0; }
    .service__forwhom li { font-size: 14px; }
    .service__details > summary { font-size: 13px; padding: 14px 0; }
    .service__details-section h4 { font-size: 14.5px; }
    .service__details-section ul li { font-size: 13px; }
    .service__course h5 { font-size: 15.5px; }
    .service__course > p { font-size: 13.5px; }
    .service__course dl > div { grid-template-columns: 76px 1fr; gap: 10px; }
    .service__course dl dt { font-size: 11px; }
    .service__course dl dd { font-size: 12.5px; }
    .service__steps li { font-size: 13.5px; }
    .service__details > summary { font-size: 13.5px; }
  }

  /* =========================================
     §3 リアル校舎 details 内：「思い出の場所に」ブロック
     （旧 §4 を統合・写真は横スクロール snap で縦長を回避）
     ========================================= */
  .service__memories {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
  }
  .service__memories-title {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.6vw, 28px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.5;
    letter-spacing: 0.02em;
    margin-bottom: 18px;
  }
  .service__memories-lead {
    font-size: 14.5px;
    line-height: 1.95;
    color: rgba(255, 255, 255, 0.94);
    margin-bottom: 24px;
  }
  .service__memories-lead strong {
    color: var(--paper);
    font-weight: 700;
    background: linear-gradient(transparent 60%, rgba(255, 215, 100, 0.4) 60%);
    padding: 0 2px;
  }
  /* 横スクロール写真ギャラリー */
  .service__memories-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* containerのpaddingを越えてフルブリード気味に */
    margin: 0 -16px;
    padding: 0 16px 14px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.4) rgba(0, 0, 0, 0.18);
  }
  .service__memories-scroll::-webkit-scrollbar { height: 6px; }
  .service__memories-scroll::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.18); border-radius: 3px; }
  .service__memories-scroll::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.4); border-radius: 3px; }
  .service__memory-photo {
    flex: 0 0 78%;
    max-width: 360px;
    scroll-snap-align: start;
    margin: 0;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.18);
    aspect-ratio: 4 / 3;
  }
  .service__memory-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .service__memory-photo figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 24px 14px 12px;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.65) 100%);
    color: var(--paper);
  }
  .service__memory-photo-no {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: 22px;
    line-height: 1;
    color: rgba(255, 215, 100, 0.95);
  }
  .service__memory-photo-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }
  .service__memories-caption {
    margin-top: 16px;
    font-size: 13.5px;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.86);
  }

  @media (min-width: 769px) {
    .service__memory-photo {
      flex: 0 0 320px;
      max-width: 380px;
    }
  }
  @media (max-width: 540px) {
    .service__memory-photo { flex-basis: 84%; }
  }

  /* =========================================
     §5 保護者・生徒の声
     （合格実績は §2 既出のため §5 では削除、声のみに簡素化）
     ========================================= */
  .voices__subtitle {
    font-family: var(--font-serif);
    font-size: 22px;
    color: var(--purple);
    margin: 56px 0 32px;
    letter-spacing: 0.04em;
  }

  .voices__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .voices__grid--two {
    grid-template-columns: repeat(2, 1fr);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .voices__grid,
    .voices__grid--two { grid-template-columns: 1fr; gap: 8px; }
    .voices__subtitle { font-size: 19px; margin: 40px 0 20px; }
  }

  /* =========================================
     §5 講師紹介 イントロ（2026-05-16 改訂）
     講師2名のアイコン＋「+7名」表記で「9人体制のうち代表2名を紹介」を視覚化
     ========================================= */
  .teachers__intro {
    padding: 20px 0 4px;
  }
  .teachers__intro .section-eyebrow {
    margin-bottom: 10px;
  }
  .teachers__intro-title {
    font-family: var(--font-serif);
    font-size: clamp(24px, 4vw, 38px);
    font-weight: 900;
    line-height: 1.45;
    color: var(--purple);
    margin-bottom: 18px;
    letter-spacing: 0.02em;
  }
  .teachers__intro-lead {
    font-size: 15.5px;
    line-height: 2.05;
    color: var(--charcoal);
    margin-bottom: 28px;
    max-width: 760px;
  }
  /* §5 イントロ 9人シルエット（FVと同じ画像、§5では大きめに見せる） */
  .teachers__intro-silhouette {
    margin: 8px 0 28px;
  }
  .teachers__intro-silhouette img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 760px;
    margin: 0 auto;
  }
  .teachers__intro-note {
    font-size: 14px;
    line-height: 1.9;
    color: var(--charcoal-soft);
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.65);
    border-left: 3px solid var(--orange);
  }
  @media (max-width: 768px) {
    .teachers__intro { padding: 4px 0 4px; }
    .teachers__intro-title { font-size: 22px; }
    .teachers__intro-lead { font-size: 14.5px; line-height: 1.95; margin-bottom: 18px; }
    .teachers__intro-silhouette { margin: 4px 0 22px; }
    .teachers__intro-note { font-size: 13px; padding: 12px 14px; }
  }

  /* =========================================
     §5 講師紹介 本体
     hero overlay（縦長4:5の実写写真 + 紫グラデで上下のみoverlay・中央は写真質感を見せる）
     + body（白背景で詳細情報を読ませる）の2層構造
     カードUI（角丸+影+padding）は不使用
     ========================================= */
  .teacher-feat {
    background: var(--paper);
    color: var(--charcoal);
  }
  .teacher-feat:first-of-type { margin-top: 40px; }
  .teacher-feat + .teacher-feat { margin-top: 0; }

  /* hero：縦長実写写真をフルブリード背景に。画像の上に head/quote/bio までを重ねる
     画像下半分は被写体（プレゼン現場/英語現場のモチーフ）が常に見える背景位置 */
  .teacher-feat__hero {
    position: relative;
    width: 100%;
    background-size: cover;
    background-position: bottom center;
    background-repeat: no-repeat;
    background-color: var(--purple-deep);
    overflow: hidden;
  }
  .teacher-feat__tint {
    position: absolute;
    inset: 0;
    /* 上層：下端を白フェード（body白背景に自然繋ぎ・§3サービスhero同パターン）
       下層：上部のみブランド紫overlay（head/quote読みやすく、bio〜中央は写真そのまま） */
    background:
      linear-gradient(180deg,
        transparent 0%,
        transparent 72%,
        rgba(255, 255, 255, 0.4) 85%,
        rgba(255, 255, 255, 0.85) 95%,
        var(--paper) 100%),
      linear-gradient(180deg,
        color-mix(in srgb, var(--purple) 78%, transparent) 0%,
        color-mix(in srgb, var(--purple) 42%, transparent) 22%,
        color-mix(in srgb, var(--purple) 12%, transparent) 42%,
        transparent 60%);
  }
  .teacher-feat__hero-content {
    position: relative;
    z-index: 1;
    padding: 36px 0 48px;
  }
  .teacher-feat__hero-content > .container {
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .teacher-feat__head {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .teacher-feat__icon {
    flex-shrink: 0;
    width: 112px;
    height: 112px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }
  .teacher-feat__icon {
    background: var(--paper);
    border: 2px solid rgba(255, 255, 255, 0.85);
  }
  .teacher-feat__icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* 國府先生の線画イラストアイコンは余白を作って表示（cover でなく contain で） */
  .teacher-feat__icon--illustration img {
    object-fit: contain;
    padding: 4px;
    background: var(--paper);
  }
  .teacher-feat__title-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .teacher-feat__role {
    display: inline-block;
    width: max-content;
    max-width: 100%;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--paper);
    background: rgba(255, 255, 255, 0.2);
    padding: 5px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }
  .teacher-feat__name {
    font-family: var(--font-serif);
    font-size: clamp(30px, 4.8vw, 44px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.2;
    letter-spacing: 0.04em;
    margin: 4px 0 0;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.4);
  }
  .teacher-feat__name-en {
    display: block;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.22em;
    margin-top: 2px;
  }
  .teacher-feat__quote {
    font-family: var(--font-serif);
    font-size: clamp(19px, 2.6vw, 26px);
    font-weight: 700;
    color: var(--paper);
    line-height: 1.6;
    letter-spacing: 0.02em;
    padding-left: 16px;
    border-left: 3px solid var(--orange);
    /* 写真質感の上で確実に浮かび上がるよう多重 text-shadow */
    text-shadow:
      0 2px 14px rgba(0, 0, 0, 0.75),
      0 1px 4px rgba(0, 0, 0, 0.65),
      0 0 2px rgba(0, 0, 0, 0.45);
    max-width: 720px;
  }
  .teacher-feat__quote .num {
    color: var(--paper);
    font-size: 1.05em;
    margin: 0 0.04em;
  }

  /* hero 内 bio（リード文）：overlay なしの位置に配置されるため、
     強めの text-shadow（多重）で写真の上で確実に読めるようにする */
  .teacher-feat__hero-content .teacher-feat__bio p {
    font-size: 14.5px;
    line-height: 2;
    color: var(--paper);
    margin-bottom: 14px;
    text-shadow:
      0 2px 12px rgba(0, 0, 0, 0.85),
      0 1px 4px rgba(0, 0, 0, 0.75),
      0 0 2px rgba(0, 0, 0, 0.6);
    max-width: 720px;
  }
  .teacher-feat__hero-content .teacher-feat__bio p:last-child { margin-bottom: 0; }
  .teacher-feat__hero-content .teacher-feat__bio .mark {
    background: linear-gradient(transparent 60%, rgba(232, 122, 46, 0.55) 60%);
    color: var(--paper);
    font-weight: 700;
