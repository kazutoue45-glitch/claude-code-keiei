<script>
  /* 画像が存在しない場合に CSS フォールバックを表示するための処理。
     onerror 属性で対応しているが、初期表示時に src が解決できない場合のため
     load イベントでも検査する。 */
  document.querySelectorAll('img[onerror]').forEach((img) => {
    if (img.complete && img.naturalWidth === 0) {
      img.dispatchEvent(new Event('error'));
    }
  });
</script>
