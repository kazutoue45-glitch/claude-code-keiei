    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.82);
    margin-bottom: 1px;
    font-family: var(--font-sans);
  }

  .hero__topband-sub {
    font-size: 11px;
    line-height: 1.45;
    text-align: right;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.02em;
  }

  .hero__topband-sub small {
    font-size: 9.5px;
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.04em;
  }

  .hero__photo {
    position: relative;
    aspect-ratio: 16 / 13;
    max-height: 78vh;
    overflow: visible;
    background: var(--purple-deep);
  }

  .hero__photo > img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 60%;
  }

  /* 写真の下端に白フェード（白パネルへの繋ぎを自然に） */
  .hero__photo-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 55%, rgba(255, 255, 255, 0.92) 100%);
    pointer-events: none;
  }

  /* キャッチコピーを写真下端寄りに配置（バッジと高さを揃える） */
  .hero__catch {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0 28px 14px;
    z-index: 3;
  }

  /* §1 円形メダル型ゴールドバッジ（catch の下端ラインと揃える） */
  .hero__medal {
    position: absolute;
    bottom: 22px;
    right: 20px;
    width: 130px;
    height: 130px;
    z-index: 4;
    filter: drop-shadow(0 12px 22px rgba(26, 15, 46, 0.4));
    animation: medal-in 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero__medal img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  @keyframes medal-in {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero__panel {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 32px;
    position: relative;
    z-index: 2;
  }

  .hero__logo {
    display: block;
    width: clamp(180px, 52vw, 360px);
    height: auto;
