    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .trust__card-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--paper);
    line-height: 1.3;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.02em;
  }
  .trust__card--placeholder .trust__card-name {
    text-shadow: none;
  }

  @media (max-width: 768px) {
    .trust { padding: 48px 0 56px; }
    .trust__title { margin-bottom: 20px; }
    .trust__card { width: 170px; }
    .trust__card-name { font-size: 18px; }
    .trust__card-group { font-size: 10px; padding: 3px 8px; }
  }

  /* =========================================
     §3 共感
     ========================================= */
  /* §3 共感セクション（シルエット配置の基準） */
  .empathy {
    position: relative;
    padding: 96px 0;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .empathy { padding: 56px 0; }
  }

  /* SectionHeader下マージンは標準維持 */
  .empathy :global(.sh) { margin-bottom: 36px; }
  @media (max-width: 768px) {
    .empathy :global(.sh) { margin-bottom: 28px; }
  }

  /* pair：リスト＋シルエットをまとめる箱（シルエットがリストに追従） */
  .empathy__pair {
    position: relative;
    margin: 0 auto;
    max-width: 720px;
  }

  /* リスト本体を前面に */
  .empathy__pair > .empathy__list {
    position: relative;
    z-index: 1;
  }

  /* シルエット：pair の縦中央に絶対配置 → リストの真横に並ぶ */
  .empathy__silhouette {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    opacity: 0.18;
    top: 50%;
    transform: translateY(-50%);
    width: 360px;
    height: auto;
  }

  /* PC: リストの左/右側にしっかり大きく見える */
  .empathy__silhouette--problems { left: -120px; }
  .empathy__silhouette--solve { right: -120px; }

  /* スマホ: リスト本体と重なるサイズで配置 */
  @media (max-width: 768px) {
    .empathy__silhouette {
      opacity: 0.14;
      width: 220px;
    }
    .empathy__silhouette--problems { left: -50px; }
    .empathy__silhouette--solve { right: -50px; }
  }

  /* §3 共感リスト：1行1項目・余白最小・密度高 */
  .empathy__list {
    display: flex;
    flex-direction: column;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .empathy__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 3px 0;
    font-size: 14.5px;
    line-height: 1.45;
    color: var(--charcoal);
  }

  @media (max-width: 768px) {
    .empathy__list li {
      padding: 2px 0;
      gap: 10px;
      font-size: 13.5px;
      line-height: 1.4;
    }
  }

  /* お悩み：オレンジ円に白の「?」（コンパクト） */
  .empathy__mark--q {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: 13px;
    line-height: 1;
  }

  /* 解決：丸ナシ・太いオレンジ単独チェック */
  .empathy__check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--orange);
  }
  .empathy__check svg { width: 20px; height: 20px; }

  /* Before/After 切り替えの橋渡し・締めコピー（リスト周辺は適度な余白） */
  .empathy__bridge,
  .empathy__close {
    margin: 40px auto 28px;
    text-align: center;
    color: var(--charcoal-soft);
    font-size: 13.5px;
    line-height: 1.7;
  }

  .empathy__bridge span,
  .empathy__close span {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: clamp(20px, 5.5vw, 30px);
    font-weight: 900;
    color: var(--purple-deep);
    letter-spacing: 0.04em;
    padding: 4px 12px;
    background: linear-gradient(transparent 60%, rgba(255, 105, 0, 0.32) 60%);
    line-height: 1.5;
    margin-top: 8px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .empathy__bridge {
      margin: 32px auto 20px;
      font-size: 13px;
    }
  }

  /* =========================================
     §3 3つの学び方（脱カード・レイヤー構成）
     ========================================= */
  .learn .container { position: relative; }

  .learn__service {
    position: relative;
    display: grid;
    align-items: center;
    margin-top: 96px;
    padding-top: 56px;
    border-top: 1px solid var(--line);
  }
  .learn__service:first-of-type {
    border-top: none;
    margin-top: 32px;
    padding-top: 24px;
  }

  /* 巨大番号＝背景レイヤー */
  .learn__num {
    position: absolute;
    font-family: var(--font-serif);
    font-weight: 900;
    color: var(--accent);
    opacity: 0.07;
    line-height: 0.82;
    letter-spacing: -0.02em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    font-size: clamp(180px, 28vw, 360px);
  }
  .learn__service--01 .learn__num { top: 20px; left: -8px; }
  .learn__service--02 .learn__num { top: 20px; right: -8px; }
  .learn__service--03 .learn__num { top: 20px; left: -8px; }

  .learn__photo {
    position: relative;
    z-index: 1;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--pale-gray);
  }
  .learn__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .learn__photo-tag {
    position: absolute;
    bottom: 0;
    left: 0;
    background: var(--accent);
    color: var(--paper);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 8px 16px;
  }

  .learn__text {
    position: relative;
    z-index: 2;
  }
  .learn__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 16px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--accent);
  }
  .learn__text h3 {
    font-family: var(--font-serif);
    font-size: clamp(22px, 3.4vw, 34px);
    color: var(--charcoal);
    line-height: 1.45;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }
  .learn__lead {
    font-size: 16px;
    color: var(--charcoal-soft);
    line-height: 1.95;
    margin-bottom: 28px;
  }
  /* リード文（ナラティブ） */
  .learn__lead {
    font-size: 16px;
    color: var(--charcoal-soft);
    line-height: 2;
    margin-bottom: 28px;
  }

  /* メタ情報1行：対象 / 指導形態 / 月額 */
  .learn__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 32px;
    padding: 18px 0;
    margin-bottom: 24px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .learn__meta li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .learn__meta span {
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .learn__meta b {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 900;
    color: var(--charcoal);
    letter-spacing: 0.02em;
  }

  /* 「こんな方におすすめ」コールアウト */
  .learn__forwhom {
    background: rgba(76, 29, 149, 0.04);
    border-left: 3px solid var(--accent);
    padding: 18px 22px;
    margin-bottom: 28px;
  }
  .learn__forwhom-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }
  .learn__forwhom ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .learn__forwhom li {
    font-size: 14px;
    color: var(--charcoal);
    line-height: 1.7;
    padding-left: 22px;
    position: relative;
  }
  .learn__forwhom li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 900;
    font-size: 14px;
  }

  /* 詳細トグル */
  .learn__details {
    margin-top: 20px;
    border-top: 1px solid var(--line);
    padding-top: 4px;
  }
  .learn__details > summary {
    list-style: none;
    cursor: pointer;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.06em;
    padding: 14px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .learn__details > summary::-webkit-details-marker { display: none; }
  .learn__details > summary::before {
    content: "＋";
    font-size: 16px;
    line-height: 1;
    width: 1em;
    text-align: center;
    transition: transform 0.2s;
  }
  .learn__details[open] > summary::before {
    content: "−";
  }
  .learn__details > summary:hover {
    opacity: 0.75;
  }

  /* トグル内データ：基本情報と同じグリッド */
  .learn__details-data {
    display: flex;
    flex-direction: column;
    margin: 8px 0 24px;
  }
  .learn__details-data > div {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--line);
  }
  .learn__details-data > div:last-child { border-bottom: none; }
  .learn__details-data dt {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.06em;
    padding-top: 3px;
  }
  .learn__details-data dd {
    font-size: 13.5px;
    color: var(--charcoal-soft);
    line-height: 1.85;
  }

  /* トグル内のセクションブロック（時間割／講師／校舎 等） */
  .learn__details-section {
    margin: 8px 0 24px;
  }
  .learn__details-section + .learn__details-section {
    margin-top: 28px;
  }
  .learn__details-section h4 {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 900;
    color: var(--charcoal);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--line);
    letter-spacing: 0.04em;
  }
  .learn__details-section ul,
  .learn__details-section ol {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 0;
  }
  .learn__details-section ul li {
    font-size: 13.5px;
    color: var(--charcoal-soft);
    line-height: 1.85;
    padding-left: 16px;
    position: relative;
  }
  .learn__details-section ul li::before {
    content: "・";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .learn__details-note {
    font-size: 11.5px;
    color: var(--muted);
    margin-top: 8px;
  }

  /* 受講までの流れ（番号付きステップ） */
  .learn__steps {
    counter-reset: learn-step;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 0;
  }
  .learn__steps li {
    counter-increment: learn-step;
    list-style: none;
    padding-left: 32px;
    position: relative;
    font-size: 14px;
    color: var(--charcoal);
    line-height: 1.7;
  }
  .learn__steps li::before {
    content: counter(learn-step);
    position: absolute;
    left: 0;
    top: 0;
    width: 22px;
    height: 22px;
    background: var(--accent);
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: 12px;
    font-weight: 900;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 4つの講座カード（オンライン詳細内） */
  .learn__course {
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }
  .learn__course:last-child { border-bottom: none; }
  .learn__course h5 {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 900;
    color: var(--accent);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }
  .learn__course h5 .num {
    color: var(--accent);
    font-size: 1.2em;
    margin: 0 0.05em;
  }
  .learn__course > p {
    font-size: 14px;
    color: var(--charcoal-soft);
    line-height: 1.95;
    margin-bottom: 14px;
  }
  .learn__course dl {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: rgba(76, 29, 149, 0.03);
    border-left: 2px solid var(--accent);
    padding: 14px 16px;
  }
  .learn__course dl > div {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 12px;
  }
  .learn__course dl dt {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .learn__course dl dd {
    font-size: 13px;
    color: var(--charcoal-soft);
    line-height: 1.75;
  }

  @media (max-width: 768px) {
    .learn__details-section h4 { font-size: 14px; }
    .learn__details-section ul li { font-size: 13px; }
    .learn__course h5 { font-size: 15px; }
    .learn__course > p { font-size: 13.5px; }
    .learn__course dl > div { grid-template-columns: 76px 1fr; gap: 10px; }
    .learn__course dl dt { font-size: 11px; }
    .learn__course dl dd { font-size: 12.5px; }
    .learn__steps li { font-size: 13px; }
  }

  /* サービス特化CTA（トグル内末尾） */
  .learn__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    background: var(--accent);
    color: var(--paper);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 16px 20px;
    border-radius: 10px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .learn__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.18);
  }
  .learn__cta span {
    font-weight: 900;
  }

  /* PC: ジグザグ配置・写真は端まではみ出す */
  @media (min-width: 901px) {
    .learn__service {
      grid-template-columns: 1.05fr 1fr;
      column-gap: 64px;
    }
    .learn__service--02 {
      grid-template-columns: 1fr 1.05fr;
    }
    .learn__service--02 .learn__photo { order: 2; }
    .learn__service--02 .learn__text { order: 1; }
    /* 写真を画面端まで広げる（container を超える） */
    .learn__service--01 .learn__photo,
    .learn__service--03 .learn__photo {
      margin-left: calc((100vw - var(--container)) / -2 - 24px);
    }
    .learn__service--02 .learn__photo {
      margin-right: calc((100vw - var(--container)) / -2 - 24px);
    }
  }

  /* SP: 縦積み・写真→テキスト */
  @media (max-width: 900px) {
    .learn__service {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-top: 64px;
      padding-top: 40px;
    }
    .learn__service:first-of-type {
      margin-top: 24px;
      padding-top: 16px;
    }
    .learn__photo {
      aspect-ratio: 5 / 4;
      margin-left: calc(-1 * 18px);
      margin-right: calc(-1 * 18px);
      width: calc(100% + 36px);
    }
    .learn__num {
      font-size: 220px;
      opacity: 0.06;
      top: 12px;
    }
    .learn__service--01 .learn__num { left: -12px; }
    .learn__service--02 .learn__num { right: -12px; }
    .learn__service--03 .learn__num { left: -12px; }
    .learn__lead { font-size: 14.5px; line-height: 1.95; margin-bottom: 22px; }
    .learn__meta { gap: 16px 24px; padding: 14px 0; margin-bottom: 20px; }
    .learn__meta b { font-size: 15.5px; }
    .learn__forwhom { padding: 16px 18px; margin-bottom: 22px; }
    .learn__forwhom li { font-size: 13.5px; }
    .learn__details-data > div {
      grid-template-columns: 84px 1fr;
      gap: 12px;
    }
    .learn__details-data dt { font-size: 11px; }
    .learn__details-data dd { font-size: 13px; }
    .learn__cta { font-size: 14px; padding: 14px 18px; }
  }

  /* =========================================
     §3 サービス紹介（フルブリード・イメージカラー背景・写真にコピー重ね）
     ========================================= */
  .service {
    background: var(--accent);
    color: var(--paper);
    margin: 0;
  }
  .service:first-of-type { margin-top: 56px; }
  .service + .service { margin-top: 0; }

  /* ヒーロー：写真にコピーを重ねる */
  .service__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
  }
  .service__hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
  }
  .service__hero-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(95deg,
        color-mix(in srgb, var(--accent) 88%, transparent) 0%,
        color-mix(in srgb, var(--accent) 55%, transparent) 28%,
        transparent 52%),
      linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.18) 100%);
  }
  .service__hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .service__hero-content > .container {
    position: relative;
    max-width: var(--container);
    margin: 0 auto;
  }
  .service__num {
    position: absolute;
    top: -56px;
    left: -8px;
    font-family: var(--font-serif);
    font-size: clamp(140px, 20vw, 260px);
    font-weight: 900;
    line-height: 1;
    color: rgba(255, 255, 255, 0.14);
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
  }
  .service__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    background: rgba(255, 255, 255, 0.18);
    color: var(--paper);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 18px;
    backdrop-filter: blur(6px);
  }
  .service__name {
    font-family: var(--font-serif);
    font-size: clamp(15px, 2vw, 19px);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.96);
    letter-spacing: 0.16em;
    margin-bottom: 14px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
  .service__catch {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4.6vw, 52px);
    font-weight: 900;
    color: var(--paper);
    line-height: 1.4;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
    max-width: 720px;
  }
  .service__catch .num {
    color: var(--paper);
    font-size: 1.05em;
    margin: 0 0.05em;
  }

  /* 本文：service color背景にホワイト */
  .service__body {
    padding: 56px 0 72px;
  }
  .service__body > .container {
    max-width: 760px;
    margin: 0 auto;
  }
  .service__story p {
    font-size: 16px;
    line-height: 2.1;
    color: rgba(255, 255, 255, 0.96);
    margin-bottom: 22px;
  }
  .service__story p:last-child { margin-bottom: 0; }
  .service__story .mark {
    background: linear-gradient(transparent 60%, rgba(255, 215, 100, 0.4) 60%);
    color: var(--paper);
    font-weight: 700;
    padding: 0 2px;
  }

  /* メタ情報1行 */
  .service__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 36px;
    padding: 22px 0;
    margin: 32px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.25);
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }
  .service__meta li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .service__meta span {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .service__meta b {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 900;
    color: var(--paper);
    letter-spacing: 0.02em;
  }
  .service__meta b small {
    display: block;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 2px;
  }

  /* こんな方におすすめ コールアウト */
  .service__forwhom {
    background: rgba(0, 0, 0, 0.18);
    padding: 22px 26px;
    margin: 28px 0;
    border-radius: 8px;
  }
  .service__forwhom-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 14px;
  }
  .service__forwhom ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .service__forwhom li {
    position: relative;
    padding-left: 24px;
    font-size: 15px;
