---
const { text, href = "#", id, variant = "main" } = Astro.props;
---

<div class="cta-wrap">
  <a href={href} class:list={["cta-btn", variant === "fv" && "cta-btn--fv"]} id={id} aria-label={text}>
    <svg class="cta-btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 22s8-7 8-13a8 8 0 1 0-16 0c0 6 8 13 8 13Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.6"/>
    </svg>
    <span>{text}</span>
    <svg class="cta-btn__chev" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
  <p class="cta-wrap__sub">ご相談・お申込みは公式LINEから。塾長が直接お返事します。</p>
</div>

<style>
  .cta-wrap {
    margin: 80px auto;
    max-width: 480px;
    width: 100%;
    padding: 0 24px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .cta-wrap { margin: 56px auto; }
  }

  .cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    height: 64px;
    padding: 0 28px;
    background: linear-gradient(180deg, #F08C42 0%, var(--orange) 60%, var(--orange-deep) 100%);
    color: var(--paper);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.02em;
    border-radius: 999px;
    box-shadow: 0 10px 26px rgba(232, 122, 46, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.3);
    transition: filter 0.2s, transform 0.2s, box-shadow 0.2s;
    line-height: 1;
  }

  .cta-btn:hover,
  .cta-btn:focus-visible {
    filter: brightness(1.05);
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(232, 122, 46, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.35);
    outline: none;
  }

  .cta-btn:focus-visible {
    outline: 3px solid var(--purple);
    outline-offset: 3px;
  }

  /* FV直下CTA：少し大きめにしてアテンション強化（色は他CTAと統一） */
  .cta-btn--fv {
    height: 68px;
    font-size: 18px;
  }

  .cta-btn__icon {
    flex-shrink: 0;
  }

  .cta-btn__chev {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .cta-wrap__sub {
    margin-top: 14px;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .cta-btn { font-size: 15px; height: 56px; }
  }
</style>
