---
const {
  index,
  title,
  shortLabel,
  bgImage,
  bgPosition = "center center",
  anchorId,
  accentColor,
  isNew = false,
} = Astro.props;
---

<a
  href={`#${anchorId}`}
  class="svc-card"
  style={`--accent:${accentColor};`}
  aria-label={title}
>
  <div class="svc-card__bg">
    {bgImage && <img src={bgImage} alt="" loading="lazy" style={`object-position: ${bgPosition};`} />}
    <span class="svc-card__overlay" aria-hidden="true"></span>
  </div>

  {isNew && <span class="svc-card__new" aria-label="新サービス">New!</span>}

  <div class="svc-card__content">
    <span class="svc-card__num">{index}</span>
    <h3 class="svc-card__title">{title}</h3>
    {shortLabel && <span class="svc-card__sub">{shortLabel}</span>}
    <span class="svc-card__cta" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .svc-card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 5;
    overflow: hidden;
    transition: transform 0.3s;
    color: var(--paper);
    text-decoration: none;
    background: var(--accent);
  }

  .svc-card:focus-visible {
    outline: 3px solid var(--orange);
    outline-offset: -3px;
  }

  .svc-card__bg {
    position: absolute;
    inset: 0;
  }

  .svc-card__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* object-position は services 配列から bgPosition で個別指定（同じ画像でも縦長cover時の被写体が違うため） */
    image-orientation: from-image;
    transition: transform 0.6s;
  }

  .svc-card:hover .svc-card__bg img {
    transform: scale(1.08);
  }

  .svc-card__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 30%, transparent) 0%, color-mix(in srgb, var(--accent) 92%, transparent) 100%);
  }

  .svc-card__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px 18px 18px;
    z-index: 1;
  }

  .svc-card__num {
    position: absolute;
    top: 18px;
    left: 18px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 38px;
    line-height: 1;
    color: var(--paper);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    opacity: 0.9;
  }

  .svc-card__title {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.45;
    color: var(--paper);
    letter-spacing: 0.02em;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    margin-bottom: 8px;
    white-space: nowrap;
  }

  .svc-card__sub {
    display: block;
    font-size: 11.5px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.86);
    letter-spacing: 0.06em;
    line-height: 1.55;
    margin-bottom: 14px;
  }

  .svc-card__cta {
    align-self: flex-end;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s, background 0.25s;
  }

  .svc-card:hover .svc-card__cta {
    transform: translateX(4px);
  }

  /* スマホでも3列横並びを維持（参考画像のように縦長カラム3つ） */
  @media (max-width: 768px) {
    .svc-card { aspect-ratio: 3 / 5.2; }
    .svc-card__content { padding: 16px 8px 14px; }
    .svc-card__num { font-size: 26px; top: 12px; left: 8px; }
    /* 改行廃止：letter-spacing で詰め、palt 効きながら1行で収める */
    .svc-card__title { font-size: 13.5px; line-height: 1.4; margin-bottom: 6px; letter-spacing: -0.04em; }
    .svc-card__sub { font-size: 9.5px; margin-bottom: 10px; line-height: 1.45; letter-spacing: -0.02em; }
    .svc-card__cta { width: 28px; height: 28px; }
    .svc-card__cta svg { width: 14px; height: 14px; }
  }

  @media (max-width: 380px) {
    .svc-card__title { font-size: 12px; letter-spacing: -0.05em; }
    .svc-card__sub { font-size: 9px; }
    .svc-card__num { font-size: 22px; }
  }

  /* NEW バッジ：斜め金色シャインテキスト（円形廃止）
     background-clip: text + linear-gradient のメタリックグラデを
     左→右にアニメーションで反射光を走らせる */
  .svc-card__new {
    position: absolute;
    top: 14px;
    right: 10px;
    z-index: 3;
    font-family: "DM Serif Display", "Noto Serif JP", Georgia, serif;
    font-size: 34px;
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1;
    color: transparent;
    background: linear-gradient(
      100deg,
      #8B6914 0%,
      #B8860B 18%,
      #D4AF37 32%,
      #FFE7A0 46%,
      #FFFFFF 50%,
      #FFE7A0 54%,
      #D4AF37 68%,
      #B8860B 82%,
      #8B6914 100%
    );
    background-size: 250% 100%;
    background-position: 200% center;
    -webkit-background-clip: text;
    background-clip: text;
    transform: rotate(14deg);
    animation: svcNewShine 6s ease-out infinite;
    pointer-events: none;
    filter:
      drop-shadow(0 2px 4px rgba(0, 0, 0, 0.6))
      drop-shadow(0 0 2px rgba(0, 0, 0, 0.5))
      drop-shadow(0 0 1px rgba(139, 105, 20, 0.8));
  }
  /* 反射光：素早く左→右に走り、長めの待機。一定速ではなくメリハリ */
  @keyframes svcNewShine {
    0%   { background-position: 200% center; }
    20%  { background-position: -100% center; }
    100% { background-position: -100% center; }
  }
  @media (max-width: 768px) {
    .svc-card__new {
      font-size: 24px;
      top: 10px;
      right: 8px;
    }
  }
</style>
