---
const {
  index,
  title,
  tagline,
  target,
  priceRange,
  forWhom,
  anchorId,
  accentColor,
  iconName,
} = Astro.props;
---

<a href={`#${anchorId}`} class="svc-card" style={`--accent:${accentColor};`}>
  <div class="svc-card__head">
    <span class="svc-card__num">{index}</span>
    <span class="svc-card__icon">
      {iconName === "building" && (
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 8v2M12 8v2M16 8v2M8 12v2M12 12v2M16 12v2M9 20v-4h6v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "monitor" && (
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="3" y="4" width="18" height="12" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "bag" && (
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="4" y="7" width="16" height="14" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 7V5a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
    </span>
  </div>
  <h3 class="svc-card__title">{title}</h3>
  <p class="svc-card__tagline">{tagline}</p>
  <dl class="svc-card__meta">
    <div>
      <dt>対象学年</dt>
      <dd>{target}</dd>
    </div>
    <div>
      <dt>月額目安</dt>
      <dd>{priceRange}</dd>
    </div>
  </dl>
  <div class="svc-card__forwhom">
    <span class="svc-card__forwhom-label">こんな保護者の方に</span>
    <ul>
      {forWhom.map((line) => <li>{line}</li>)}
    </ul>
  </div>
  <span class="svc-card__more">→ 詳しく見る</span>
</a>

<style>
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-top: 4px solid var(--accent);
    border-radius: var(--radius-md);
    padding: 36px 32px;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    color: var(--charcoal-soft);
    height: 100%;
  }

  .svc-card:hover,
  .svc-card:focus-visible {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
    outline: none;
  }

  .svc-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .svc-card__num {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .svc-card__icon {
    color: var(--accent);
    opacity: 0.7;
  }

  .svc-card__title {
    font-size: 20px;
    margin-bottom: 8px;
    color: var(--purple);
  }

  .svc-card__tagline {
    font-size: 13px;
    color: var(--charcoal-soft);
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .svc-card__meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 16px;
    background: var(--pale-gray);
    border-radius: var(--radius-sm);
    margin-bottom: 16px;
  }

  .svc-card__meta div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 13px;
  }

  .svc-card__meta dt {
    color: var(--muted);
    font-weight: 500;
    flex-shrink: 0;
  }

  .svc-card__meta dd {
    color: var(--charcoal);
    font-weight: 600;
    text-align: right;
  }

  .svc-card__forwhom {
    flex-grow: 1;
    margin-bottom: 16px;
  }

  .svc-card__forwhom-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .svc-card__forwhom ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .svc-card__forwhom li {
    font-size: 13px;
    color: var(--charcoal-soft);
    line-height: 1.7;
    padding-left: 16px;
    position: relative;
  }

  .svc-card__forwhom li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 8px;
    height: 1.5px;
    background: var(--accent);
  }

  .svc-card__more {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    margin-top: auto;
  }
</style>
