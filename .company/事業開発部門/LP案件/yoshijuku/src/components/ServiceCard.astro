---
const {
  index,
  title,
  tagline,
  target,
  priceRange,
  forWhom,
  anchorId,
  accentColor,
  iconName,
  bgImage,
} = Astro.props;
---

<a
  href={`#${anchorId}`}
  class="svc-card"
  style={`--accent:${accentColor};`}
>
  <div class="svc-card__visual">
    {bgImage && <img src={bgImage} alt="" loading="lazy" />}
    <span class="svc-card__visual-tint" aria-hidden="true"></span>
    <span class="svc-card__num">{index}</span>
    <span class="svc-card__icon" aria-hidden="true">
      {iconName === "building" && (
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
          <rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 8v2M12 8v2M16 8v2M8 12v2M12 12v2M16 12v2M9 20v-4h6v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "monitor" && (
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="4" width="18" height="12" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "bag" && (
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
          <rect x="4" y="7" width="16" height="14" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 7V5a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
    </span>
  </div>

  <div class="svc-card__body">
    <h3 class="svc-card__title">{title}</h3>
    <p class="svc-card__tagline">{tagline}</p>
    <dl class="svc-card__meta">
      <div>
        <dt>対象</dt>
        <dd>{target}</dd>
      </div>
      <div>
        <dt>月額目安</dt>
        <dd>{priceRange}</dd>
      </div>
    </dl>
  </div>

  <div class="svc-card__cta">
    <span>詳しく見る</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .svc-card {
    display: grid;
    grid-template-columns: 280px 1fr auto;
    align-items: stretch;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-left: 6px solid var(--accent);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    color: var(--charcoal);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .svc-card:hover,
  .svc-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    outline: none;
  }

  /* === 左：背景画像エリア === */
  .svc-card__visual {
    position: relative;
    min-height: 180px;
    background: var(--accent);
    overflow: hidden;
    color: var(--paper);
  }

  .svc-card__visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    image-orientation: from-image;
  }

  .svc-card__visual-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 88%, transparent) 0%, color-mix(in srgb, var(--accent) 50%, transparent) 100%);
  }

  .svc-card__num {
    position: absolute;
    top: 18px;
    left: 22px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 36px;
    color: var(--paper);
    line-height: 1;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.25);
  }

  .svc-card__icon {
    position: absolute;
    bottom: 22px;
    right: 22px;
    color: var(--paper);
    opacity: 0.92;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.25));
  }

  /* === 中央：テキスト === */
  .svc-card__body {
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
  }

  .svc-card__title {
    font-size: 22px;
    color: var(--purple);
    line-height: 1.4;
  }

  .svc-card__tagline {
    font-size: 14px;
    color: var(--charcoal-soft);
    line-height: 1.85;
  }

  .svc-card__meta {
    display: flex;
    gap: 28px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .svc-card__meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .svc-card__meta dt {
    font-size: 11px;
    color: var(--muted);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .svc-card__meta dd {
    font-size: 14px;
    color: var(--charcoal);
    font-weight: 700;
  }

  /* === 右：CTA矢印 === */
  .svc-card__cta {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 36px;
    background: var(--accent);
    color: var(--paper);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: filter 0.2s, padding 0.2s;
  }

  .svc-card:hover .svc-card__cta {
    filter: brightness(1.08);
    padding: 0 44px 0 36px;
  }

  .svc-card__cta svg {
    transition: transform 0.2s;
  }

  .svc-card:hover .svc-card__cta svg {
    transform: translateX(6px);
  }

  /* === タブレット以下 === */
  @media (max-width: 900px) {
    .svc-card {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .svc-card__visual {
      min-height: 160px;
    }

    .svc-card__num {
      font-size: 32px;
    }

    .svc-card__body {
      padding: 28px 24px;
    }

    .svc-card__title {
      font-size: 19px;
    }

    .svc-card__cta {
      padding: 18px 24px;
      justify-content: space-between;
    }

    .svc-card:hover .svc-card__cta {
      padding: 18px 24px;
    }
  }
</style>
