---
const {
  index,
  title,
  shortLabel,
  bgImage,
  anchorId,
  accentColor,
} = Astro.props;
---

<a
  href={`#${anchorId}`}
  class="svc-card"
  style={`--accent:${accentColor};`}
  aria-label={title}
>
  <div class="svc-card__bg">
    {bgImage && <img src={bgImage} alt="" loading="lazy" />}
    <span class="svc-card__overlay" aria-hidden="true"></span>
  </div>

  <div class="svc-card__content">
    <span class="svc-card__num">{index}</span>
    <h3 class="svc-card__title">{title}</h3>
    {shortLabel && <span class="svc-card__sub">{shortLabel}</span>}
    <span class="svc-card__cta" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .svc-card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 5;
    overflow: hidden;
    transition: transform 0.3s;
    color: var(--paper);
    text-decoration: none;
    background: var(--accent);
  }

  .svc-card:focus-visible {
    outline: 3px solid var(--orange);
    outline-offset: -3px;
  }

  .svc-card__bg {
    position: absolute;
    inset: 0;
  }

  .svc-card__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    image-orientation: from-image;
    transition: transform 0.6s;
  }

  .svc-card:hover .svc-card__bg img {
    transform: scale(1.08);
  }

  .svc-card__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 30%, transparent) 0%, color-mix(in srgb, var(--accent) 92%, transparent) 100%);
  }

  .svc-card__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px 18px 18px;
    z-index: 1;
  }

  .svc-card__num {
    position: absolute;
    top: 18px;
    left: 18px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 38px;
    line-height: 1;
    color: var(--paper);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    opacity: 0.9;
  }

  .svc-card__title {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.45;
    color: var(--paper);
    letter-spacing: 0.02em;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    margin-bottom: 8px;
  }

  .svc-card__sub {
    display: block;
    font-size: 11.5px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.86);
    letter-spacing: 0.06em;
    line-height: 1.55;
    margin-bottom: 14px;
  }

  .svc-card__cta {
    align-self: flex-end;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s, background 0.25s;
  }

  .svc-card:hover .svc-card__cta {
    transform: translateX(4px);
  }

  /* スマホでも3列横並びを維持（参考画像のように縦長カラム3つ） */
  @media (max-width: 768px) {
    .svc-card { aspect-ratio: 3 / 5.2; }
    .svc-card__content { padding: 16px 12px 14px; }
    .svc-card__num { font-size: 26px; top: 12px; left: 12px; }
    .svc-card__title { font-size: 13.5px; line-height: 1.4; margin-bottom: 6px; letter-spacing: 0; }
    .svc-card__sub { font-size: 9.5px; margin-bottom: 10px; line-height: 1.45; }
    .svc-card__cta { width: 28px; height: 28px; }
    .svc-card__cta svg { width: 14px; height: 14px; }
  }

  @media (max-width: 380px) {
    .svc-card__title { font-size: 12px; }
    .svc-card__sub { font-size: 9px; }
    .svc-card__num { font-size: 22px; }
  }
</style>
