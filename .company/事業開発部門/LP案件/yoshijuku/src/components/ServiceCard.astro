---
const {
  index,
  title,
  tagline,
  target,
  priceRange,
  anchorId,
  accentColor,
  iconName,
  bgImage,
} = Astro.props;
---

<a
  href={`#${anchorId}`}
  class="svc-card"
  style={`--accent:${accentColor};`}
>
  <div class="svc-card__visual">
    {bgImage && <img src={bgImage} alt="" loading="lazy" />}
    <span class="svc-card__visual-tint" aria-hidden="true"></span>
    <span class="svc-card__num">{index}</span>
    <span class="svc-card__icon" aria-hidden="true">
      {iconName === "building" && (
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
          <rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 8v2M12 8v2M16 8v2M8 12v2M12 12v2M16 12v2M9 20v-4h6v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "monitor" && (
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="4" width="18" height="12" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
      {iconName === "bag" && (
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
          <rect x="4" y="7" width="16" height="14" stroke="currentColor" stroke-width="1.6" rx="1"/>
          <path d="M8 7V5a4 4 0 0 1 8 0v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      )}
    </span>
  </div>

  <div class="svc-card__body">
    <h3 class="svc-card__title">{title}</h3>
    <p class="svc-card__tagline">{tagline}</p>
    <dl class="svc-card__meta">
      <div>
        <dt>対象</dt>
        <dd>{target}</dd>
      </div>
      <div>
        <dt>月額目安</dt>
        <dd>{priceRange}</dd>
      </div>
    </dl>
  </div>

  <div class="svc-card__cta">
    <span>詳しく見る</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.25s, box-shadow 0.25s;
    color: var(--charcoal);
    text-decoration: none;
    height: 100%;
  }

  .svc-card:hover,
  .svc-card:focus-visible {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    outline: none;
  }

  /* === 上：ビジュアルエリア === */
  .svc-card__visual {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--accent);
    overflow: hidden;
    color: var(--paper);
  }

  .svc-card__visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-orientation: from-image;
  }

  .svc-card__visual-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 86%, transparent) 0%, color-mix(in srgb, var(--accent) 55%, transparent) 100%);
  }

  .svc-card__num {
    position: absolute;
    top: 22px;
    left: 24px;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 44px;
    color: var(--paper);
    line-height: 1;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
  }

  .svc-card__icon {
    position: absolute;
    bottom: 22px;
    right: 24px;
    color: var(--paper);
    opacity: 0.92;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.3));
  }

  /* === 中：情報エリア === */
  .svc-card__body {
    flex: 1;
    padding: 32px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .svc-card__title {
    font-size: 20px;
    color: var(--purple);
    line-height: 1.45;
  }

  .svc-card__tagline {
    font-size: 13.5px;
    color: var(--charcoal-soft);
    line-height: 1.85;
    flex: 1;
  }

  .svc-card__meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 16px;
    margin-top: 4px;
  }

  .svc-card__meta div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .svc-card__meta dt {
    font-size: 12px;
    color: var(--muted);
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .svc-card__meta dd {
    font-size: 14px;
    color: var(--charcoal);
    font-weight: 700;
    text-align: right;
  }

  /* === 下：CTAバー === */
  .svc-card__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 18px 28px;
    background: var(--accent);
    color: var(--paper);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: filter 0.2s;
  }

  .svc-card:hover .svc-card__cta {
    filter: brightness(1.08);
  }

  .svc-card__cta svg {
    transition: transform 0.2s;
  }

  .svc-card:hover .svc-card__cta svg {
    transform: translateX(6px);
  }

  @media (max-width: 540px) {
    .svc-card__num { font-size: 36px; top: 18px; left: 20px; }
    .svc-card__body { padding: 28px 22px 22px; }
    .svc-card__title { font-size: 18px; }
    .svc-card__cta { padding: 16px 22px; font-size: 13px; }
  }
</style>
