---
const {
  name,
  nameEn,
  title,
  quote,
  bioParagraphs = [],
  achievements = [],
  message,
  photoSrc,
} = Astro.props;
---

<article class="teacher">
  <div class="teacher__head">
    <div class="teacher__photo">
      <img src={photoSrc} alt={`${name}先生`} loading="lazy" />
    </div>
    <div class="teacher__name">
      <h3>{name}</h3>
      {nameEn && <span class="teacher__name-en">{nameEn}</span>}
      <p class="teacher__title">{title}</p>
    </div>
  </div>

  <blockquote class="teacher__quote">{quote}</blockquote>

  {bioParagraphs.length > 0 && (
    <div class="teacher__bio">
      {bioParagraphs.map((p) => <p>{p}</p>)}
    </div>
  )}

  {achievements.length > 0 && (
    <ul class="teacher__achievements">
      {achievements.map((a) => (
        <li>
          <span class="teacher__ach-label">{a.label}</span>
          <span class="teacher__ach-desc">{a.desc}</span>
        </li>
      ))}
    </ul>
  )}

  {message && <p class="teacher__message">{message}</p>}
</article>

<style>
  .teacher {
    display: flex;
    flex-direction: column;
    gap: 24px;
    background: var(--paper);
    border-radius: var(--radius-md);
    padding: 44px 40px;
    box-shadow: var(--shadow-md);
  }

  .teacher__head {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .teacher__photo {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--pale-gray);
    border: 3px solid var(--pale-gray);
  }

  .teacher__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .teacher__name h3 {
    font-size: 22px;
    margin-bottom: 2px;
    color: var(--purple);
  }

  .teacher__name-en {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.16em;
    margin-bottom: 4px;
  }

  .teacher__title {
    font-size: 12px;
    color: var(--orange);
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.04em;
  }

  .teacher__quote {
    font-size: 17px;
    font-weight: 700;
    color: var(--purple);
    line-height: 1.75;
    padding: 20px 24px;
    background: var(--pale-gray);
    border-radius: var(--radius-sm);
  }

  .teacher__bio p {
    font-size: 14px;
    line-height: 1.95;
    color: var(--charcoal-soft);
    margin-bottom: 10px;
  }

  .teacher__bio p:last-child { margin-bottom: 0; }

  .teacher__achievements {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 20px;
    background: var(--pale-gray);
    border-radius: var(--radius-sm);
  }

  .teacher__achievements li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .teacher__ach-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--purple);
  }

  .teacher__ach-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .teacher__message {
    font-size: 14px;
    line-height: 1.95;
    color: var(--charcoal-soft);
    padding-top: 14px;
    border-top: 1px dashed var(--line);
  }

  @media (max-width: 768px) {
    .teacher { padding: 24px 20px; }
    .teacher__photo { width: 80px; height: 80px; }
    .teacher__name h3 { font-size: 19px; }
    .teacher__quote { font-size: 15px; padding: 14px 16px; }
  }
</style>
