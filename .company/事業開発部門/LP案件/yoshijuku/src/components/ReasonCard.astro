---
const {
  number,
  title,
  bullets = [],
  iconSrc,
  iconAlt,
} = Astro.props;
---

<article class="reason">
  <div class="reason__head">
    <span class="reason__num">{number}</span>
    <div class="reason__icon">
      {iconSrc ? (
        <img src={iconSrc} alt={iconAlt ?? ""} loading="lazy" />
      ) : (
        <span class="img-placeholder img-placeholder--circle">画像準備中<br />（Codex生成）</span>
      )}
    </div>
  </div>
  <h3 class="reason__title" set:html={title}></h3>
  <ul class="reason__bullets">
    {bullets.map((line) => <li>{line}</li>)}
  </ul>
</article>

<style>
  .reason {
    display: flex;
    flex-direction: column;
    gap: 20px;
    background: var(--paper);
    border-radius: var(--radius-md);
    padding: 44px 36px 36px;
    box-shadow: var(--shadow-md);
    transition: box-shadow 0.25s, transform 0.25s;
    height: 100%;
  }

  .reason:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .reason__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .reason__num {
    font-family: var(--font-serif);
    font-size: 44px;
    font-weight: 700;
    color: var(--purple);
    line-height: 1;
    letter-spacing: 0.04em;
  }

  .reason__icon {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .reason__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .reason__title {
    font-size: 18px;
    color: var(--purple);
    line-height: 1.7;
  }

  .reason__bullets {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .reason__bullets li {
    font-size: 14px;
    color: var(--charcoal-soft);
    line-height: 1.95;
  }

  @media (max-width: 768px) {
    .reason { padding: 28px 22px; }
    .reason__num { font-size: 36px; }
    .reason__icon { width: 80px; height: 80px; }
    .reason__title { font-size: 16px; }
  }
</style>
