---
const { current = "home", base } = Astro.props;
const nav = [
  { id: "home", label: "ホーム", href: base },
  { id: "strengths", label: "フォレストの強み", href: `${base}strengths/` },
  { id: "price", label: "お月謝", href: `${base}price/` },
  { id: "schools", label: "教室案内", href: `${base}schools/` },
  { id: "contact", label: "お問い合わせ", href: `${base}contact/` },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={base} class="site-logo" aria-label="個別指導塾フォレスト">
      <span class="site-logo__mark" aria-hidden="true">
        <svg viewBox="0 0 44 44" width="40" height="40">
          <circle cx="22" cy="22" r="21" fill="#B8232A" />
          <path d="M22 10 C 19 14, 16 16, 16 22 C 16 26, 19 29, 22 29 C 25 29, 28 26, 28 22 C 28 18, 25 15, 22 12 C 22 16, 20 18, 20 21 C 20 23, 21 24, 22 24 C 23 24, 24 23, 24 22"
            fill="#F4B872"
            stroke="#FFFCF6"
            stroke-width="0.5"
          />
        </svg>
      </span>
      <span class="site-logo__text">
        <span class="site-logo__lead">個別指導塾</span>
        <span class="site-logo__name">フォレスト</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={item.id === current ? "is-active" : ""}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={`${base}contact/`} class="site-header__cta">
      <span>無料資料請求</span>
    </a>

    <button class="site-burger" aria-label="メニューを開く" data-burger>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu>
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
      <li class="mobile-menu__cta">
        <a href={`${base}contact/`} class="btn btn--flame">無料資料請求・個別相談</a>
      </li>
    </ul>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .site-logo__mark {
    display: inline-flex;
    align-items: center;
  }

  .site-logo__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-logo__lead {
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.2em;
    font-weight: 500;
  }

  .site-logo__name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.04em;
  }

  .site-nav {
    margin-left: auto;
  }

  .site-nav ul {
    display: flex;
    gap: 28px;
  }

  .site-nav a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    transition: color 0.2s;
    position: relative;
    padding: 6px 0;
  }

  .site-nav a:hover { color: var(--flame); }

  .site-nav a.is-active {
    color: var(--flame);
    font-weight: 700;
  }

  .site-nav a.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--flame);
    border-radius: 2px;
  }

  .site-header__cta {
    background: var(--flame);
    color: var(--paper);
    font-size: 14px;
    font-weight: 700;
    padding: 12px 22px;
    border-radius: 999px;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 14px rgba(184, 35, 42, 0.32);
  }

  .site-header__cta:hover {
    background: var(--flame-deep);
    transform: translateY(-1px);
  }

  .site-burger {
    display: none;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    margin-left: auto;
  }

  .site-burger span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.25s, opacity 0.25s;
  }

  .site-burger.is-open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-burger.is-open span:nth-child(2) { opacity: 0; }
  .site-burger.is-open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    background: var(--paper);
    border-top: 1px solid var(--line);
    padding: 16px 20px 24px;
  }

  .mobile-menu.is-open { display: block; }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-menu a {
    display: block;
    padding: 14px 4px;
    font-weight: 500;
    border-bottom: 1px solid var(--line);
  }

  .mobile-menu__cta { padding-top: 16px; }

  .mobile-menu__cta .btn {
    display: block;
    text-align: center;
    width: 100%;
  }

  @media (max-width: 900px) {
    .site-nav,
    .site-header__cta { display: none; }
    .site-burger { display: flex; }
  }
</style>

<script>
  const burger = document.querySelector("[data-burger]");
  const menu = document.querySelector("[data-mobile-menu]");
  burger?.addEventListener("click", () => {
    burger.classList.toggle("is-open");
    menu?.classList.toggle("is-open");
  });
</script>
