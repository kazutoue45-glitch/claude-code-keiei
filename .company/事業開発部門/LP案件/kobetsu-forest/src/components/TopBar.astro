---
const { base } = Astro.props;
---

<div class="topstrip">
  <div class="topstrip__inner">
    <span>個別指導塾フォレスト　城東区・生野区・東成区の学習塾</span>
    <span class="topstrip__areas">蒲生四丁目・関目・鴫野・放出・野江・今福鶴見・京橋・関目成育・今里・北巽・桃谷・鶴橋・小路・緑橋など</span>
  </div>
</div>

<div class="contactbar">
  <div class="contactbar__inner">
    <a href={`${base}contact/`} class="contactbar__sat">
      <span class="contactbar__sat-tag">毎週土曜・5教科対応</span>
      <span class="contactbar__sat-text">
        <strong>無料</strong>の質問クラス開講中
      </span>
      <span class="contactbar__sat-arrow" aria-hidden="true">→</span>
    </a>
    <div class="contactbar__phones">
      <a href="tel:0669391001" class="contactbar__phone">
        <span class="contactbar__phone-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M19.23 15.26l-2.54-.29c-.61-.07-1.21.14-1.64.57l-1.84 1.84a15.045 15.045 0 0 1-6.59-6.59l1.85-1.85c.43-.43.64-1.03.57-1.64l-.29-2.52a2.001 2.001 0 0 0-1.99-1.77H5.03c-1.13 0-2.07.94-2 2.07.53 8.54 7.36 15.36 15.89 15.89 1.13.07 2.07-.87 2.07-2v-1.73c.01-1.01-.75-1.86-1.76-1.98z"/></svg>
        </span>
        <span class="contactbar__phone-text">
          <span class="contactbar__phone-label">蒲生四丁目駅前校</span>
          <span class="contactbar__phone-num">06-6939-1001</span>
        </span>
      </a>
      <a href="tel:0643066300" class="contactbar__phone">
        <span class="contactbar__phone-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M19.23 15.26l-2.54-.29c-.61-.07-1.21.14-1.64.57l-1.84 1.84a15.045 15.045 0 0 1-6.59-6.59l1.85-1.85c.43-.43.64-1.03.57-1.64l-.29-2.52a2.001 2.001 0 0 0-1.99-1.77H5.03c-1.13 0-2.07.94-2 2.07.53 8.54 7.36 15.36 15.89 15.89 1.13.07 2.07-.87 2.07-2v-1.73c.01-1.01-.75-1.86-1.76-1.98z"/></svg>
        </span>
        <span class="contactbar__phone-text">
          <span class="contactbar__phone-label">今里校</span>
          <span class="contactbar__phone-num">06-4306-6300</span>
        </span>
      </a>
    </div>
  </div>
</div>

<style>
  .topstrip {
    background: var(--flame-deep);
    color: var(--paper);
    font-size: 12px;
    padding: 6px 0;
  }

  .topstrip__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .topstrip__inner > span:first-child {
    font-weight: 700;
  }

  .topstrip__areas {
    color: rgba(255, 252, 246, 0.78);
    font-size: 11px;
  }

  .contactbar {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 12px 0;
  }

  .contactbar__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: space-between;
  }

  /* 土曜CTA */
  .contactbar__sat {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #FFE94D;
    color: var(--ink);
    padding: 10px 18px 10px 14px;
    border: 2px solid var(--ink);
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s;
  }

  .contactbar__sat:hover {
    background: #FFD700;
  }

  .contactbar__sat-tag {
    font-size: 10px;
    font-weight: 700;
    background: var(--ink);
    color: #FFE94D;
    padding: 3px 8px;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .contactbar__sat-text {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .contactbar__sat-text strong {
    color: var(--flame-deep);
    font-size: 17px;
    margin-right: 2px;
  }

  .contactbar__sat-arrow {
    font-weight: 900;
    font-size: 16px;
    color: var(--flame-deep);
  }

  /* 電話番号 */
  .contactbar__phones {
    display: flex;
    gap: 16px;
  }

  .contactbar__phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
  }

  .contactbar__phone-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--flame);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contactbar__phone-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .contactbar__phone-label {
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.02em;
  }

  .contactbar__phone-num {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  @media (max-width: 980px) {
    .contactbar__inner {
      flex-wrap: wrap;
      gap: 12px;
    }
    .contactbar__sat {
      width: 100%;
      justify-content: center;
    }
    .contactbar__phones {
      width: 100%;
      justify-content: center;
      gap: 16px;
    }
  }

  @media (max-width: 600px) {
    .topstrip {
      font-size: 11px;
      padding: 5px 0;
    }
    .topstrip__inner {
      padding: 0 12px;
      gap: 4px;
    }
    .topstrip__areas {
      display: none;
    }
    .contactbar {
      padding: 8px 0;
    }
    .contactbar__inner {
      padding: 0 12px;
    }
    .contactbar__sat {
      padding: 8px 12px;
      gap: 8px;
    }
    .contactbar__sat-text { font-size: 12px; }
    .contactbar__sat-text strong { font-size: 14px; }
    .contactbar__sat-arrow { display: none; }
    .contactbar__phones {
      gap: 8px;
    }
    .contactbar__phone-num { font-size: 16px; }
  }
</style>
