---
const { base } = Astro.props;
---

<div class="sticky-cta">
  <a href="tel:0669391001" class="sticky-cta__btn sticky-cta__btn--tel">
    <span class="sticky-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
    </span>
    <span class="sticky-cta__text">
      <span class="sticky-cta__sub">蒲生四丁目駅前校</span>
      <span class="sticky-cta__num">06-6939-1001</span>
    </span>
  </a>
  <a href={`${base}contact/`} class="sticky-cta__btn sticky-cta__btn--form">
    <span class="sticky-cta__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
        <polyline points="22,6 12,13 2,6" />
      </svg>
    </span>
    <span class="sticky-cta__text">
      <span class="sticky-cta__sub">かんたん1分</span>
      <span class="sticky-cta__num">無料資料請求</span>
    </span>
  </a>
</div>

<style>
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--paper);
    box-shadow: 0 -4px 16px rgba(20, 56, 32, 0.12);
    padding: 8px;
    gap: 8px;
    border-top: 1px solid var(--line);
  }

  .sticky-cta__btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 8px;
    border-radius: var(--radius-md);
    font-weight: 700;
  }

  .sticky-cta__btn--tel {
    background: var(--forest);
    color: var(--paper);
  }

  .sticky-cta__btn--form {
    background: var(--flame);
    color: var(--paper);
  }

  .sticky-cta__icon {
    display: inline-flex;
    flex-shrink: 0;
  }

  .sticky-cta__text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    text-align: left;
  }

  .sticky-cta__sub {
    font-size: 10px;
    opacity: 0.85;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .sticky-cta__num {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .sticky-cta {
      display: flex;
    }
  }
</style>
