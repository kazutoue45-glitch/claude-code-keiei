---
const { number, title, body, icon = "leaf" } = Astro.props;

const icons = {
  leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
  fire: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  book: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>',
  calendar: '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
};
---

<article class="strength-card">
  <div class="strength-card__head">
    <span class="strength-card__num">{number}</span>
    <span class="strength-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[icon] ?? icons.leaf} />
    </span>
  </div>
  <h3>{title}</h3>
  <p>{body}</p>
</article>

<style>
  .strength-card {
    background: var(--paper);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    border: 1px solid var(--line);
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    position: relative;
    overflow: hidden;
  }

  .strength-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--forest), var(--ember));
    opacity: 0;
    transition: opacity 0.25s;
  }

  .strength-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--forest);
  }

  .strength-card:hover::before {
    opacity: 1;
  }

  .strength-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .strength-card__num {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 900;
    color: var(--ember);
    line-height: 1;
    letter-spacing: 0;
  }

  .strength-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--forest-soft);
    color: var(--forest);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .strength-card h3 {
    font-size: 19px;
    color: var(--forest-deep);
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .strength-card p {
    font-size: 14.5px;
    color: var(--ink-soft);
    line-height: 1.85;
  }
</style>
