---
import Base from "../layouts/Base.astro";
import StatBlock from "../components/StatBlock.astro";
import StrengthCard from "../components/StrengthCard.astro";
import SchoolCard from "../components/SchoolCard.astro";

const base = import.meta.env.BASE_URL;

const strengths = [
  { number: "01", title: "つきっきりの個別指導", body: "1対2・1対3でも、わからないを見逃さない。問題を解くスピード・理解度・やる気の3つを毎回見ています。", icon: "users" },
  { number: "02", title: "成績で生徒を選ばない", body: "「できる子」だけ集めても本当の指導力は身につきません。一人ひとりの今からの伸びに本気で向き合います。", icon: "leaf" },
  { number: "03", title: "毎週土曜・無料質問クラス", body: "19:00〜22:00、5教科対応の自由質問クラス。塾生は何度来ても無料。「わからない」を翌週に持ち越しません。", icon: "calendar" },
  { number: "04", title: "中学受験 合格率100%", body: "2001年の開校以来、中学受験は合格率100%の実績。常翔学園・信愛女学院など地元中堅私学に対応。", icon: "star" },
  { number: "05", title: "平日17時から自習室開放", body: "「集中して勉強できる場所がある」だけで、家では出せない力が出ます。塾生は自由に使えます。", icon: "book" },
  { number: "06", title: "クラブ活動と両立できる時間割", body: "20:00〜21:50の遅い時間帯にも対応。部活で疲れた日も、無理なく通い続けられる仕組みです。", icon: "sun" },
];
---

<Base current="home">
  <!-- HERO: 元サイトのブランド資産（赤＋緑バッジ＋大きな漢字＋生徒写真）を踏襲しつつモダン化 -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>

    <div class="hero__inner">
      <div class="hero__card">
        <div class="hero__head">
          <span class="hero__badge">他塾で伸びなかった生徒の、成績アップを目指します</span>
          <span class="hero__age">2001年開校・地域密着25年</span>
        </div>

        <p class="hero__eyebrow">個別指導塾フォレスト　大阪市城東区／生野区／東成区</p>

        <h1 class="hero__title">
          <span class="hero__title-pre">講師がずっと横にいる</span>
          <span class="hero__title-main">つきっきり個別指導。</span>
        </h1>

        <p class="hero__lead">
          内容のぎっしり詰まった質の高い個別授業を、安心の料金設定で。<br />
          成績で生徒を選ばない。一人ひとりの「これから」に本気で向き合います。
        </p>

        <div class="hero__photo">
          <img src={`${base}images/lesson.jpg`} alt="個別指導塾フォレストの個別指導の様子" />
          <div class="hero__photo-tag">1対1〜1対3の個別指導</div>
        </div>

        <div class="hero__targets" aria-label="対象学年">
          <div class="hero__target">
            <span class="hero__target-label">対応</span>
            <span class="hero__target-name">小学生</span>
          </div>
          <div class="hero__target">
            <span class="hero__target-label">対応</span>
            <span class="hero__target-name">中学生</span>
          </div>
          <div class="hero__target hero__target--accent">
            <span class="hero__target-label">合格率100%</span>
            <span class="hero__target-name">中学受験</span>
          </div>
        </div>

        <div class="hero__actions">
          <a href={`${base}contact/`} class="btn btn--flame btn--big">
            かんたん1分・無料資料請求
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="tel:0669391001" class="hero__tel">
            <span class="hero__tel-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span class="hero__tel-text">
              <span class="hero__tel-label">蒲生四丁目駅前校</span>
              <span class="hero__tel-num">06-6939-1001</span>
            </span>
          </a>
        </div>

        <div class="hero__campaign">
          <span class="hero__campaign-tag">新年度キャンペーン</span>
          <span class="hero__campaign-text">スタート月謝<strong>2ヶ月半額</strong>／入塾金<strong>無料</strong></span>
        </div>
      </div>
    </div>
  </section>

  <!-- 塾長メッセージ（横長フルブリード） -->
  <section class="principal">
    <div class="principal__photo">
      <img src={`${base}images/jukucho.jpg`} alt="個別指導塾フォレスト 塾長 黒田清登" />
    </div>
    <div class="principal__content">
      <div class="principal__inner">
        <span class="section-label">塾長メッセージ</span>
        <h2>
          成績で、<br />
          生徒を選ばない。
        </h2>
        <p>
          たとえ時代がどのようにぶれようが、子供中心の視点から子供達が本当に望んでいることに応え、そして親の子供に対する熱い思いに共感することが、塾本来の役割だと、私は思っています。
        </p>
        <p>
          学校の先生より、塾の私たちは「本音で接する立場」にいます。教育現場の最前線で、子供達の小さな変化に気づき、保護者の皆様と並走する。それがフォレストの仕事です。
        </p>
        <div class="principal__sign">
          <span class="principal__sign-role">個別指導塾フォレスト 塾長</span>
          <span class="principal__sign-name">黒田 清登</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST IN NUMBERS</span>
        <h2 class="section-title">数字で見るフォレスト</h2>
      </div>
      <div class="stats-grid">
        <StatBlock value="25" unit="年" label="2001年開校・地域に根差した実績" accent="flame" />
        <StatBlock value="100" unit="%" label="中学受験 合格率（開校以来）" accent="flame" />
        <StatBlock value="2" unit="校" label="蒲生四丁目駅前校・今里校" accent="forest" />
        <StatBlock value="土" unit="" label="毎週土曜・無料質問クラス" accent="ember" />
      </div>
    </div>
  </section>

  <!-- Strengths -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST STRENGTHS</span>
        <h2 class="section-title">
          ホンモノの個別指導は<br class="sp-only" />
          「つきっきり」でなければならない。
        </h2>
        <p class="section-lead">
          フォレストの個別指導は、ただ机を並べるだけの時間ではありません。一問ごとに、生徒の理解度・スピード・表情まで見つめながら進める。それが、私たちが25年続けてきた指導の形です。
        </p>
      </div>

      <div class="strengths-grid">
        {strengths.map((s) => (
          <StrengthCard {...s} />
        ))}
      </div>

      <div class="strengths-more">
        <a href={`${base}strengths/`} class="btn btn--outline">
          強みの詳細を見る
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">SCHOOLS</span>
        <h2 class="section-title">通いやすい、地元の2校舎。</h2>
        <p class="section-lead">
          地元の小中学校に密着し、クラブ活動を終えた後でも通える時間割でお待ちしています。
        </p>
      </div>
      <div class="schools-grid">
        <SchoolCard
          name="蒲生四丁目駅前校"
          station="地下鉄今里筋線・長堀鶴見緑地線「蒲生四丁目駅」徒歩1分"
          address="大阪市城東区中央1丁目12-17 モーガ第１ビル2F"
          tel="06-6939-1001"
          image={`${base}images/gamou.png`}
          mapUrl="https://maps.google.com/?q=大阪市城東区中央1丁目12-17"
          accent="蒲生四丁目駅前校"
        />
        <SchoolCard
          name="今里校"
          station="地下鉄千日前線・今里筋線「今里駅」徒歩圏"
          address="大阪市生野区新今里3-1-2"
          tel="06-4306-6300"
          image={`${base}images/imazato.jpg`}
          mapUrl="https://maps.google.com/?q=大阪市生野区新今里3-1-2"
          accent="今里校"
        />
      </div>
    </div>
  </section>

  <!-- Voices -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">VOICES</span>
        <h2 class="section-title">大逆転の合格を、何度も見てきました。</h2>
        <p class="section-lead">
          E判定からの志望校合格、勉強嫌いの克服、苦手だった教科が得意に変わる瞬間。フォレストには、生徒たち一人ひとりの「ビフォーアフター」があります。
        </p>
      </div>
      <div class="voices">
        <a href="https://kobetsu-forest.com/2018-12-17-08-20-44.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">大逆転合格</span>
          <h3>「もうダメかも」から、第一志望へ。</h3>
          <p>受験直前の追い込みで結果を変えた生徒たちのストーリー。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/2019-05-27-14-29-10.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">ビフォーアフター</span>
          <h3>勉強への向き合い方が、変わった。</h3>
          <p>入塾前と後で、生徒の変化を時系列で記録した実例集。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/diary.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">合格体験記一覧</span>
          <h3>すべての合格を、本人の言葉で。</h3>
          <p>歴代の塾生が綴った合格までの道のりをご覧ください。</p>
          <span class="voice-card__more">読む →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta__bg" aria-hidden="true"></div>
    <div class="container cta__inner">
      <span class="section-label">RESERVATION</span>
      <h2>
        まずは、お子さまの<br />
        「今」を聞かせてください。
      </h2>
      <p>
        ご相談は無料、入塾の無理な勧誘は一切ありません。<br />
        資料請求はかんたん1分。お電話でも、フォームでも、お好きな方法でどうぞ。
      </p>
      <ul class="cta__bullets">
        <li>スタート月謝 <strong>2ヶ月半額</strong> キャンペーン実施中</li>
        <li>入塾金は <strong>無料</strong></li>
        <li>講習会は <strong>希望者のみ・強制ゼロ</strong></li>
      </ul>
      <div class="cta__actions">
        <a href={`${base}contact/`} class="btn btn--white">
          無料資料請求・個別相談
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}price/`} class="btn btn--ghost">お月謝を見る</a>
      </div>
      <div class="cta__phones">
        <a href="tel:0669391001" class="cta__phone">
          <span class="cta__phone-label">蒲生四丁目駅前校</span>
          <span class="cta__phone-num">06-6939-1001</span>
        </a>
        <a href="tel:0643066300" class="cta__phone">
          <span class="cta__phone-label">今里校</span>
          <span class="cta__phone-num">06-4306-6300</span>
        </a>
      </div>
      <p class="cta__hours">受付時間：平日 14:00〜22:00 ／ 土曜 14:00〜21:00</p>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    padding: 56px 24px 80px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(135deg, var(--flame) 0%, var(--flame-deep) 100%);
  }

  /* 元サイト準拠の斜め三角パターン */
  .hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(255, 252, 246, 0.06) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(126, 18, 24, 0.5) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(126, 18, 24, 0.4) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 252, 246, 0.04) 75%);
    background-size: 56px 56px;
    background-position: 0 0, 0 28px, 28px -28px, -28px 0;
    opacity: 0.55;
  }

  .hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(244, 184, 114, 0.18), transparent 50%),
      radial-gradient(circle at 90% 10%, rgba(126, 18, 24, 0.4), transparent 50%);
  }

  .hero__inner {
    max-width: 1080px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero__card {
    background: var(--paper);
    border-radius: 28px;
    padding: 40px 48px 48px;
    box-shadow: 0 30px 80px rgba(20, 8, 8, 0.32), 0 0 0 1px rgba(255, 252, 246, 0.4);
    position: relative;
  }

  .hero__head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-bottom: 24px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--forest);
    color: var(--paper);
    font-size: 13px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 6px;
    letter-spacing: 0.02em;
    box-shadow: 0 3px 0 var(--forest-deep);
  }

  .hero__age {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-soft);
    padding: 6px 12px;
    background: var(--cream);
    border-radius: 999px;
    letter-spacing: 0.05em;
  }

  .hero__eyebrow {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-mute);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: 0.02em;
    margin-bottom: 24px;
  }

  .hero__title-pre {
    display: block;
    font-size: clamp(16px, 2.4vw, 22px);
    color: var(--ink);
    margin-bottom: 8px;
    font-weight: 700;
    line-height: 1.5;
  }

  .hero__title-main {
    display: block;
    font-size: clamp(44px, 8.5vw, 96px);
    line-height: 1.1;
    background: linear-gradient(180deg, var(--flame) 0%, var(--flame-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 2px 0 rgba(126, 18, 24, 0.08);
    letter-spacing: 0.01em;
  }

  .hero__lead {
    font-size: clamp(14.5px, 1.7vw, 16.5px);
    line-height: 2;
    color: var(--ink-soft);
    margin-bottom: 32px;
    max-width: 800px;
  }

  /* メインビジュアル写真 */
  .hero__photo {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 21 / 9;
    background: var(--cream);
    margin-bottom: 28px;
    box-shadow: var(--shadow-md);
  }

  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero__photo-tag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(20, 17, 15, 0.78);
    color: var(--paper);
    font-size: 12px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    letter-spacing: 0.05em;
  }

  /* 学年バッジ */
  .hero__targets {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .hero__target {
    background: var(--cream);
    border: 1.5px solid var(--line);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero__target--accent {
    background: linear-gradient(135deg, var(--flame), var(--flame-deep));
    border-color: var(--flame-deep);
    color: var(--paper);
  }

  .hero__target-label {
    font-size: 10px;
    color: var(--ink-mute);
    font-weight: 700;
    letter-spacing: 0.1em;
    background: var(--paper);
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .hero__target--accent .hero__target-label {
    color: var(--flame-deep);
    background: var(--flame-glow);
  }

  .hero__target-name {
    font-family: var(--font-serif);
    font-size: clamp(16px, 2.2vw, 20px);
    font-weight: 900;
    color: var(--ink);
  }

  .hero__target--accent .hero__target-name {
    color: var(--paper);
  }

  /* CTA + Tel */
  .hero__actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .btn--big {
    padding: 20px 36px;
    font-size: 17px;
  }

  .hero__tel {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--ink);
  }

  .hero__tel-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__tel-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero__tel-label {
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }

  .hero__tel-num {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  /* キャンペーン帯 */
  .hero__campaign {
    margin-top: 16px;
    padding: 14px 20px;
    background: linear-gradient(90deg, var(--flame-glow), #f7c585);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero__campaign-tag {
    font-size: 11px;
    font-weight: 700;
    color: var(--flame-deep);
    background: var(--paper);
    padding: 4px 12px;
    border-radius: 999px;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

  .hero__campaign-text {
    font-size: 14px;
    color: var(--flame-deep);
    font-weight: 600;
  }

  .hero__campaign-text strong {
    font-weight: 900;
    margin: 0 4px;
    font-size: 16px;
  }

  /* ===== PRINCIPAL ===== */
  .principal {
    background: var(--ink);
    color: var(--paper);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: 560px;
    overflow: hidden;
  }

  .principal__photo {
    position: relative;
    overflow: hidden;
    background: #2a1a1a;
  }

  .principal__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .principal__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 60%, var(--ink) 100%);
  }

  .principal__content {
    display: flex;
    align-items: center;
    padding: 80px 48px 80px 64px;
  }

  .principal__inner {
