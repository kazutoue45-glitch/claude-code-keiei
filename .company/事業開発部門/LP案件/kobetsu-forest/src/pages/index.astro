---
import Base from "../layouts/Base.astro";
import StatBlock from "../components/StatBlock.astro";
import StrengthCard from "../components/StrengthCard.astro";
import SchoolCard from "../components/SchoolCard.astro";

const base = import.meta.env.BASE_URL;

const strengths = [
  { number: "01", title: "つきっきりの個別指導", body: "1対2・1対3でも、わからないを見逃さない。問題を解くスピード・理解度・やる気の3つを毎回見ています。", icon: "users" },
  { number: "02", title: "成績で生徒を選ばない", body: "「できる子」だけ集めても本当の指導力は身につきません。一人ひとりの今からの伸びに本気で向き合います。", icon: "leaf" },
  { number: "03", title: "毎週土曜・無料質問クラス", body: "19:00〜22:00、5教科対応の自由質問クラス。塾生は何度来ても無料。「わからない」を翌週に持ち越しません。", icon: "calendar" },
  { number: "04", title: "中学受験 合格率100%", body: "2001年の開校以来、中学受験は合格率100%の実績。常翔学園・信愛女学院など地元中堅私学に対応。", icon: "star" },
  { number: "05", title: "平日17時から自習室開放", body: "「集中して勉強できる場所がある」だけで、家では出せない力が出ます。塾生は自由に使えます。", icon: "book" },
  { number: "06", title: "クラブ活動と両立できる時間割", body: "20:00〜21:50の遅い時間帯にも対応。部活で疲れた日も、無理なく通い続けられる仕組みです。", icon: "sun" },
];
---

<Base current="home">
  <!-- HERO: 1ビューポート完結。写真をカード全面背景にして大文字「個別指導」をオーバーレイ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>

    <div class="hero__container">
      <article class="hero__card">
        <img class="hero__photo" src={`${base}images/lesson.jpg`} alt="個別指導塾フォレストの個別指導の様子" />
        <div class="hero__mask" aria-hidden="true"></div>

        <div class="hero__content">
          <div class="hero__badges">
            <span class="hero__badge hero__badge--green">受験成功への第一歩</span>
            <span class="hero__badge hero__badge--age">2001年開校・地域密着25年</span>
          </div>

          <h1 class="hero__title">
            <span class="hero__title-pre">講師がずっと横にいる、ホンモノの</span>
            <span class="hero__title-main">
              <span>個</span><span>別</span><span>指</span><span>導</span>
            </span>
          </h1>

          <p class="hero__lead">
            <strong>安心の料金設定</strong>で、内容のぎっしり詰まった<br />
            質の高い<strong>個別授業</strong>が受けられます。
          </p>

          <div class="hero__targets">
            <span class="hero__target">小学生</span>
            <span class="hero__target">中学生</span>
            <span class="hero__target hero__target--accent">中学受験 合格率100%</span>
          </div>

          <div class="hero__actions">
            <a href={`${base}contact/`} class="hero__cta">
              <span class="hero__cta-mini">かんたん1分</span>
              <span class="hero__cta-main">無料資料請求・個別相談</span>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:0669391001" class="hero__tel">
              <span class="hero__tel-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span class="hero__tel-text">
                <span class="hero__tel-label">蒲生四丁目駅前校</span>
                <span class="hero__tel-num">06-6939-1001</span>
              </span>
            </a>
          </div>
        </div>
      </article>

      <!-- 元サイト準拠：白カード下の赤帯（他塾で〜） -->
      <div class="hero__strip">
        <strong>他塾で伸びなかった生徒の、成績アップを目指します</strong>
        <span class="hero__strip-area">大阪市城東区／生野区／東成区　2校舎</span>
      </div>
    </div>
  </section>

  <!-- 塾長メッセージ -->
  <section class="principal">
    <div class="principal__photo">
      <img src={`${base}images/jukucho.jpg`} alt="個別指導塾フォレスト 塾長 黒田清登" />
    </div>
    <div class="principal__content">
      <div class="principal__inner">
        <span class="section-label">塾長メッセージ</span>
        <h2>
          成績で、<br />
          生徒を選ばない。
        </h2>
        <p>
          たとえ時代がどのようにぶれようが、子供中心の視点から子供達が本当に望んでいることに応え、そして親の子供に対する熱い思いに共感することが、塾本来の役割だと、私は思っています。
        </p>
        <p>
          学校の先生より、塾の私たちは「本音で接する立場」にいます。教育現場の最前線で、子供達の小さな変化に気づき、保護者の皆様と並走する。それがフォレストの仕事です。
        </p>
        <div class="principal__sign">
          <span class="principal__sign-role">個別指導塾フォレスト 塾長</span>
          <span class="principal__sign-name">黒田 清登</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST IN NUMBERS</span>
        <h2 class="section-title">数字で見るフォレスト</h2>
      </div>
      <div class="stats-grid">
        <StatBlock value="25" unit="年" label="2001年開校・地域に根差した実績" accent="flame" />
        <StatBlock value="100" unit="%" label="中学受験 合格率（開校以来）" accent="flame" />
        <StatBlock value="2" unit="校" label="蒲生四丁目駅前校・今里校" accent="forest" />
        <StatBlock value="土" unit="" label="毎週土曜・無料質問クラス" accent="ember" />
      </div>
    </div>
  </section>

  <!-- Strengths -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST STRENGTHS</span>
        <h2 class="section-title">
          ホンモノの個別指導は<br class="sp-only" />
          「つきっきり」でなければならない。
        </h2>
        <p class="section-lead">
          フォレストの個別指導は、ただ机を並べるだけの時間ではありません。一問ごとに、生徒の理解度・スピード・表情まで見つめながら進める。それが、私たちが25年続けてきた指導の形です。
        </p>
      </div>

      <div class="strengths-grid">
        {strengths.map((s) => (
          <StrengthCard {...s} />
        ))}
      </div>

      <div class="strengths-more">
        <a href={`${base}strengths/`} class="btn btn--outline">
          強みの詳細を見る
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">SCHOOLS</span>
        <h2 class="section-title">通いやすい、地元の2校舎。</h2>
        <p class="section-lead">
          地元の小中学校に密着し、クラブ活動を終えた後でも通える時間割でお待ちしています。
        </p>
      </div>
      <div class="schools-grid">
        <SchoolCard
          name="蒲生四丁目駅前校"
          station="地下鉄今里筋線・長堀鶴見緑地線「蒲生四丁目駅」徒歩1分"
          address="大阪市城東区中央1丁目12-17 モーガ第１ビル2F"
          tel="06-6939-1001"
          image={`${base}images/gamou.png`}
          mapUrl="https://maps.google.com/?q=大阪市城東区中央1丁目12-17"
          accent="蒲生四丁目駅前校"
        />
        <SchoolCard
          name="今里校"
          station="地下鉄千日前線・今里筋線「今里駅」徒歩圏"
          address="大阪市生野区新今里3-1-2"
          tel="06-4306-6300"
          image={`${base}images/imazato.jpg`}
          mapUrl="https://maps.google.com/?q=大阪市生野区新今里3-1-2"
          accent="今里校"
        />
      </div>
    </div>
  </section>

  <!-- Voices -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">VOICES</span>
        <h2 class="section-title">大逆転の合格を、何度も見てきました。</h2>
        <p class="section-lead">
          E判定からの志望校合格、勉強嫌いの克服、苦手だった教科が得意に変わる瞬間。フォレストには、生徒たち一人ひとりの「ビフォーアフター」があります。
        </p>
      </div>
      <div class="voices">
        <a href="https://kobetsu-forest.com/2018-12-17-08-20-44.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">大逆転合格</span>
          <h3>「もうダメかも」から、第一志望へ。</h3>
          <p>受験直前の追い込みで結果を変えた生徒たちのストーリー。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/2019-05-27-14-29-10.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">ビフォーアフター</span>
          <h3>勉強への向き合い方が、変わった。</h3>
          <p>入塾前と後で、生徒の変化を時系列で記録した実例集。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/diary.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">合格体験記一覧</span>
          <h3>すべての合格を、本人の言葉で。</h3>
          <p>歴代の塾生が綴った合格までの道のりをご覧ください。</p>
          <span class="voice-card__more">読む →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta__bg" aria-hidden="true"></div>
    <div class="container cta__inner">
      <span class="section-label">RESERVATION</span>
      <h2>
        まずは、お子さまの<br />
        「今」を聞かせてください。
      </h2>
      <p>
        ご相談は無料、入塾の無理な勧誘は一切ありません。<br />
        資料請求はかんたん1分。お電話でも、フォームでも、お好きな方法でどうぞ。
      </p>
      <ul class="cta__bullets">
        <li>スタート月謝 <strong>2ヶ月半額</strong> キャンペーン実施中</li>
        <li>入塾金は <strong>無料</strong></li>
        <li>講習会は <strong>希望者のみ・強制ゼロ</strong></li>
      </ul>
      <div class="cta__actions">
        <a href={`${base}contact/`} class="btn btn--white">
          無料資料請求・個別相談
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}price/`} class="btn btn--ghost">お月謝を見る</a>
      </div>
      <div class="cta__phones">
        <a href="tel:0669391001" class="cta__phone">
          <span class="cta__phone-label">蒲生四丁目駅前校</span>
          <span class="cta__phone-num">06-6939-1001</span>
        </a>
        <a href="tel:0643066300" class="cta__phone">
          <span class="cta__phone-label">今里校</span>
          <span class="cta__phone-num">06-4306-6300</span>
        </a>
      </div>
      <p class="cta__hours">受付時間：平日 14:00〜22:00 ／ 土曜 14:00〜21:00</p>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO: 1ビューポート完結 ===== */
  .hero {
    position: relative;
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    padding: 28px 24px 32px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(135deg, var(--flame) 0%, var(--flame-deep) 100%);
  }

  .hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(255, 252, 246, 0.06) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(126, 18, 24, 0.55) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(126, 18, 24, 0.4) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 252, 246, 0.04) 75%);
    background-size: 56px 56px;
    background-position: 0 0, 0 28px, 28px -28px, -28px 0;
    opacity: 0.55;
  }

  .hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 100% 0%, rgba(244, 184, 114, 0.18), transparent 40%),
      radial-gradient(circle at 0% 100%, rgba(126, 18, 24, 0.4), transparent 50%);
  }

  .hero__container {
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  /* メインカード：写真をBG、テキストをoverlay */
  .hero__card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 24px 60px rgba(20, 8, 8, 0.32), 0 0 0 1px rgba(255, 252, 246, 0.45);
    aspect-ratio: 21 / 9;
    min-height: 480px;
    max-height: 620px;
  }

  .hero__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65% 45%;
    z-index: 1;
  }

  .hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(95deg, rgba(255, 252, 246, 0.97) 0%, rgba(255, 252, 246, 0.95) 38%, rgba(255, 252, 246, 0.65) 55%, rgba(255, 252, 246, 0.05) 75%, transparent 92%);
  }

  .hero__content {
    position: relative;
    z-index: 3;
    height: 100%;
    padding: 44px 56px 44px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 720px;
  }

  /* バッジ */
  .hero__badges {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 18px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    font-size: 12.5px;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }

  .hero__badge--green {
    background: var(--forest);
    color: var(--paper);
    box-shadow: 0 3px 0 var(--forest-deep);
  }

  .hero__badge--age {
    background: var(--paper);
    color: var(--ink);
    border: 1.5px solid var(--ink);
  }

  /* タイトル */
  .hero__title {
    font-family: var(--font-serif);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 22px;
  }

  .hero__title-pre {
    display: block;
    font-size: clamp(15px, 1.7vw, 19px);
    color: var(--ink);
    margin-bottom: 10px;
    font-weight: 700;
    line-height: 1.5;
  }

  .hero__title-main {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
    font-size: clamp(64px, 11vw, 132px);
    line-height: 0.95;
    letter-spacing: 0.02em;
  }

  .hero__title-main span {
    background: linear-gradient(180deg, var(--flame) 0%, var(--flame-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 2px 0 rgba(126, 18, 24, 0.06);
    display: inline-block;
    transform-origin: bottom center;
  }

  .hero__title-main span:nth-child(1) { transform: translateY(-2px); }
  .hero__title-main span:nth-child(2) { transform: translateY(2px); }
  .hero__title-main span:nth-child(3) { transform: translateY(-1px); }
  .hero__title-main span:nth-child(4) { transform: translateY(3px); }

  .hero__lead {
    font-size: clamp(13.5px, 1.5vw, 15.5px);
    line-height: 1.85;
    color: var(--ink-soft);
    margin-bottom: 22px;
    font-weight: 500;
  }

  .hero__lead strong {
    color: var(--flame-deep);
    font-weight: 900;
    background: linear-gradient(transparent 65%, rgba(244, 184, 114, 0.5) 65%);
    padding: 0 2px;
  }

  /* 学年バッジ */
  .hero__targets {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }

  .hero__target {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--paper);
    border: 2px solid var(--ink);
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 900;
    padding: 8px 20px;
    border-radius: 999px;
    letter-spacing: 0.05em;
    box-shadow: 2px 2px 0 var(--ink);
  }

  .hero__target--accent {
    background: var(--flame);
    border-color: var(--flame-deep);
    color: var(--paper);
    box-shadow: 2px 2px 0 var(--flame-deep);
  }

  /* CTA + Tel */
  .hero__actions {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .hero__cta {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    background: var(--flame);
    color: var(--paper);
    padding: 12px 28px;
    border-radius: 12px;
    font-weight: 700;
    box-shadow: 0 6px 0 var(--flame-deep), 0 12px 24px rgba(184, 35, 42, 0.32);
    transition: transform 0.15s, box-shadow 0.15s;
    position: relative;
  }

  .hero__cta:hover {
    transform: translateY(2px);
    box-shadow: 0 4px 0 var(--flame-deep), 0 8px 18px rgba(184, 35, 42, 0.32);
  }

  .hero__cta-mini {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--flame-glow);
  }

  .hero__cta-main {
    font-size: 17px;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .hero__cta svg {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
  }

  .hero__tel {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }

  .hero__tel-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__tel-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero__tel-label {
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.05em;
    margin-bottom: 1px;
  }

  .hero__tel-num {
    font-family: var(--font-serif);
    font-size: 21px;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  /* 下部の赤帯（元サイト準拠） */
  .hero__strip {
    margin-top: 16px;
    padding: 14px 28px;
    background: var(--paper);
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: space-between;
    border: 2px solid var(--ink);
  }

  .hero__strip strong {
    font-family: var(--font-serif);
    font-size: clamp(14px, 1.7vw, 18px);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .hero__strip-area {
    font-size: 12px;
    color: var(--ink-mute);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  /* ===== PRINCIPAL ===== */
  .principal {
    background: var(--ink);
    color: var(--paper);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: 540px;
    overflow: hidden;
  }

  .principal__photo {
