---
import Base from "../layouts/Base.astro";
import StatBlock from "../components/StatBlock.astro";
import StrengthCard from "../components/StrengthCard.astro";
import SchoolCard from "../components/SchoolCard.astro";

const base = import.meta.env.BASE_URL;

const strengths = [
  { number: "01", title: "つきっきりの個別指導", body: "1対2・1対3でも、わからないを見逃さない。問題を解くスピード・理解度・やる気の3つを毎回見ています。", icon: "users" },
  { number: "02", title: "成績で生徒を選ばない", body: "「できる子」だけ集めても本当の指導力は身につきません。一人ひとりの今からの伸びに本気で向き合います。", icon: "leaf" },
  { number: "03", title: "毎週土曜・無料質問クラス", body: "19:00〜22:00、5教科対応の自由質問クラス。塾生は何度来ても無料。「わからない」を翌週に持ち越しません。", icon: "calendar" },
  { number: "04", title: "中学受験 合格率100%", body: "2001年の開校以来、中学受験は合格率100%の実績。常翔学園・信愛女学院など地元中堅私学に対応。", icon: "star" },
  { number: "05", title: "平日17時から自習室開放", body: "「集中して勉強できる場所がある」だけで、家では出せない力が出ます。塾生は自由に使えます。", icon: "book" },
  { number: "06", title: "クラブ活動と両立できる時間割", body: "20:00〜21:50の遅い時間帯にも対応。部活で疲れた日も、無理なく通い続けられる仕組みです。", icon: "sun" },
];
---

<Base current="home">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="hero__inner container">
      <div class="hero__copy">
        <span class="hero__eyebrow">大阪市城東区・生野区・東成区／個別指導</span>
        <h1 class="hero__title">
          意志あるところに、<br />
          道は開ける。
        </h1>
        <p class="hero__lead">
          できる子を集めるのではなく、<br />
          目の前の一人を伸ばす塾でありたい。<br />
          フォレストは、つきっきりの個別指導で<br />
          子どもの「やる気の灯」を守ります。
        </p>
        <div class="hero__actions">
          <a href={`${base}contact/`} class="btn btn--flame">
            無料資料請求・個別相談
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={`${base}strengths/`} class="btn btn--outline">フォレストの強みを見る</a>
        </div>
        <div class="hero__campaign">
          <div class="hero__campaign-flame" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14-.22-4.05 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.15.43-2.29 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
          </div>
          <div>
            <strong>新年度キャンペーン</strong>
            <span>スタート月謝 2ヶ月半額／入塾金無料</span>
          </div>
        </div>
      </div>
      <div class="hero__media">
        <div class="hero__photo-frame">
          <img src={`${base}images/jukucho.jpg`} alt="塾長 黒田清登（炎）" />
          <div class="hero__photo-tag">
            <span class="hero__photo-tag-eyebrow">塾長</span>
            <span class="hero__photo-tag-name">黒田 清登</span>
            <span class="hero__photo-tag-nick">― 炎 ―</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="container">
      <div class="stats-grid">
        <StatBlock value="25" unit="年" label="2001年開校・地域に根差した実績" accent="forest" />
        <StatBlock value="100" unit="%" label="中学受験 合格率（開校以来）" accent="flame" />
        <StatBlock value="2" unit="校" label="蒲生四丁目駅前校・今里校" accent="ember" />
        <StatBlock value="土" unit="" label="毎週土曜・無料質問クラス" accent="forest" />
      </div>
    </div>
  </section>

  <!-- Principal message -->
  <section class="section section--cream">
    <div class="container">
      <div class="message-grid">
        <div class="message-grid__media">
          <img src={`${base}images/lesson.jpg`} alt="授業の様子" />
          <div class="message-grid__quote">
            <span>「成績で生徒を選ばない。」</span>
          </div>
        </div>
        <div class="message-grid__copy">
          <span class="section-label">塾長メッセージ</span>
          <h2 class="section-title">
            塾本来の役割は、<br />
            子どもの本音に応えること。
          </h2>
          <p>
            たとえ時代がどのようにぶれようが、子供中心の視点から子供達が本当に望んでいることに応え、そして親の子供に対する熱い思いに共感することが、塾本来の役割だと、私は思っています。
          </p>
          <p>
            学校の先生より、塾の私たちは「本音で接する立場」にいます。教育現場の最前線で、子供達の小さな変化に気づき、保護者の皆様と並走する。それがフォレストの仕事です。
          </p>
          <p class="message-grid__sign">
            個別指導塾フォレスト 塾長　<strong>黒田 清登</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strengths -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FORESTの強み</span>
        <h2 class="section-title">
          ホンモノの個別指導は<br class="sp-only" />
          「つきっきり」でなければならない。
        </h2>
        <p class="section-lead">
          フォレストの個別指導は、ただ机を並べるだけの時間ではありません。一問ごとに、生徒の理解度・スピード・表情まで見つめながら進める。それが、私たちが25年続けてきた指導の形です。
        </p>
      </div>

      <div class="strengths-grid">
        {strengths.map((s) => (
          <StrengthCard {...s} />
        ))}
      </div>

      <div class="strengths-more">
        <a href={`${base}strengths/`} class="btn btn--outline">
          強みの詳細を見る
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">教室案内</span>
        <h2 class="section-title">通いやすい、地元の2校舎。</h2>
        <p class="section-lead">
          地元の小中学校に密着し、クラブ活動を終えた後でも通える時間割でお待ちしています。
        </p>
      </div>
      <div class="schools-grid">
        <SchoolCard
          name="蒲生四丁目駅前校"
          station="地下鉄今里筋線・長堀鶴見緑地線「蒲生四丁目駅」徒歩1分"
          address="大阪市城東区中央1丁目12-17 モーガ第１ビル2F"
          tel="06-6939-1001"
          image={`${base}images/gamou.png`}
          mapUrl="https://maps.google.com/?q=大阪市城東区中央1丁目12-17"
          accent="蒲生四丁目駅前校"
        />
        <SchoolCard
          name="今里校"
          station="地下鉄千日前線・今里筋線「今里駅」徒歩圏"
          address="大阪市生野区新今里3-1-2"
          tel="06-4306-6300"
          image={`${base}images/imazato.jpg`}
          mapUrl="https://maps.google.com/?q=大阪市生野区新今里3-1-2"
          accent="今里校"
        />
      </div>
    </div>
  </section>

  <!-- Voice -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">合格体験記</span>
        <h2 class="section-title">大逆転の合格を、何度も見てきました。</h2>
        <p class="section-lead">
          E判定からの志望校合格、勉強嫌いの克服、苦手だった教科が得意に変わる瞬間。フォレストには、生徒たち一人ひとりの「ビフォーアフター」があります。
        </p>
      </div>
      <div class="voices">
        <a href="https://kobetsu-forest.com/2018-12-17-08-20-44.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">大逆転合格</span>
          <h3>「もうダメかも」から、第一志望へ。</h3>
          <p>受験直前の追い込みで結果を変えた生徒たちのストーリー。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/2019-05-27-14-29-10.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">ビフォーアフター</span>
          <h3>勉強への向き合い方が、変わった。</h3>
          <p>入塾前と後で、生徒の変化を時系列で記録した実例集。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/diary.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">合格体験記一覧</span>
          <h3>すべての合格を、本人の言葉で。</h3>
          <p>歴代の塾生が綴った合格までの道のりをご覧ください。</p>
          <span class="voice-card__more">読む →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--forest cta-section">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-grid__copy">
          <span class="section-label">資料請求・無料個別相談</span>
          <h2 class="section-title">
            まずは、お子さまの<br />
            「今」を聞かせてください。
          </h2>
          <p>
            ご相談は無料、入塾の無理な勧誘は一切ありません。資料請求はかんたん1分。お電話・フォーム・公式LINE、お好きな方法でご連絡ください。
          </p>
          <ul class="cta-grid__bullets">
            <li>スタート月謝 2ヶ月半額キャンペーン実施中</li>
            <li>入塾金は無料</li>
            <li>講習会は希望者のみ・強制ゼロ</li>
          </ul>
          <div class="cta-grid__actions">
            <a href={`${base}contact/`} class="btn btn--flame">
              無料資料請求・個別相談
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={`${base}price/`} class="btn btn--ghost">お月謝を見る</a>
          </div>
        </div>
        <div class="cta-grid__phones">
          <h3 class="cta-grid__phones-title">お電話でのご相談</h3>
          <a href="tel:0669391001" class="cta-grid__phone">
            <span class="cta-grid__phone-label">蒲生四丁目駅前校</span>
            <span class="cta-grid__phone-num">06-6939-1001</span>
          </a>
          <a href="tel:0643066300" class="cta-grid__phone">
            <span class="cta-grid__phone-label">今里校</span>
            <span class="cta-grid__phone-num">06-4306-6300</span>
          </a>
          <p class="cta-grid__hours">受付時間：平日 14:00〜22:00 ／ 土曜 14:00〜21:00</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 80px 0 100px;
    background: linear-gradient(180deg, #FAF6EC 0%, #F4EEDD 100%);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 85% 20%, rgba(232, 163, 61, 0.18), transparent 45%),
      radial-gradient(circle at 10% 80%, rgba(31, 77, 46, 0.08), transparent 40%);
  }

  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--forest);
    background: rgba(31, 77, 46, 0.08);
    padding: 8px 16px;
    border-radius: 999px;
    margin-bottom: 24px;
  }

  .hero__title {
    font-size: clamp(36px, 6vw, 60px);
    line-height: 1.3;
    color: var(--forest-deep);
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  .hero__lead {
    font-size: 16px;
    line-height: 2;
    color: var(--ink-soft);
    margin-bottom: 32px;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .hero__actions .btn--outline {
    background: transparent;
  }

  .hero__campaign {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 14px 22px;
    background: var(--paper);
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
  }

  .hero__campaign-flame {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--flame);
    color: var(--paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__campaign strong {
    display: block;
    font-size: 14px;
    color: var(--forest-deep);
    margin-bottom: 2px;
  }

  .hero__campaign span {
    font-size: 13px;
    color: var(--ink-soft);
  }

  .hero__media {
    position: relative;
  }

  .hero__photo-frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4 / 5;
    background: var(--forest-soft);
  }

  .hero__photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero__photo-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(20, 56, 32, 0.5) 100%);
  }

  .hero__photo-tag {
    position: absolute;
    bottom: 24px;
    left: 24px;
    z-index: 2;
    color: var(--paper);
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero__photo-tag-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--ember);
    margin-bottom: 4px;
  }

  .hero__photo-tag-name {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 4px;
  }

  .hero__photo-tag-nick {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* Message */
  .message-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }

  .message-grid__media {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 4 / 3;
  }

  .message-grid__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .message-grid__quote {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 24px;
    background: linear-gradient(180deg, transparent, rgba(20, 56, 32, 0.85));
    color: var(--paper);
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .message-grid__copy p {
    font-size: 15.5px;
    line-height: 2;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }

  .message-grid__sign {
    margin-top: 24px;
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--forest-deep);
  }

  .message-grid__sign strong {
    font-size: 22px;
    font-weight: 900;
    margin-left: 4px;
  }

  /* Strengths grid */
  .section-head {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-head .section-label,
  .section-head .section-title,
  .section-head .section-lead {
    margin-left: auto;
    margin-right: auto;
  }

  .strengths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .strengths-more {
    text-align: center;
    margin-top: 48px;
  }

  /* Schools */
  .schools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* Voices */
  .voices {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .voice-card {
    display: block;
    padding: 32px 28px;
    background: var(--cream);
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  }

  .voice-card:hover {
    transform: translateY(-4px);
    border-color: var(--forest);
    box-shadow: var(--shadow-md);
  }

  .voice-card__tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--flame);
    background: rgba(217, 75, 43, 0.1);
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  .voice-card h3 {
    font-size: 18px;
    color: var(--forest-deep);
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .voice-card p {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .voice-card__more {
    font-size: 13px;
    font-weight: 700;
    color: var(--forest);
  }

  /* CTA */
  .cta-section {
    background:
      radial-gradient(circle at 90% 10%, rgba(232, 163, 61, 0.15), transparent 50%),
      radial-gradient(circle at 10% 90%, rgba(217, 75, 43, 0.18), transparent 50%),
      var(--forest);
  }

  .cta-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .cta-grid p {
    color: rgba(255, 253, 248, 0.85);
    font-size: 15.5px;
    line-height: 2;
    margin-bottom: 24px;
  }

  .cta-grid__bullets {
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cta-grid__bullets li {
    color: var(--paper);
    font-size: 14.5px;
    padding-left: 28px;
    position: relative;
  }

  .cta-grid__bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ember);
  }

  .cta-grid__bullets li::after {
    content: "✓";
    position: absolute;
    left: 3px;
    top: 5px;
    color: var(--forest-deep);
    font-size: 11px;
    font-weight: 900;
  }

  .cta-grid__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-grid__phones {
    background: rgba(255, 253, 248, 0.06);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 253, 248, 0.18);
    border-radius: var(--radius-lg);
    padding: 32px;
  }

  .cta-grid__phones-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--ember);
    margin-bottom: 20px;
    font-family: var(--font-sans);
  }

  .cta-grid__phone {
    display: block;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 253, 248, 0.18);
    color: var(--paper);
  }

  .cta-grid__phone:last-of-type {
    border-bottom: none;
    margin-bottom: 12px;
  }

  .cta-grid__phone-label {
    display: block;
    font-size: 12px;
    color: rgba(255, 253, 248, 0.7);
    margin-bottom: 4px;
    letter-spacing: 0.05em;
  }

  .cta-grid__phone-num {
    display: block;
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .cta-grid__hours {
    font-size: 12px !important;
