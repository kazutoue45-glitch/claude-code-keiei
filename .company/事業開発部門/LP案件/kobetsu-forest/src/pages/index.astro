---
import Base from "../layouts/Base.astro";
import StatBlock from "../components/StatBlock.astro";
import StrengthCard from "../components/StrengthCard.astro";
import SchoolCard from "../components/SchoolCard.astro";

const base = import.meta.env.BASE_URL;

const strengths = [
  { number: "01", title: "つきっきりの個別指導", body: "1対2・1対3でも、わからないを見逃さない。問題を解くスピード・理解度・やる気の3つを毎回見ています。", icon: "users" },
  { number: "02", title: "成績で生徒を選ばない", body: "「できる子」だけ集めても本当の指導力は身につきません。一人ひとりの今からの伸びに本気で向き合います。", icon: "leaf" },
  { number: "03", title: "毎週土曜・無料質問クラス", body: "19:00〜22:00、5教科対応の自由質問クラス。塾生は何度来ても無料。「わからない」を翌週に持ち越しません。", icon: "calendar" },
  { number: "04", title: "中学受験 合格率100%", body: "2001年の開校以来、中学受験は合格率100%の実績。常翔学園・信愛女学院など地元中堅私学に対応。", icon: "star" },
  { number: "05", title: "平日17時から自習室開放", body: "「集中して勉強できる場所がある」だけで、家では出せない力が出ます。塾生は自由に使えます。", icon: "book" },
  { number: "06", title: "クラブ活動と両立できる時間割", body: "20:00〜21:50の遅い時間帯にも対応。部活で疲れた日も、無理なく通い続けられる仕組みです。", icon: "sun" },
];
---

<Base current="home">
  <!-- HERO: 1カラム・フルブリード・タイポグラフィ主役 -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__noise"></div>
      <span class="hero__kanji">炎</span>
    </div>

    <div class="hero__content">
      <span class="hero__eyebrow">大阪市城東区／生野区／東成区　個別指導　2001年開校</span>

      <h1 class="hero__title">
        <span class="hero__title-line1">意志あるところに、</span>
        <span class="hero__title-line2">道は開ける。</span>
      </h1>

      <p class="hero__lead">
        できる子を集めるのではなく、目の前の一人を伸ばす塾でありたい。<br />
        フォレストは、つきっきりの個別指導で「やる気の灯」を守り続けます。
      </p>

      <div class="hero__meta">
        <div class="hero__meta-item">
          <span class="hero__meta-num">25</span>
          <span class="hero__meta-unit">年</span>
          <span class="hero__meta-label">2001年開校</span>
        </div>
        <i class="hero__meta-divider" aria-hidden="true"></i>
        <div class="hero__meta-item">
          <span class="hero__meta-num">100</span>
          <span class="hero__meta-unit">%</span>
          <span class="hero__meta-label">中学受験合格率</span>
        </div>
        <i class="hero__meta-divider" aria-hidden="true"></i>
        <div class="hero__meta-item">
          <span class="hero__meta-num">2</span>
          <span class="hero__meta-unit">校</span>
          <span class="hero__meta-label">蒲生四丁目／今里</span>
        </div>
      </div>

      <div class="hero__actions">
        <a href={`${base}contact/`} class="btn btn--white">
          無料資料請求・個別相談
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}strengths/`} class="btn btn--ghost">フォレストの強みを見る</a>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <span>SCROLL</span>
      <i></i>
    </div>
  </section>

  <!-- 塾長紹介（横長フルブリード写真） -->
  <section class="principal">
    <div class="principal__photo">
      <img src={`${base}images/jukucho.jpg`} alt="塾長 黒田清登（炎）" />
    </div>
    <div class="principal__content">
      <div class="principal__inner">
        <span class="section-label">塾長メッセージ</span>
        <h2>
          成績で、<br />
          生徒を選ばない。
        </h2>
        <p>
          たとえ時代がどのようにぶれようが、子供中心の視点から子供達が本当に望んでいることに応え、そして親の子供に対する熱い思いに共感することが、塾本来の役割だと、私は思っています。
        </p>
        <p>
          学校の先生より、塾の私たちは「本音で接する立場」にいます。教育現場の最前線で、子供達の小さな変化に気づき、保護者の皆様と並走する。それがフォレストの仕事です。
        </p>
        <div class="principal__sign">
          <span class="principal__sign-role">個別指導塾フォレスト 塾長</span>
          <span class="principal__sign-name">黒田 清登</span>
          <span class="principal__sign-nick">― 炎 ―</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST IN NUMBERS</span>
        <h2 class="section-title">数字で見るフォレスト</h2>
      </div>
      <div class="stats-grid">
        <StatBlock value="25" unit="年" label="2001年開校・地域に根差した実績" accent="flame" />
        <StatBlock value="100" unit="%" label="中学受験 合格率（開校以来）" accent="flame" />
        <StatBlock value="2" unit="校" label="蒲生四丁目駅前校・今里校" accent="forest" />
        <StatBlock value="土" unit="" label="毎週土曜・無料質問クラス" accent="ember" />
      </div>
    </div>
  </section>

  <!-- Strengths -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">FOREST STRENGTHS</span>
        <h2 class="section-title">
          ホンモノの個別指導は<br class="sp-only" />
          「つきっきり」でなければならない。
        </h2>
        <p class="section-lead">
          フォレストの個別指導は、ただ机を並べるだけの時間ではありません。一問ごとに、生徒の理解度・スピード・表情まで見つめながら進める。それが、私たちが25年続けてきた指導の形です。
        </p>
      </div>

      <div class="strengths-grid">
        {strengths.map((s) => (
          <StrengthCard {...s} />
        ))}
      </div>

      <div class="strengths-more">
        <a href={`${base}strengths/`} class="btn btn--outline">
          強みの詳細を見る
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <span class="section-label">SCHOOLS</span>
        <h2 class="section-title">通いやすい、地元の2校舎。</h2>
        <p class="section-lead">
          地元の小中学校に密着し、クラブ活動を終えた後でも通える時間割でお待ちしています。
        </p>
      </div>
      <div class="schools-grid">
        <SchoolCard
          name="蒲生四丁目駅前校"
          station="地下鉄今里筋線・長堀鶴見緑地線「蒲生四丁目駅」徒歩1分"
          address="大阪市城東区中央1丁目12-17 モーガ第１ビル2F"
          tel="06-6939-1001"
          image={`${base}images/gamou.png`}
          mapUrl="https://maps.google.com/?q=大阪市城東区中央1丁目12-17"
          accent="蒲生四丁目駅前校"
        />
        <SchoolCard
          name="今里校"
          station="地下鉄千日前線・今里筋線「今里駅」徒歩圏"
          address="大阪市生野区新今里3-1-2"
          tel="06-4306-6300"
          image={`${base}images/imazato.jpg`}
          mapUrl="https://maps.google.com/?q=大阪市生野区新今里3-1-2"
          accent="今里校"
        />
      </div>
    </div>
  </section>

  <!-- Voices -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-label">VOICES</span>
        <h2 class="section-title">大逆転の合格を、何度も見てきました。</h2>
        <p class="section-lead">
          E判定からの志望校合格、勉強嫌いの克服、苦手だった教科が得意に変わる瞬間。フォレストには、生徒たち一人ひとりの「ビフォーアフター」があります。
        </p>
      </div>
      <div class="voices">
        <a href="https://kobetsu-forest.com/2018-12-17-08-20-44.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">大逆転合格</span>
          <h3>「もうダメかも」から、第一志望へ。</h3>
          <p>受験直前の追い込みで結果を変えた生徒たちのストーリー。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/2019-05-27-14-29-10.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">ビフォーアフター</span>
          <h3>勉強への向き合い方が、変わった。</h3>
          <p>入塾前と後で、生徒の変化を時系列で記録した実例集。</p>
          <span class="voice-card__more">読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/diary.html" target="_blank" rel="noopener" class="voice-card">
          <span class="voice-card__tag">合格体験記一覧</span>
          <h3>すべての合格を、本人の言葉で。</h3>
          <p>歴代の塾生が綴った合格までの道のりをご覧ください。</p>
          <span class="voice-card__more">読む →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA: 深紅フルブリード -->
  <section class="cta">
    <div class="cta__bg" aria-hidden="true"></div>
    <div class="container cta__inner">
      <span class="section-label">RESERVATION</span>
      <h2>
        まずは、お子さまの<br />
        「今」を聞かせてください。
      </h2>
      <p>
        ご相談は無料、入塾の無理な勧誘は一切ありません。<br />
        資料請求はかんたん1分。お電話でも、フォームでも、お好きな方法でどうぞ。
      </p>
      <ul class="cta__bullets">
        <li>スタート月謝 <strong>2ヶ月半額</strong> キャンペーン実施中</li>
        <li>入塾金は <strong>無料</strong></li>
        <li>講習会は <strong>希望者のみ・強制ゼロ</strong></li>
      </ul>
      <div class="cta__actions">
        <a href={`${base}contact/`} class="btn btn--white">
          無料資料請求・個別相談
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}price/`} class="btn btn--ghost">お月謝を見る</a>
      </div>
      <div class="cta__phones">
        <a href="tel:0669391001" class="cta__phone">
          <span class="cta__phone-label">蒲生四丁目駅前校</span>
          <span class="cta__phone-num">06-6939-1001</span>
        </a>
        <a href="tel:0643066300" class="cta__phone">
          <span class="cta__phone-label">今里校</span>
          <span class="cta__phone-num">06-4306-6300</span>
        </a>
      </div>
      <p class="cta__hours">受付時間：平日 14:00〜22:00 ／ 土曜 14:00〜21:00</p>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 92vh;
    padding: 80px 24px 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: var(--paper);
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(244, 184, 114, 0.25), transparent 55%),
      radial-gradient(ellipse at 80% 80%, rgba(126, 18, 24, 0.7), transparent 60%),
      linear-gradient(180deg, var(--flame-deep) 0%, #5a0d12 100%);
  }

  .hero__noise {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-image:
      repeating-linear-gradient(45deg, rgba(255, 252, 246, 0.04) 0 2px, transparent 2px 4px),
      radial-gradient(circle at 20% 50%, rgba(255, 252, 246, 0.08), transparent 30%),
      radial-gradient(circle at 70% 20%, rgba(244, 184, 114, 0.12), transparent 35%);
  }

  /* 巨大な「炎」漢字（背景） */
  .hero__kanji {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(420px, 80vw, 920px);
    color: rgba(255, 252, 246, 0.05);
    line-height: 0.85;
    letter-spacing: 0;
    pointer-events: none;
    user-select: none;
    text-shadow: 0 0 80px rgba(244, 184, 114, 0.12);
  }

  .hero__content {
    position: relative;
    max-width: 980px;
    width: 100%;
    z-index: 2;
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--flame-glow);
    border: 1px solid rgba(244, 184, 114, 0.5);
    padding: 8px 22px;
    border-radius: 999px;
    margin-bottom: 36px;
    background: rgba(126, 18, 24, 0.25);
    backdrop-filter: blur(6px);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0.04em;
    margin-bottom: 32px;
    text-shadow: 0 8px 40px rgba(20, 17, 15, 0.45);
  }

  .hero__title-line1 {
    display: block;
    font-size: clamp(28px, 5vw, 52px);
    color: var(--flame-glow);
    margin-bottom: 12px;
    font-weight: 700;
  }

  .hero__title-line2 {
    display: block;
    font-size: clamp(56px, 11vw, 132px);
    color: var(--paper);
    line-height: 1.1;
  }

  .hero__lead {
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 2.2;
    color: rgba(255, 252, 246, 0.92);
    margin-bottom: 48px;
    font-weight: 400;
  }

  /* メタ（数字3つを横並び） */
  .hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 28px;
    padding: 22px 36px;
    background: rgba(20, 17, 15, 0.32);
    border: 1px solid rgba(255, 252, 246, 0.18);
    border-radius: 100px;
    backdrop-filter: blur(8px);
    margin-bottom: 48px;
  }

  .hero__meta-item {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .hero__meta-num {
    font-family: var(--font-serif);
    font-size: 36px;
    font-weight: 900;
    color: var(--flame-glow);
    line-height: 1;
  }

  .hero__meta-unit {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--flame-glow);
    margin-right: 6px;
  }

  .hero__meta-label {
    font-size: 11px;
    color: rgba(255, 252, 246, 0.78);
    letter-spacing: 0.1em;
    margin-left: 2px;
  }

  .hero__meta-divider {
    width: 1px;
    height: 32px;
    background: rgba(255, 252, 246, 0.22);
  }

  .hero__actions {
    display: inline-flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    color: rgba(255, 252, 246, 0.6);
    font-size: 10px;
    letter-spacing: 0.3em;
    z-index: 3;
  }

  .hero__scroll i {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, rgba(255, 252, 246, 0.6), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ===== PRINCIPAL ===== */
  .principal {
    background: var(--ink);
    color: var(--paper);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: 600px;
    overflow: hidden;
  }

  .principal__photo {
    position: relative;
    overflow: hidden;
    background: #2a1a1a;
  }

  .principal__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    filter: contrast(1.05) saturate(0.95);
  }

  .principal__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 60%, var(--ink) 100%);
  }

  .principal__content {
    display: flex;
    align-items: center;
    padding: 80px 48px 80px 64px;
  }

  .principal__inner {
    max-width: 520px;
  }

  .principal__inner h2 {
    font-size: clamp(32px, 4.5vw, 52px);
    color: var(--paper);
    margin: 16px 0 28px;
    line-height: 1.4;
    letter-spacing: 0.04em;
  }

  .principal__inner p {
    font-size: 15.5px;
    line-height: 2.1;
    color: rgba(255, 252, 246, 0.84);
    margin-bottom: 20px;
  }

  .principal__sign {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 252, 246, 0.18);
    display: flex;
    flex-direction: column;
    line-height: 1.4;
  }

  .principal__sign-role {
    font-size: 12px;
    color: rgba(255, 252, 246, 0.6);
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }

  .principal__sign-name {
    font-family: var(--font-serif);
    font-size: 30px;
    font-weight: 900;
    color: var(--paper);
    margin-bottom: 2px;
  }

  .principal__sign-nick {
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--flame-glow);
    letter-spacing: 0.15em;
  }

  /* ===== SECTION HEAD ===== */
  .section-head {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-head .section-label,
  .section-head .section-title,
  .section-head .section-lead {
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== STATS ===== */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* ===== STRENGTHS ===== */
  .strengths-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .strengths-more {
    text-align: center;
    margin-top: 56px;
  }

  /* ===== SCHOOLS ===== */
  .schools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* ===== VOICES ===== */
  .voices {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .voice-card {
    display: block;
    padding: 32px 28px;
    background: var(--paper);
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
  }

  .voice-card:hover {
    transform: translateY(-4px);
    border-color: var(--flame);
    box-shadow: var(--shadow-md);
  }

  .voice-card__tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--flame);
    background: rgba(184, 35, 42, 0.1);
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 16px;
  }

  .voice-card h3 {
    font-size: 18px;
    color: var(--ink);
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .voice-card p {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.85;
    margin-bottom: 16px;
  }

  .voice-card__more {
    font-size: 13px;
    font-weight: 700;
    color: var(--flame);
  }

  /* ===== CTA ===== */
  .cta {
    position: relative;
    padding: 96px 0 112px;
    color: var(--paper);
    overflow: hidden;
    isolation: isolate;
  }

  .cta__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(244, 184, 114, 0.2), transparent 50%),
