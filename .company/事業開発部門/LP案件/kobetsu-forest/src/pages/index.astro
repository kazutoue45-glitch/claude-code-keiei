---
import Base from "../layouts/Base.astro";
import SchoolCard from "../components/SchoolCard.astro";

const base = import.meta.env.BASE_URL;

const strengths = [
  { num: "01", title: "1対2・1対3のつきっきり指導", body: "わからない箇所をその場で潰します。問題を解くスピード・理解度・やる気を一回ごとに見ています。" },
  { num: "02", title: "成績で生徒を選ばない", body: "「できる子」だけ集めません。今の偏差値ではなく、これから伸ばす力に本気で向き合う方針です。" },
  { num: "03", title: "毎週土曜の無料質問クラス", body: "19:00〜22:00、5教科対応。塾生は何度来ても無料です。「わからない」を翌週に持ち越しません。" },
  { num: "04", title: "中学受験 合格率100%", body: "2001年の開校以来、中学受験は合格率100%。常翔学園・信愛女学院など地元中堅私学に対応します。" },
  { num: "05", title: "平日17時〜の自習室", body: "塾生は自由に使えます。家では出せない集中力が、ここなら出る。講師がそばにいるので質問もすぐ。" },
  { num: "06", title: "クラブ活動と両立", body: "20:00〜21:50の遅い時間帯にも対応。部活で疲れた日も、無理なく通い続けられる時間割です。" },
];
---

<Base current="home">
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>

    <div class="hero__container">
      <article class="hero__card">
        <img class="hero__photo" src={`${base}images/lesson.jpg`} alt="個別指導塾フォレストの個別指導の様子" />
        <div class="hero__mask" aria-hidden="true"></div>

        <div class="hero__content">
          <div class="hero__badges">
            <span class="hero__badge hero__badge--green">受験成功への第一歩</span>
            <span class="hero__badge hero__badge--age">2001年開校・地域密着25年</span>
          </div>

          <h1 class="hero__title">
            <span class="hero__title-pre">講師がずっと横にいる、ホンモノの</span>
            <span class="hero__title-main">個別指導</span>
          </h1>

          <p class="hero__lead">
            安心の料金設定で、内容のぎっしり詰まった<br />
            質の高い個別授業が受けられます。
          </p>

          <div class="hero__targets">
            <span class="hero__target">小学生</span>
            <span class="hero__target">中学生</span>
            <span class="hero__target hero__target--accent">中学受験 合格率100%</span>
          </div>

          <div class="hero__actions">
            <a href={`${base}contact/`} class="hero__cta">
              <span class="hero__cta-mini">かんたん1分</span>
              <span class="hero__cta-main">無料資料請求・個別相談</span>
            </a>
            <a href="tel:0669391001" class="hero__tel">
              <span class="hero__tel-text">
                <span class="hero__tel-label">蒲生四丁目駅前校</span>
                <span class="hero__tel-num">06-6939-1001</span>
              </span>
            </a>
          </div>
        </div>
      </article>

      <div class="hero__strip">
        <strong>他塾で伸びなかった生徒の、成績アップを目指します</strong>
        <span class="hero__strip-area">大阪市城東区／生野区／東成区　2校舎</span>
      </div>
    </div>
  </section>

  <!-- 塾長メッセージ -->
  <section class="principal">
    <div class="principal__photo">
      <img src={`${base}images/jukucho.jpg`} alt="個別指導塾フォレスト 塾長 黒田清登" />
    </div>
    <div class="principal__content">
      <div class="principal__inner">
        <span class="section-label">塾長より、保護者のみなさまへ</span>
        <h2>成績で、<br />生徒を選ばない。</h2>
        <p>
          たとえ時代がどのようにぶれようが、子供中心の視点から子供達が本当に望んでいることに応え、そして親の子供に対する熱い思いに共感することが、塾本来の役割だと、私は思っています。
        </p>
        <p>
          学校の先生より、塾の私たちは「本音で接する立場」にいます。教育現場の最前線で、子供達の小さな変化に気づき、保護者の皆様と並走する。それがフォレストの仕事です。
        </p>
        <div class="principal__sign">
          <span class="principal__sign-role">個別指導塾フォレスト 塾長</span>
          <span class="principal__sign-name">黒田 清登</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 数字 -->
  <section class="numbers">
    <div class="container">
      <div class="numbers__head">
        <span class="section-label">数字でわかるフォレスト</span>
        <h2>地域に根を張って、25年。</h2>
      </div>
      <div class="numbers__grid">
        <div class="num-item">
          <div class="num-item__num"><span>25</span><small>年</small></div>
          <div class="num-item__label">2001年開校・地域に根差した実績</div>
        </div>
        <div class="num-item num-item--accent">
          <div class="num-item__num"><span>100</span><small>％</small></div>
          <div class="num-item__label">中学受験 合格率（開校以来）</div>
        </div>
        <div class="num-item">
          <div class="num-item__num"><span>2</span><small>校</small></div>
          <div class="num-item__label">蒲生四丁目駅前校・今里校</div>
        </div>
        <div class="num-item">
          <div class="num-item__num"><span>1</span><small>対2〜3</small></div>
          <div class="num-item__label">完全個別の少人数指導</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 強み -->
  <section class="strengths">
    <div class="container">
      <div class="strengths__head">
        <span class="section-label">フォレストの強み</span>
        <h2>
          ホンモノの個別指導は、<br class="sp-only" />
          「つきっきり」でなければならない。
        </h2>
        <p>
          フォレストの個別指導は、机を並べるだけの時間ではありません。一問ごとに、生徒の理解度・スピード・表情まで見つめながら進める。それが私たちが25年続けてきた指導の形です。
        </p>
      </div>

      <div class="strengths__list">
        {strengths.map((s) => (
          <div class="str-row">
            <div class="str-row__num">
              <span class="str-row__num-mini">No.</span>
              <span class="str-row__num-big">{s.num}</span>
            </div>
            <div class="str-row__body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="strengths__more">
        <a href={`${base}strengths/`} class="btn btn--outline">強みの詳細を読む</a>
      </div>
    </div>
  </section>

  <!-- 教室案内 -->
  <section class="schools-section">
    <div class="container">
      <div class="schools-section__head">
        <span class="section-label">通える、地元の2校舎</span>
        <h2>クラブ活動の後でも通える時間割。</h2>
      </div>
      <div class="schools-grid">
        <SchoolCard
          name="蒲生四丁目駅前校"
          station="地下鉄今里筋線・長堀鶴見緑地線「蒲生四丁目駅」徒歩1分"
          address="大阪市城東区中央1丁目12-17 モーガ第１ビル2F"
          tel="06-6939-1001"
          image={`${base}images/gamou.png`}
          mapUrl="https://maps.google.com/?q=大阪市城東区中央1丁目12-17"
          accent="蒲生四丁目駅前校"
        />
        <SchoolCard
          name="今里校"
          station="地下鉄千日前線・今里筋線「今里駅」徒歩圏"
          address="大阪市生野区新今里3-1-2"
          tel="06-4306-6300"
          image={`${base}images/imazato.jpg`}
          mapUrl="https://maps.google.com/?q=大阪市生野区新今里3-1-2"
          accent="今里校"
        />
      </div>
    </div>
  </section>

  <!-- 合格体験記 -->
  <section class="voices-section">
    <div class="container">
      <div class="voices-section__head">
        <span class="section-label">合格体験記</span>
        <h2>大逆転の合格を、何度も見てきました。</h2>
      </div>
      <div class="voices">
        <a href="https://kobetsu-forest.com/2018-12-17-08-20-44.html" target="_blank" rel="noopener" class="voice">
          <div class="voice__head">
            <span class="voice__tag">大逆転合格</span>
          </div>
          <h3>「もうダメかも」から、第一志望へ。</h3>
          <p>受験直前の追い込みで結果を変えた生徒たちのストーリーをご覧いただけます。</p>
          <span class="voice__more">記事を読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/2019-05-27-14-29-10.html" target="_blank" rel="noopener" class="voice">
          <div class="voice__head">
            <span class="voice__tag">ビフォーアフター</span>
          </div>
          <h3>勉強への向き合い方が、変わった。</h3>
          <p>入塾前と後で、生徒の変化を時系列で記録した実例集をご覧いただけます。</p>
          <span class="voice__more">記事を読む →</span>
        </a>
        <a href="https://kobetsu-forest.com/diary.html" target="_blank" rel="noopener" class="voice">
          <div class="voice__head">
            <span class="voice__tag">合格体験記一覧</span>
          </div>
          <h3>すべての合格を、本人の言葉で。</h3>
          <p>歴代の塾生が綴った合格までの道のりをご覧いただけます。</p>
          <span class="voice__more">記事を読む →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-grid__left">
          <span class="section-label">資料請求・お問い合わせ</span>
          <h2>
            まずは、お子さまの<br />
            「今」を聞かせてください。
          </h2>
          <p>
            ご相談は無料、入塾の無理な勧誘は一切ありません。資料請求はかんたん1分。お電話・フォーム・お好きな方法でご連絡ください。
          </p>
          <ul class="cta-grid__bullets">
            <li><span>新年度キャンペーン</span>スタート月謝 <strong>2ヶ月半額</strong></li>
            <li><span>入塾金</span>通常22,000円が <strong>無料</strong></li>
            <li><span>講習会</span>希望者のみ・<strong>強制ゼロ</strong></li>
          </ul>
          <div class="cta-grid__actions">
            <a href={`${base}contact/`} class="btn btn--flame">無料資料請求・個別相談</a>
            <a href={`${base}price/`} class="btn btn--outline">お月謝表を見る</a>
          </div>
        </div>
        <div class="cta-grid__right">
          <h3 class="cta-grid__phones-title">お電話でのご相談</h3>
          <a href="tel:0669391001" class="cta-grid__phone">
            <span class="cta-grid__phone-label">蒲生四丁目駅前校</span>
            <span class="cta-grid__phone-num">06-6939-1001</span>
          </a>
          <a href="tel:0643066300" class="cta-grid__phone">
            <span class="cta-grid__phone-label">今里校</span>
            <span class="cta-grid__phone-num">06-4306-6300</span>
          </a>
          <p class="cta-grid__hours">受付：平日 14:00〜22:00 ／ 土曜 14:00〜21:00</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    padding: 28px 24px 32px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--flame);
  }

  .hero__bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(255, 252, 246, 0.06) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(126, 18, 24, 0.55) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(126, 18, 24, 0.4) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 252, 246, 0.04) 75%);
    background-size: 56px 56px;
    background-position: 0 0, 0 28px, 28px -28px, -28px 0;
    opacity: 0.55;
  }

  .hero__container {
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .hero__card {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 16px 40px rgba(20, 8, 8, 0.32);
    aspect-ratio: 21 / 9;
    min-height: 480px;
    max-height: 600px;
    border: 4px solid var(--paper);
  }

  .hero__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% 40%;
    z-index: 1;
  }

  .hero__mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(95deg, rgba(255, 252, 246, 0.97) 0%, rgba(255, 252, 246, 0.95) 38%, rgba(255, 252, 246, 0.65) 55%, rgba(255, 252, 246, 0.05) 75%, transparent 92%);
  }

  .hero__content {
    position: relative;
    z-index: 3;
    height: 100%;
    padding: 44px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 720px;
  }

  .hero__badges {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 700;
    padding: 6px 14px;
    letter-spacing: 0.02em;
  }

  .hero__badge--green {
    background: var(--forest);
    color: var(--paper);
  }

  .hero__badge--age {
    background: var(--cream);
    color: var(--ink);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 22px;
  }

  .hero__title-pre {
    display: block;
    font-size: clamp(15px, 1.7vw, 19px);
    color: var(--ink);
    margin-bottom: 12px;
    font-weight: 700;
    line-height: 1.5;
  }

  .hero__title-main {
    display: block;
    font-size: clamp(64px, 11vw, 132px);
    line-height: 0.95;
    color: var(--flame-deep);
    letter-spacing: 0.04em;
  }

  .hero__lead {
    font-size: clamp(13.5px, 1.5vw, 15.5px);
    line-height: 1.95;
    color: var(--ink);
    margin-bottom: 22px;
    font-weight: 500;
  }

  .hero__targets {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .hero__target {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 900;
    padding: 6px 18px;
    letter-spacing: 0.05em;
  }

  .hero__target--accent {
    background: var(--flame);
    border-color: var(--flame-deep);
    color: var(--paper);
  }

  .hero__actions {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .hero__cta {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    background: var(--flame);
    color: var(--paper);
    padding: 12px 32px 14px;
    font-weight: 700;
    border: 2px solid var(--flame-deep);
  }

  .hero__cta:hover {
    background: var(--flame-deep);
  }

  .hero__cta-mini {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--flame-glow);
    margin-bottom: 1px;
  }

  .hero__cta-main {
    font-size: 16.5px;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .hero__tel {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }

  .hero__tel-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero__tel-label {
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.05em;
  }

  .hero__tel-num {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .hero__strip {
    margin-top: 12px;
    padding: 12px 24px;
    background: var(--paper);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .hero__strip strong {
    font-family: var(--font-serif);
    font-size: clamp(14px, 1.6vw, 17px);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .hero__strip-area {
    font-size: 12px;
    color: var(--ink-mute);
    font-weight: 600;
  }

  /* ===== PRINCIPAL ===== */
  .principal {
    background: var(--ink);
    color: var(--paper);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: 540px;
    overflow: hidden;
  }

  .principal__photo {
    position: relative;
    overflow: hidden;
    background: #2a1a1a;
  }

  .principal__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .principal__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 60%, var(--ink) 100%);
  }

  .principal__content {
    display: flex;
    align-items: center;
    padding: 72px 48px 72px 56px;
  }

  .principal__inner { max-width: 540px; }

  .principal__inner h2 {
    font-size: clamp(30px, 4.2vw, 48px);
    color: var(--paper);
    margin: 6px 0 26px;
    line-height: 1.4;
    letter-spacing: 0.04em;
  }

  .principal__inner p {
    font-size: 15px;
    line-height: 2.05;
    color: rgba(255, 252, 246, 0.84);
    margin-bottom: 18px;
  }

  .principal__sign {
    margin-top: 32px;
    padding-top: 22px;
    border-top: 1px solid rgba(255, 252, 246, 0.18);
    display: flex;
    flex-direction: column;
    line-height: 1.4;
  }

  .principal__sign-role {
    font-size: 12px;
    color: rgba(255, 252, 246, 0.6);
    margin-bottom: 6px;
  }

  .principal__sign-name {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 900;
    color: var(--paper);
  }

  /* ===== NUMBERS ===== */
  .numbers {
    background: var(--cream);
    padding: 88px 0;
  }

  .numbers__head {
    text-align: center;
    margin-bottom: 56px;
  }

  .numbers__head h2 {
    font-size: clamp(26px, 3.6vw, 36px);
    color: var(--ink);
  }

  .numbers__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--paper);
    border: 2px solid var(--ink);
  }

  .num-item {
    padding: 32px 24px;
    text-align: center;
    border-right: 1px solid var(--line);
  }

  .num-item:last-child { border-right: none; }

  .num-item--accent {
    background: var(--flame);
    color: var(--paper);
  }

  .num-item__num {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 6px;
    margin-bottom: 8px;
    font-family: var(--font-serif);
    line-height: 1;
  }

  .num-item__num span {
    font-size: clamp(48px, 6vw, 72px);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  .num-item--accent .num-item__num span {
    color: var(--paper);
  }

  .num-item__num small {
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
  }

  .num-item--accent .num-item__num small {
    color: var(--flame-glow);
  }

  .num-item__label {
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .num-item--accent .num-item__label {
    color: rgba(255, 252, 246, 0.92);
  }

  /* ===== STRENGTHS ===== */
  .strengths {
    padding: 96px 0;
  }

  .strengths__head {
    max-width: 720px;
    margin-bottom: 64px;
  }

  .strengths__head h2 {
    font-size: clamp(28px, 4vw, 40px);
    color: var(--ink);
    margin-bottom: 18px;
    line-height: 1.5;
